// BSLLS:LatinAndCyrillicSymbolInWord-off
////////////////////////////////////////////////////////////////////////////////
// Модуль для десериализации YAML документов
// 
// Поддерживает парсинг различных типов YAML структур:
// - Объекты (соответствия)
// - Массивы 
// - Скалярные значения
// - Многострочные строки
// - Flow-синтаксис (объекты и массивы)
// - Якоря и алиасы

#Использовать logos

////////////////////////////////////////////////////////////////////////////////
// ПЕРЕМЕННЫЕ МОДУЛЯ
////////////////////////////////////////////////////////////////////////////////

// Логгер для отладочной информации
Перем Лог;

// YAML константы документов
Перем YAML_РАЗДЕЛИТЕЛЬ_ДОКУМЕНТА;      // = "---"
Перем YAML_ТЕРМИНАТОР_ДОКУМЕНТА;       // = "..."

// Константы парсинга
Перем МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ; // = 2
Перем ДЕЙСТВИЕ_ПРЕРВАТЬ;                // = "прервать"

// Константы численных систем
Перем ДЛИНА_ПРЕФИКСА_ШЕСТНАДЦАТЕРИЧНОГО_ЧИСЛА; // = 2  
Перем ОСНОВАНИЕ_ДЕСЯТИЧНОЙ_СИСТЕМЫ;            // = 10
Перем ОСНОВАНИЕ_ШЕСТНАДЦАТЕРИЧНОЙ_СИСТЕМЫ;     // = 16

// Константы типов кавычек
Перем ТИП_КАВЫЧЕК_ДВОЙНЫЕ;              // = "double"
Перем ТИП_КАВЫЧЕК_ОДИНАРНЫЕ;            // = "single"

// Сообщения об ошибках
Перем ОШИБКА_ЛИШНИЕ_ЗАПЯТЫЕ_FLOW;      // = "Flow последовательность содержит лишние запятые"

// Состояние парсинга
Перем ТекущиеТАГДирективы;             // Хранилище TAG директив
Перем ВстречалаYAMLДиректива;          // Флаг встречи YAML директивы в текущем документе

Перем Якоря; // Соответствие для хранения якорей

// Кэш для регулярных выражений для оптимизации производительности
Перем КэшРегулярныхВыражений;

// Статический массив управляющих символов для оптимизации
Перем СтатическийМассивУправляющихСимволов;

// Кэш для типов строк для избежания повторных вычислений
Перем КэшТиповСтрок;

////////////////////////////////////////////////////////////////////////////////
// ФАБРИКА СТРУКТУР
////////////////////////////////////////////////////////////////////////////////

// Создает структуру результата обработки документа
//
// Параметры:
//   Документ - Массив - документ для возврата
//
// Возвращаемое значение:
//   Структура - структура с полем Документ
//
Функция СоздатьРезультатОбработкиДокумента(Документ)
    Возврат Новый Структура("Документ", Документ);
КонецФункции

// Создает структуру для управляющего символа и его позиции
//
// Параметры:
//   Символ - Строка - найденный символ
//   Позиция - Число - позиция символа
//
// Возвращаемое значение:
//   Структура - структура с полями Символ и Позиция
//
Функция СоздатьСтруктуруУправляющегоСимвола(Символ = "", Позиция = 0)
    Возврат Новый Структура("Символ, Позиция", Символ, Позиция);
КонецФункции

// Создает структуру результата обработки сущности
//
// Параметры:
//   Сущность - Структура - обработанная сущность
//   НовыйИндекс - Число - новый индекс для продолжения обработки
//
// Возвращаемое значение:
//   Структура - структура с полями Сущность и НовыйИндекс
//
Функция СоздатьРезультатОбработкиСущности(Сущность, НовыйИндекс)
    Возврат Новый Структура("Сущность, НовыйИндекс", Сущность, НовыйИндекс);
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ПУБЛИЧНЫЕ МЕТОДЫ
////////////////////////////////////////////////////////////////////////////////

// Основная функция для десериализации YAML
//
// Параметры:
//   СтрокаYaml - Строка - YAML-строка для парсинга
//
// Возвращаемое значение:
//   Массив - массив распарсенных документов YAML
//
// Исключения:
//   При некорректном синтаксисе YAML
//
Функция Прочитать(СтрокаYaml) Экспорт
    Лог.Отладка("Начало десериализации YAML");
    Если ПустаяСтрока(СтрокаYaml) Тогда
        Лог.Отладка("Входная строка YAML пуста, возвращаем пустое соответствие");
        Возврат Новый Соответствие();
    КонецЕсли;
    
    // Очищаем TAG директивы перед началом парсинга
    ТекущиеТАГДирективы.Очистить();
    
    // Сбрасываем флаг YAML директивы
    ВстречалаYAMLДиректива = Ложь;
    
    // Очищаем якоря перед началом парсинга
    Якоря.Очистить();
    
    // Очищаем кэш типов строк перед началом парсинга
    КэшТиповСтрок.Очистить();
    
    
    // Разбиваем на строки
    Строки = СтрРазделить(СтрокаYaml, Символы.ПС);
    Лог.Отладка("Строка YAML разбита на " + Строки.Количество() + " строк");
    
    МассивДокументов = Новый Массив();
    МассивСтрокДокументов = РазбитьНаДокументы(Строки);
    Лог.Отладка("Найдено " + МассивСтрокДокументов.Количество() + " документов YAML");
    
    Для каждого СтрокиДокумента Из МассивСтрокДокументов Цикл
        Лог.Отладка("Обработка документа с " + СтрокиДокумента.Количество() + " строками");
        РезультатДокумента = ДанныеИзМассиваСтрок(СтрокиДокумента);
        // Всегда добавляем результат документа, даже если это Неопределено (пустой документ -> null)
        МассивДокументов.Добавить(РезультатДокумента);
    КонецЦикла;
    
    // Лог.Отладка("Десериализация YAML завершена успешно");
    Возврат МассивДокументов;
    
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// МЕТОДЫ РАБОТЫ С ДОКУМЕНТАМИ
////////////////////////////////////////////////////////////////////////////////

// Разбивает массив строк на отдельные YAML документы
//
// Параметры:
//   МассивСтрок - Массив - массив строк исходного YAML
//
// Возвращаемое значение:
//   Массив - массив документов, каждый документ представлен массивом строк
//
Функция РазбитьНаДокументы(МассивСтрок)
    Лог.Отладка("Начало разбиения на документы");
    МассивСтрокДокументов = Новый Массив();
    Документ = Неопределено; // Начинаем без документа
    
    Для Каждого Строка Из МассивСтрок Цикл
        Результат = ОбработатьСтрокуДокумента(Строка, Документ, МассивСтрокДокументов);
        Документ = Результат.Документ;
    КонецЦикла;
    
    Если Не Документ = Неопределено Тогда
        МассивСтрокДокументов.Добавить(Документ);
    ИначеЕсли ВстречалаYAMLДиректива Тогда
        // Если была YAML директива, но нет документа - это ошибка
        ВызватьИсключение "YAML директива без последующего документа";
    КонецЕсли;
    
    Лог.Отладка("Разбиение на документы завершено, найдено " + МассивСтрокДокументов.Количество() + " документов");
    Возврат МассивСтрокДокументов;
КонецФункции

// Обрабатывает одну строку документа
//
// Параметры:
//   Строка - Строка - обрабатываемая строка
//   Документ - Массив - текущий документ
//   МассивСтрокДокументов - Массив - массив всех документов
//
// Возвращаемое значение:
//   Структура - результат обработки с полем Документ
//
Функция ОбработатьСтрокуДокумента(Строка, Документ, МассивСтрокДокументов)
    
    Если ЭтоДействительныйРазделительДокумента(Строка) Тогда
        Лог.Отладка("Найден разделитель документа " + YAML_РАЗДЕЛИТЕЛЬ_ДОКУМЕНТА);
        Документ = ОбработатьРазделительДокумента(Строка, Документ, МассивСтрокДокументов);
    ИначеЕсли ЭтоДействительныйТерминаторДокумента(Строка) Тогда
        Лог.Отладка("Найден терминатор документа " + YAML_ТЕРМИНАТОР_ДОКУМЕНТА);
        Документ = ОбработатьТерминаторДокумента(Документ, МассивСтрокДокументов);
    Иначе
        Документ = ОбработатьОбычнуюСтроку(Строка, Документ);
    КонецЕсли;
    
    Результат = СоздатьРезультатОбработкиДокумента(Документ);
    Возврат Результат;
    
КонецФункции

// Обрабатывает разделитель документа и создает новый документ
//
// Параметры:
//  Строка - Строка - строка с разделителем документа
//  Документ - Массив - текущий документ для сохранения
//  МассивСтрокДокументов - Массив - массив документов для добавления нового
//
// Возвращаемое значение:
//  Массив - новый документ.
//
Функция ОбработатьРазделительДокумента(Знач Строка, Знач Документ, Знач МассивСтрокДокументов)
    
    // Конец документа, сохраняем текущий и начинаем новый
    // Сохраняем документ, даже если он пустой (согласно YAML спецификации)
    Если Документ <> Неопределено Тогда
        МассивСтрокДокументов.Добавить(Документ);
        // Очищаем TAG директивы только после обработки предыдущего документа
        ТекущиеТАГДирективы.Очистить();
        // Сбрасываем флаг YAML директивы для нового документа
        ВстречалаYAMLДиректива = Ложь;
    КонецЕсли;
    
    Документ = Новый Массив();
    Строка = СтрЗаменить(Строка, YAML_РАЗДЕЛИТЕЛЬ_ДОКУМЕНТА, "");
    Если Не ПустаяСтрока(СокрЛП(Строка)) Тогда
        Документ.Добавить(Строка);
    КонецЕсли;
    
    Возврат Документ;
    
КонецФункции

// Обрабатывает терминатор документа ...
//
// Параметры:
//   Документ - Массив - текущий документ
//   МассивСтрокДокументов - Массив - массив всех документов
//
// Возвращаемое значение:
//   Массив - новый документ (Неопределено если вне документа)
//
Функция ОбработатьТерминаторДокумента(Документ, МассивСтрокДокументов)
    
    // Конец текущего документа
    Если Документ <> Неопределено И Документ.Количество() > 0 Тогда
        МассивСтрокДокументов.Добавить(Документ);
    ИначеЕсли ВстречалаYAMLДиректива Тогда
        // Если была директива, но пустой или несуществующий документ, это ошибка
        ВызватьИсключение "YAML директива без последующего документа";
    КонецЕсли;
    
    Документ = Неопределено; // Переходим в состояние вне документа
    // Сбрасываем флаг YAML директивы
    ВстречалаYAMLДиректива = Ложь;
    
    Возврат Документ;
    
КонецФункции

// Обрабатывает обычную строку
//
// Параметры:
//   Строка - Строка - обрабатываемая строка
//   Документ - Массив - текущий документ
//
// Возвращаемое значение:
//   Массив - документ с добавленной строкой
//
Функция ОбработатьОбычнуюСтроку(Строка, Документ)
    
    ВывестиОтладочнуюИнформациюОСтроке(Строка, Документ);
    
    СтрокаБезПробелов = СокрЛП(Строка);
    
    // TAG директивы обрабатываем всегда, но проверяем контекст
    Если СтрНачинаетсяС(СтрокаБезПробелов, "%TAG") Тогда
        Возврат ОбработатьТагДирективуВКонтексте(СтрокаБезПробелов, Документ);
    КонецЕсли;
    
    Если Документ = Неопределено Тогда
        Возврат ОбработатьСтрокуВнеДокумента(СтрокаБезПробелов, Строка, Документ);
    КонецЕсли;   

    Документ.Добавить(Строка);
    
    Возврат Документ;
    
КонецФункции

// Выводит отладочную информацию о строке и документе
//
// Параметры:
//   Строка - Строка - обрабатываемая строка
//   Документ - Массив, Неопределено - текущий документ
//
Процедура ВывестиОтладочнуюИнформациюОСтроке(Строка, Документ)
    ТекстДляОтладки = "ОбработатьОбычнуюСтроку: строка='" + Строка + "'";
    ТекстДляОтладки = ТекстДляОтладки + ", Документ=" 
                                        + ?(Документ = Неопределено, 
                                                "Неопределено",
                                                "Массив[" + Документ.Количество() + "]");
    Лог.Отладка(ТекстДляОтладки);
КонецПроцедуры

// Обрабатывает TAG директиву в контексте документа
//
// Параметры:
//   СтрокаБезПробелов - Строка - строка без пробелов
//   Документ - Массив, Неопределено - текущий документ
//
// Возвращаемое значение:
//   Массив, Неопределено - обновленный документ
//
Функция ОбработатьТагДирективуВКонтексте(СтрокаБезПробелов, Документ)
    Лог.Отладка("Обработка TAG директивы: " + СтрокаБезПробелов);
    
    // Если мы уже внутри документа (документ содержит данные), 
    // то директивы недопустимы без завершения документа
    Если Документ <> Неопределено И Документ.Количество() > 0 Тогда
        СообщениеОшибки = "Директива %TAG не может появляться в середине документа ";
        СообщениеОшибки = СообщениеОшибки + "без завершения документа маркером '...'";
        ВызватьИсключение СообщениеОшибки;
    КонецЕсли;
    
    // Обрабатываем TAG директиву
    ОбработатьТАГДирективу(СтрокаБезПробелов);
    Возврат Документ;
КонецФункции

// Обрабатывает строку вне документа
//
// Параметры:
//   СтрокаБезПробелов - Строка - строка без пробелов
//   ПолнаяСтрока - Строка - исходная строка
//   Документ - Массив, Неопределено - текущий документ
//
// Возвращаемое значение:
//   Массив, Неопределено - обновленный документ
//
Функция ОбработатьСтрокуВнеДокумента(СтрокаБезПробелов, ПолнаяСтрока, Документ)
    // Мы вне документа - здесь можем обрабатывать YAML директивы
    Если СтрНачинаетсяС(СтрокаБезПробелов, "%YAML") Тогда
        Лог.Отладка("Обработка YAML директивы: " + СтрокаБезПробелов);
        
        // Проверяем, не была ли уже YAML директива
        Если ВстречалаYAMLДиректива Тогда
            ВызватьИсключение "Дублирование YAML директивы не допускается";
        КонецЕсли;
        
        // Валидируем формат YAML директивы
        ЧастиДирективы = СтрРазделить(СтрокаБезПробелов, " ", Истина);
        Если ЧастиДирективы.Количество() > 2 Тогда
            ВызватьИсключение "YAML директива содержит лишние слова: " + СтрокаБезПробелов;
        ИначеЕсли ЧастиДирективы.Количество() < 2 Тогда
            ВызватьИсключение "YAML директива должна содержать версию";
        КонецЕсли;
        
        // Проверяем формат версии (должно быть x.y)
        Версия = ЧастиДирективы[1];
        
        // Проверяем, нет ли комментария без пробела (например, "1.1#comment")
        Если СтрНайти(Версия, "#") > 0 Тогда
            ВызватьИсключение "Комментарий в YAML директиве должен быть отделен пробелом";
        КонецЕсли;
        
        Если НЕ СтрНайти(Версия, ".") > 0 Тогда
            ВызватьИсключение "Неверный формат версии YAML директивы: " + Версия;
        КонецЕсли;
        
        ВстречалаYAMLДиректива = Истина;
        Возврат Документ;
    ИначеЕсли СтрНачинаетсяС(СтрокаБезПробелов, "%") И НЕ СтрНачинаетсяС(СтрокаБезПробелов, "%TAG") Тогда
        // Неизвестные директивы (как %FOO) должны игнорироваться с предупреждением
        Лог.Отладка("Игнорируем неизвестную директиву: " + СтрокаБезПробелов);
        Возврат Документ;
    Иначе
        Возврат ОбработатьСодержательнуюСтрокуВнеДокумента(ПолнаяСтрока, Документ);
    КонецЕсли;
КонецФункции

// Обрабатывает содержательную строку вне документа
//
// Параметры:
//   ПолнаяСтрока - Строка - исходная строка
//   Документ - Массив, Неопределено - текущий документ
//
// Возвращаемое значение:
//   Массив, Неопределено - обновленный документ
//
Функция ОбработатьСодержательнуюСтрокуВнеДокумента(ПолнаяСтрока, Документ)
    Если ЭтоПустаяСтрокаПослеОбрезки(ПолнаяСтрока) Тогда
        Возврат Документ; // мы вне документа, может там после и есть что-то, но эти строки нам не нужны
    КонецЕсли;
    
    // Игнорируем комментарии вне документа
    Если ЭтоПустаяСтрокаИлиКомментарий(ПолнаяСтрока) Тогда
        Лог.Отладка("Игнорируем комментарий вне документа: " + ПолнаяСтрока);
        Возврат Документ;
    КонецЕсли;
    
    // Первая содержательная строка начинает неявный документ (без ---)
    Лог.Отладка("Начинаем неявный документ с первой содержательной строки: " + ПолнаяСтрока);
    НовыйДокумент = Новый Массив();
    НовыйДокумент.Добавить(ПолнаяСтрока);
    Возврат НовыйДокумент;
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// МЕТОДЫ РАБОТЫ СО СТРОКАМИ И КОММЕНТАРИЯМИ
////////////////////////////////////////////////////////////////////////////////

// Очистка строк от комментариев и пустых строк
//
// Параметры:
////////////////////////////////////////////////////////////////////////////////
// МЕТОДЫ РАБОТЫ СО СТРОКАМИ И КОММЕНТАРИЯМИ
////////////////////////////////////////////////////////////////////////////////

// Очищает массив строк от комментариев
//
// Параметры:
//   Строки - Массив - массив строк для очистки
//
// Возвращаемое значение:
//   Массив - очищенный массив строк
//
Функция ОчиститьСтроки(Строки)
    
    ОчищенныеСтроки = Новый Массив();
    
    Для Каждого Строка Из Строки Цикл
        ОчищеннаяСтрока = УбратьКомментарийИзСтроки(СокрЛП(Строка));
        ОчищенныеСтроки.Добавить(ОчищеннаяСтрока);
    КонецЦикла;
    
    Возврат ОчищенныеСтроки;
    
КонецФункции

// Проверка, является ли строка пустой или комментарием
// Параметры:
//   Строка - Строка - строка для проверки
// Возвращаемое значение:
//   Булево - Истина, если строка пустая или комментарий
//
Функция ЭтоПустаяСтрокаИлиКомментарий(Знач Строка)
    // ОПТИМИЗАЦИЯ: Быстрая проверка без SокрЛП для пустых строк
    Если СтрДлина(Строка) = 0 Тогда
        Возврат Истина;
    КонецЕсли;
    
    // Ищем первый непробельный символ
    Для Позиция = 1 По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, Позиция, 1);
        Если Символ <> " " И Символ <> Символы.Таб Тогда
            // Если первый непробельный символ - комментарий
            Возврат Символ = "#";
        КонецЕсли;
    КонецЦикла;
    
    // Если строка состоит только из пробелов и табов
    Возврат Истина;
КонецФункции

// Убирает комментарий из строки, если она на него заканчивается
// Параметры:
//   Строка - Строка - строка для очистки
// Возвращаемое значение:
//   Строка - очищенная строка без комментариев
//
Функция УбратьКомментарийИзСтроки(Знач Строка)
    // Ищем позицию комментария неэкранированного символа #,
    // т.е. пропускаем символы в кавычках и тд.
    
    ПозицияКомментария = ПозицияНеЭкранированногоСимвола(Строка, "#");
    
    Если ПозицияКомментария = 0 Тогда
        Возврат Строка;
    КонецЕсли;

    Возврат Лев(Строка, ПозицияКомментария - 1);
КонецФункции

// Очищает строку от комментариев и пробелов, возвращает обрезанную строку
// 
// Параметры:
//   Строка - Строка - исходная строка для очистки
//
// Возвращаемое значение:
//   Строка - очищенная от комментариев и обрезанная строка
//
Функция ОчиститьСтрокуОтКомментариев(Знач Строка)
    Возврат СокрЛП(УбратьКомментарийИзСтроки(Строка));
КонецФункции

// Добавляет значение в массив строк, если оно не пустое
//
// Параметры:
//   МассивСтрок - Массив - массив для добавления
//   Значение - Строка - значение для добавления
//
Процедура ДобавитьНепустоеЗначение(МассивСтрок, Знач Значение)
    Если НЕ ПустаяСтрока(Значение) Тогда
        МассивСтрок.Добавить(Значение);
    КонецЕсли;
КонецПроцедуры

// Парсит значение из массива строк с учетом особенностей YAML
//
// Параметры:
//   СтрокиЗначения - Массив - массив строк для парсинга
//
// Возвращаемое значение:
//   Произвольный - результат парсинга YAML значения
//
Функция СпарситьЗначениеИзМассиваСтрок(СтрокиЗначения)
    Если СтрокиЗначения.Количество() = 0 Тогда
        Возврат Неопределено; // null в YAML
    ИначеЕсли СтрокиЗначения.Количество() = 1 И ТипЗнч(СтрокиЗначения[0]) = Тип("Строка") Тогда
        // Одна строка - создаем массив из одной строки и парсим
        МассивОднойСтроки = Новый Массив();
        МассивОднойСтроки.Добавить(СтрокиЗначения[0]);
        Возврат ДанныеИзМассиваСтрок(МассивОднойСтроки);
    Иначе
        Возврат ДанныеИзМассиваСтрок(СтрокиЗначения);
    КонецЕсли;
КонецФункции

// Проверяет строку на наличие табуляции после двоеточия
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка для проверки
//
Процедура ПроверитьОтсутствиеТабуляцииПослеДвоеточия(СтрокаБезОтступов)
    Если СтрДлина(СтрокаБезОтступов) > 1 
        И Сред(СтрокаБезОтступов, МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ, 1) = Символы.Таб Тогда
        ВызватьИсключение("YAML Error: Использование символов табуляции после двоеточия запрещено спецификацией YAML");
    КонецЕсли;
КонецПроцедуры

// Извлекает значение после двоеточия в начале строки
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка с двоеточием в начале
//
// Возвращаемое значение:
//   Строка - значение после двоеточия без пробелов
//
Функция ИзвлечьЗначениеПослеДвоеточия(СтрокаБезОтступов)
    Возврат УдалитьПервыйСимволСОчисткой(СтрокаБезОтступов);
КонецФункции

// Проверяет, является ли строка пустой после удаления пробелов
//
// Параметры:
//   Строка - Строка - строка для проверки
//
// Возвращаемое значение:
//   Булево - Истина, если строка пуста после обрезки пробелов
//
Функция ЭтоПустаяСтрокаПослеОбрезки(Строка)
    Возврат СокрЛП(Строка) = "";
КонецФункции


// Обрабатывает экранирующие последовательности в строке
//
// Параметры:
//   Строка - Строка - строка для обработки
//   ТипКавычек - Строка - тип кавычек (двойные или одинарные)
//
// Возвращаемое значение:
//   Строка - строка с обработанными экранирующими последовательностями
//
Функция ОбработатьЭкранирующиеПоследовательности(Строка, ТипКавычек)
    Если ТипКавычек = ТИП_КАВЫЧЕК_ДВОЙНЫЕ Тогда
        Возврат ОбработатьEscapeДляДвойныхКавычек(Строка);
    ИначеЕсли ТипКавычек = ТИП_КАВЫЧЕК_ОДИНАРНЫЕ Тогда
        Возврат ОбработатьEscapeДляОдинарныхКавычек(Строка);
    Иначе
        Возврат Строка;
    КонецЕсли;
КонецФункции

// Обрабатывает escape-последовательности для двойных кавычек
//
// Параметры:
//   Строка - Строка - исходная строка
//
// Возвращаемое значение:
//   Строка - обработанная строка
//
Функция ОбработатьEscapeДляДвойныхКавычек(Строка)
    Результат = Строка;
    
    // Проверяем недопустимые последовательности
    ПроверитьНедопустимыеEscapeПоследовательности(Результат);
    ПроверитьВалидностьEscapeПоследовательностей(Результат);
    
    // Обрабатываем Unicode и hex последовательности
    Результат = ОбработатьUnicodeEscapeПоследовательности(Результат);
    
    // Заменяем стандартные escape-последовательности
    Результат = ЗаменитьСтандартныеEscapeПоследовательности(Результат);
    
    Возврат Результат;
КонецФункции

// Обрабатывает escape-последовательности для одинарных кавычек
//
// Параметры:
//   Строка - Строка - исходная строка
//
// Возвращаемое значение:
//   Строка - обработанная строка
//
Функция ОбработатьEscapeДляОдинарныхКавычек(Строка)
    Возврат СтрЗаменить(Строка, "''", "'");
КонецФункции

// Проверяет недопустимые escape-последовательности
//
// Параметры:
//   Строка - Строка - строка для проверки
//
Процедура ПроверитьНедопустимыеEscapeПоследовательности(Строка)
    Если СтрНайти(Строка, "\'") > 0 Тогда
        ВызватьИсключение "Недопустимая escape-последовательность \' в двойных кавычках";
    КонецЕсли;
КонецПроцедуры

// Заменяет стандартные escape-последовательности
//
// Параметры:
//   Строка - Строка - исходная строка
//
// Возвращаемое значение:
//   Строка - строка с замененными последовательностями
//
Функция ЗаменитьСтандартныеEscapeПоследовательности(Строка)
    Результат = Строка;
    
    // Обрабатываем реальные символы табуляции
    Результат = СтрЗаменить(Результат, "\" + Символы.Таб, Символы.Таб);
    
    // Заменяем текстовые escape-последовательности
    Результат = СтрЗаменить(Результат, "\""", """");
    Результат = СтрЗаменить(Результат, "\ ", " ");
    Результат = СтрЗаменить(Результат, "\n", Символы.ПС);
    Результат = СтрЗаменить(Результат, "\t", Символы.Таб);
    Результат = СтрЗаменить(Результат, "\r", Символы.ВК);
    Результат = СтрЗаменить(Результат, "\b", Символ(8));  // backspace
    Результат = СтрЗаменить(Результат, "\f", Символ(12)); // form feed
    Результат = СтрЗаменить(Результат, "\/", "/");
    Результат = СтрЗаменить(Результат, "\\", "\");       // должен быть последним
    
    Возврат Результат;
КонецФункции

// Проверяет валидность escape-последовательностей в строке
//
// Параметры:
//   Строка - Строка - строка для проверки
//
Процедура ПроверитьВалидностьEscapeПоследовательностей(Строка)
    ВалидныеПоследовательности = ПолучитьВалидныеEscapeПоследовательности();
    
    Позиция = 1;
    Пока Позиция <= СтрДлина(Строка) Цикл
        Если Сред(Строка, Позиция, 1) = "\" Тогда
            Позиция = ОбработатьBackslash(Строка, Позиция, ВалидныеПоследовательности);
        КонецЕсли;
        Позиция = Позиция + 1;
    КонецЦикла;
КонецПроцедуры

// Получает массив валидных escape-последовательностей
//
// Возвращаемое значение:
//   Массив - массив валидных escape-последовательностей
//
Функция ПолучитьВалидныеEscapeПоследовательности()
    ВалидныеEscapeПоследовательности = Новый Массив;
    ВалидныеEscapeПоследовательности.Добавить("\""");
    ВалидныеEscapeПоследовательности.Добавить("\\");
    ВалидныеEscapeПоследовательности.Добавить("\/");
    ВалидныеEscapeПоследовательности.Добавить("\b");
    ВалидныеEscapeПоследовательности.Добавить("\f");
    ВалидныеEscapeПоследовательности.Добавить("\n");
    ВалидныеEscapeПоследовательности.Добавить("\r");
    ВалидныеEscapeПоследовательности.Добавить("\t");
    ВалидныеEscapeПоследовательности.Добавить("\ ");
    ВалидныеEscapeПоследовательности.Добавить("\0");
    ВалидныеEscapeПоследовательности.Добавить("\a");
    ВалидныеEscapeПоследовательности.Добавить("\e");
    ВалидныеEscapeПоследовательности.Добавить("\_");
    ВалидныеEscapeПоследовательности.Добавить("\L");
    ВалидныеEscapeПоследовательности.Добавить("\P");
    ВалидныеEscapeПоследовательности.Добавить("\" + Символы.Таб);
    
    Возврат ВалидныеEscapeПоследовательности;
КонецФункции

// Обрабатывает найденный backslash и проверяет валидность последовательности
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - текущая позиция backslash
//   ВалидныеПоследовательности - Массив - массив валидных последовательностей
//
// Возвращаемое значение:
//   Число - новая позиция после обработки
//
Функция ОбработатьBackslash(Строка, Позиция, ВалидныеПоследовательности)
    // Ищем валидную последовательность
    НовыйИндекс = НайтиВалиднуюПоследовательность(Строка, Позиция, ВалидныеПоследовательности);
    
    Если НовыйИндекс > Позиция Тогда
        Возврат НовыйИндекс;
    КонецЕсли;
    
    // Проверяем Unicode escape последовательности
    НовыйИндекс = ПроверитьUnicodeПоследовательностиВалидацией(Строка, Позиция);
    
    Если НовыйИндекс > Позиция Тогда
        Возврат НовыйИндекс;
    КонецЕсли;
    
    // Если ничего не найдено - ошибка
    ВызватьОшибкуНевалиднойПоследовательности(Строка, Позиция);
    
    Возврат Позиция;
КонецФункции

// Ищет валидную escape-последовательность начиная с позиции
//
// Параметры:
//   Строка - Строка - исходная строка  
//   Позиция - Число - позиция начала поиска
//   ВалидныеПоследовательности - Массив - массив валидных последовательностей
//
// Возвращаемое значение:
//   Число - новая позиция или исходная позиция если не найдено
//
Функция НайтиВалиднуюПоследовательность(Строка, Позиция, ВалидныеПоследовательности)
    Для Каждого ВалиднаяПоследовательность Из ВалидныеПоследовательности Цикл
        Если Позиция + СтрДлина(ВалиднаяПоследовательность) - 1 <= СтрДлина(Строка) Тогда
            Если Сред(Строка, Позиция, СтрДлина(ВалиднаяПоследовательность)) = ВалиднаяПоследовательность Тогда
                Возврат Позиция + СтрДлина(ВалиднаяПоследовательность) - 1;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Позиция;
КонецФункции

// Проверяет Unicode escape-последовательности (\uXXXX, \UXXXXXXXX, \xXX)
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция backslash
//
// Возвращаемое значение:
//   Число - новая позиция или исходная позиция если не найдено
//
Функция ПроверитьUnicodeПоследовательностиВалидацией(Строка, Позиция)
    Если Позиция + 1 > СтрДлина(Строка) Тогда
        Возврат Позиция;
    КонецЕсли;
    
    СледующийСимвол = Сред(Строка, Позиция + 1, 1);
    
    Если СледующийСимвол = "u" Тогда
        Возврат ПроверитьUnicodeПоследовательность(Строка, Позиция, 4); // \uXXXX
    ИначеЕсли СледующийСимвол = "U" Тогда
        Возврат ПроверитьUnicodeПоследовательность(Строка, Позиция, 8); // \UXXXXXXXX
    ИначеЕсли СледующийСимвол = "x" Тогда
        Возврат ПроверитьUnicodeПоследовательность(Строка, Позиция, 2); // \xXX
    Иначе
        Возврат Позиция;
    КонецЕсли;
КонецФункции

// Проверяет Unicode последовательность определенной длины
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция backslash
//   ДлинаHex - Число - ожидаемая длина hex части
//
// Возвращаемое значение:
//   Число - новая позиция или исходная позиция если не валидна
//
Функция ПроверитьUnicodeПоследовательность(Строка, Позиция, ДлинаHex)
    ОбщаяДлина = 2 + ДлинаHex; // backslash + символ + hex цифры
    
    Если Позиция + ОбщаяДлина - 1 <= СтрДлина(Строка) Тогда
        HexЧасть = Сред(Строка, Позиция + 2, ДлинаHex);
        Если ПроверитьHexСтроку(HexЧасть) Тогда
            Возврат Позиция + ОбщаяДлина - 1;
        КонецЕсли;
    КонецЕсли;
    
    Возврат Позиция;
КонецФункции

// Вызывает ошибку для невалидной escape-последовательности
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция проблемного backslash
//
Процедура ВызватьОшибкуНевалиднойПоследовательности(Строка, Позиция)
    Если Позиция + 1 <= СтрДлина(Строка) Тогда
        СледующийСимвол = Сред(Строка, Позиция + 1, 1);
        ВызватьИсключение СтрШаблон("Недопустимая escape-последовательность \%1 в двойных кавычках", СледующийСимвол);
    Иначе
        ВызватьИсключение "Недопустимая escape-последовательность в конце строки";
    КонецЕсли;
КонецПроцедуры

// Проверяет является ли строка корректной hex строкой
//
// Параметры:
//   HexСтрока - Строка - строка для проверки
//
// Возвращаемое значение:
//   Булево - Истина если строка состоит только из hex символов
//
Функция ПроверитьHexСтроку(HexСтрока)
    ВалидныеHexСимволы = "0123456789ABCDEFabcdef";
    
    Для i = 1 По СтрДлина(HexСтрока) Цикл
        Если СтрНайти(ВалидныеHexСимволы, Сред(HexСтрока, i, 1)) = 0 Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Истина;
КонецФункции

// Обрабатывает Unicode и hex escape-последовательности в строке
//
// Параметры:
//   Строка - Строка - строка для обработки
//
// Возвращаемое значение:
//   Строка - строка с замененными Unicode и hex последовательностями
//
Функция ОбработатьUnicodeEscapeПоследовательности(Строка)
    Результат = Строка;
    
    // Обрабатываем \uXXXX (4 hex цифры) - Unicode BMP
    Результат = ОбработатьUnicodeПоследовательности(Результат);
    
    // Обрабатываем \xXX (2 hex цифры)
    Результат = ОбработатьHexПоследовательности(Результат);
    
    Возврат Результат;
КонецФункции

// Обрабатывает Unicode последовательности \uXXXX в строке
//
// Параметры:
//   Строка - Строка - строка для обработки
//
// Возвращаемое значение:
//   Строка - строка с замененными Unicode последовательностями
//
Функция ОбработатьUnicodeПоследовательности(Строка)
    Результат = Строка;
    Позиция = 1;
    
    Пока Позиция <= СтрДлина(Результат) - 5 Цикл
        Если Сред(Результат, Позиция, 2) = "\u" Тогда
            Результат = ОбработатьОднуUnicodeПоследовательность(Результат, Позиция, 4, 6);
        КонецЕсли;
        Позиция = Позиция + 1;
    КонецЦикла;
    
    Возврат Результат;
КонецФункции

// Обрабатывает hex последовательности \xXX в строке
//
// Параметры:
//   Строка - Строка - строка для обработки
//
// Возвращаемое значение:
//   Строка - строка с замененными hex последовательностями
//
Функция ОбработатьHexПоследовательности(Строка)
    Результат = Строка;
    Позиция = 1;
    
    Пока Позиция <= СтрДлина(Результат) - 3 Цикл
        Если Сред(Результат, Позиция, 2) = "\x" Тогда
            Результат = ОбработатьОднуUnicodeПоследовательность(Результат, Позиция, 2, 4);
        КонецЕсли;
        Позиция = Позиция + 1;
    КонецЦикла;
    
    Возврат Результат;
КонецФункции

// Обрабатывает одну Unicode или hex последовательность
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция начала последовательности
//   ДлинаHex - Число - длина hex части
//   ОбщаяДлина - Число - общая длина последовательности
//
// Возвращаемое значение:
//   Строка - строка с замененной последовательностью
//
Функция ОбработатьОднуUnicodeПоследовательность(Строка, Позиция, ДлинаHex, ОбщаяДлина)
    HexЧасть = Сред(Строка, Позиция + 2, ДлинаHex);
    
    Если ПроверитьHexСтроку(HexЧасть) Тогда
        Возврат ЗаменитьHexНаСимвол(Строка, Позиция, HexЧасть, ОбщаяДлина);
    КонецЕсли;
    
    Возврат Строка;
КонецФункции

// Заменяет hex последовательность на соответствующий символ
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция последовательности
//   HexЧасть - Строка - hex часть для преобразования
//   ОбщаяДлина - Число - общая длина последовательности
//
// Возвращаемое значение:
//   Строка - строка с замененной последовательностью
//
Функция ЗаменитьHexНаСимвол(Строка, Позиция, HexЧасть, ОбщаяДлина)
    Попытка
        КодСимвола = ПреобразоватьHexВЧисло(HexЧасть);
        НовыйСимвол = Символ(КодСимвола);
        Возврат Лев(Строка, Позиция - 1) + НовыйСимвол + Сред(Строка, Позиция + ОбщаяДлина);
    Исключение
        // Если не удалось преобразовать, возвращаем исходную строку
        Возврат Строка;
    КонецПопытки;
КонецФункции

// Преобразует hex строку в число
//
// Параметры:
//   HexСтрока - Строка - hex строка для преобразования
//
// Возвращаемое значение:
//   Число - десятичное представление hex числа
//
Функция ПреобразоватьHexВЧисло(HexСтрока)
    Результат = 0;
    
    Для i = 1 По СтрДлина(HexСтрока) Цикл
        Символ = Сред(HexСтрока, i, 1);
        Значение = 0;
        
        Если Символ >= "0" И Символ <= "9" Тогда
            Значение = Число(Символ);
        ИначеЕсли ВРег(Символ) >= "A" И ВРег(Символ) <= "F" Тогда
            Значение = КодСимвола(ВРег(Символ)) - КодСимвола("A") + 10;
        Иначе
            Значение = 0;
        КонецЕсли;
        
        Результат = Результат * 16 + Значение;
    КонецЦикла;
    
    Возврат Результат;
КонецФункции

// Удаляет первый и последний символы из строки
//
// Параметры:
//   Строка - Строка - строка для обработки
//
// Возвращаемое значение:
//   Строка - строка без первого и последнего символов
//
Функция УдалитьПервыйИПоследнийСимволы(Строка)
    Если СтрДлина(Строка) <= МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ Тогда
        Возврат "";
    КонецЕсли;
    
    Возврат Сред(Строка, МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ, СтрДлина(Строка) - МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ);
КонецФункции

// Извлекает и очищает значение после двоеточия в строке
//
// Параметры:
//   Строка - Строка - строка содержащая двоеточие
//   ПозицияДвоеточия - Число - позиция двоеточия в строке
//
// Возвращаемое значение:
//   Строка - очищенное значение после двоеточия
//
Функция ИзвлечьЗначениеПослеДвоеточияСОчисткой(Строка, ПозицияДвоеточия)
    Возврат СокрЛП(Сред(Строка, ПозицияДвоеточия + 1));
КонецФункции

// Удаляет первый символ из строки и очищает от пробелов
//
// Параметры:
//   Строка - Строка - строка для обработки
//
// Возвращаемое значение:
//   Строка - очищенная строка без первого символа
//
Функция УдалитьПервыйСимволСОчисткой(Строка)
    Возврат СокрЛП(Сред(Строка, МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ));
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// МЕТОДЫ ОПРЕДЕЛЕНИЯ ТИПОВ ДАННЫХ
////////////////////////////////////////////////////////////////////////////////

// Определение типа содержимого строки
//
// Параметры:
//   Строки - Массив - массив строк для анализа
//
// Возвращаемое значение:
//   Строка - тип содержимого: "Объект", "Массив", "FlowПоследовательность", 
//     "FlowОбъект", "МногострочнаяСтрока", Неопределено
//
Функция ОпределитьТипСодержимого(Строки)
    Лог.Отладка("Определение типа содержимого для " + Строки.Количество() + " строк");
    
    // ОПТИМИЗАЦИЯ: Быстрый выход для частых случаев
    Если Строки.Количество() = 0 Тогда
        Лог.Предупреждение("Не найдено ни одной строки с данными");
        Возврат Неопределено;
    КонецЕсли;
    
    // ОПТИМИЗАЦИЯ: Проверяем только первую значащую строку для большинства случаев
    Для Каждого Строка Из Строки Цикл
        
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
            Продолжить;
        КонецЕсли;
        // Если это не пустая строка, то управляющий символ должен быть в ней.
        // Если мы не нашли его, то это Строка или число, или что-то другое.
        ТипДанных = НайтиТипДанныхПоСтроке(Строка);
        Лог.Отладка("Определен тип содержимого: " + ТипДанных + " по строке: " + Строка);
        Возврат ТипДанных;
    КонецЦикла;
    
    Лог.Предупреждение("Не найдено ни одной строки с данными");
    Возврат Неопределено; // Если не найдено ни одной строки с данными - возвращаем неопределено.
    
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// МЕТОДЫ ОПРЕДЕЛЕНИЯ ТИПОВ ДАННЫХ
////////////////////////////////////////////////////////////////////////////////

// Проверяет, является ли строка директивой YAML
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка без начальных и конечных пробелов.
//
// Возвращаемое значение:
//   Булево - истина, если строка является директивой.
//
Функция ЯвляетсяДирективой(ОчищеннаяСтрока)
    // Любая строка, начинающаяся с %, является директивой
    Возврат СтрНачинаетсяС(ОчищеннаяСтрока, "%");
КонецФункции

// Определяет тип данных тегированной строки
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка без начальных и конечных пробелов
//
// Возвращаемое значение:
//   Строка - тип данных ("Объект" или "Тег")
Функция ОпределитьТипТегированнойСтроки(ОчищеннаяСтрока)
    // Особая обработка для verbatim тегов !<uri> - они содержат двоеточие в URI
    ЭтоВербатимТег = СтрНачинаетсяС(ОчищеннаяСтрока, "!<");
    
    Если НЕ ЭтоВербатимТег Тогда
        // Проверяем, не является ли это тегированным ключом объекта
        // Если после тега и возможного якоря есть двоеточие, то это ключ объекта
        Если СтрНайти(ОчищеннаяСтрока, ":") > 0 Тогда
            Лог.Отладка("Найден символ объекта: : (в тегированной строке)");
            Возврат "Объект";
        КонецЕсли;
    КонецЕсли;
    
    Лог.Отладка("Найден тег по началу строки: " + ОчищеннаяСтрока);
    Возврат "Тег";
КонецФункции

// Определяет тип данных по управляющему символу
//
// Параметры:
//   ДанныеУправляющегоСимвола - Структура - данные управляющего символа
//   ИсходнаяСтрока - Строка - исходная строка для вывода ошибок
//
// Возвращаемое значение:
//   Строка - тип данных
Функция ОпределитьТипПоУправляющемуСимволу(ДанныеУправляющегоСимвола, ИсходнаяСтрока)
    
    Если ДанныеУправляющегоСимвола.Позиция = 0 Тогда
        Лог.Отладка("Управляющий символ не найден, определен как скаляр");
        Возврат "Скаляр";
    КонецЕсли;
    
    Символ = ДанныеУправляющегоСимвола.Символ;
    
    Если Символ = "[" Тогда
        Лог.Отладка("Найден символ flow последовательности: [");
        Возврат "FlowПоследовательность";
    ИначеЕсли Символ = "{" Тогда
        Лог.Отладка("Найден символ flow объекта: {");
        Возврат "FlowОбъект";
    ИначеЕсли Символ = ":" Тогда
        Лог.Отладка("Найден символ объекта: :");
        Возврат "Объект";
    ИначеЕсли Символ = "-" Тогда
        Лог.Отладка("Найден символ массива: -");
        Возврат "Массив";
    ИначеЕсли Символ = "|" ИЛИ Символ = ">" Тогда
        Лог.Отладка("Найден символ многострочной строки: " + Символ);
        Возврат "МногострочнаяСтрока";
    ИначеЕсли Символ = "&" Тогда
        Лог.Отладка("Найден символ якоря: &");
        Возврат "Якорь";
    ИначеЕсли Символ = "*" Тогда
        Лог.Отладка("Найден символ алиаса: *");
        Возврат "Алиас";      
    ИначеЕсли Символ = "!" Тогда
        Лог.Отладка("Найден символ тега: !");
        Возврат "Тег";
    ИначеЕсли Символ = "?" Тогда
        Лог.Отладка("Найден символ явного ключа: ?");
        Возврат "Объект";
    Иначе
        Лог.Ошибка("Не удалось определить тип данных в строке: " + ИсходнаяСтрока);
        ВызватьИсключение "Не удалось определить тип данных в строке: " + ИсходнаяСтрока;
    КонецЕсли;
    
КонецФункции

// Определяет тип данных YAML по строке
//
// Параметры:
//   Строка - Строка - строка YAML для анализа
//
// Возвращаемое значение:
//   Строка - тип данных YAML
Функция НайтиТипДанныхПоСтроке(Знач Строка)
    // ОПТИМИЗАЦИЯ: Проверяем кэш перед обработкой
    Если КэшТиповСтрок.Получить(Строка) <> Неопределено Тогда
        Возврат КэшТиповСтрок[Строка];
    КонецЕсли;
    
    ОчищеннаяСтрока = СокрЛП(Строка);
    
    // Проверяем директивы
    Если ЯвляетсяДирективой(ОчищеннаяСтрока) Тогда
        Лог.Отладка("Найдена директива, обрабатываем как скаляр: " + ОчищеннаяСтрока);
        КэшТиповСтрок[Строка] = "Скаляр";
        Возврат "Скаляр";
    КонецЕсли;
    
    // Проверяем синтаксис блочных скаляров
    ПроверитьСинтаксисБлочныхСкаляров(ОчищеннаяСтрока);
    
    ДанныеУправляющегоСимвола = НайтиУправляющийСимволИЕгоПозицию(Строка);
    
    // Проверяем многострочные строки (приоритет перед тегами)
    Если ЭтоМногострочнаяСтрока(ДанныеУправляющегоСимвола) Тогда
        Лог.Отладка("Найден символ многострочной строки: " + ДанныеУправляющегоСимвола.Символ);
        КэшТиповСтрок[Строка] = "МногострочнаяСтрока";
        Возврат "МногострочнаяСтрока";
    КонецЕсли;
    
    // Проверяем теги
    Если СтрНачинаетсяС(ОчищеннаяСтрока, "!") Тогда
        РезультатТип = ОпределитьТипТегированнойСтроки(ОчищеннаяСтрока);
        КэшТиповСтрок[Строка] = РезультатТип;
        Возврат РезультатТип;
    КонецЕсли;
    
    // Проверяем управляющие символы структуры
    Если ДанныеУправляющегоСимвола.Символ <> "" Тогда
        РезультатТип = ОпределитьТипПоУправляющемуСимволу(ДанныеУправляющегоСимвола, Строка);
        КэшТиповСтрок[Строка] = РезультатТип;
        Возврат РезультатТип;
    КонецЕсли;
    
    // Проверяем строки в кавычках
    ТипСтрокиВКавычках = ОпределитьТипСтрокиВКавычках(ОчищеннаяСтрока);
    Если ТипСтрокиВКавычках <> "" Тогда
        КэшТиповСтрок[Строка] = ТипСтрокиВКавычках;
        Возврат ТипСтрокиВКавычках;
    КонецЕсли;
    
    // По умолчанию - скаляр
    Лог.Отладка("Управляющий символ не найден, определен как скаляр");
    КэшТиповСтрок[Строка] = "Скаляр";
    Возврат "Скаляр";
КонецФункции

// Проверяет синтаксис блочных скаляров
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка для проверки
//
Процедура ПроверитьСинтаксисБлочныхСкаляров(ОчищеннаяСтрока)
    // Проверка на неправильный синтаксис многострочных строк
    // ># comment или |# comment без пробела недопустимы
    Если СтрНачинаетсяС(ОчищеннаяСтрока, ">#") ИЛИ СтрНачинаетсяС(ОчищеннаяСтрока, "|#") Тогда
        Лог.Ошибка("Комментарий после индикатора блочного скаляра должен быть отделен пробелом");
        ВызватьИсключение "Комментарий после индикатора блочного скаляра должен быть отделен пробелом";
    КонецЕсли;
КонецПроцедуры

// Проверяет, является ли строка многострочной
//
// Параметры:
//   ДанныеУправляющегоСимвола - Структура - данные управляющего символа
//
// Возвращаемое значение:
//   Булево - Истина, если это многострочная строка
//
Функция ЭтоМногострочнаяСтрока(ДанныеУправляющегоСимвола)
    Возврат ДанныеУправляющегоСимвола.Символ = "|" ИЛИ ДанныеУправляющегоСимвола.Символ = ">";
КонецФункции

// Определяет тип строки в кавычках
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка для анализа
//
// Возвращаемое значение:
//   Строка - тип строки или пустая строка, если не в кавычках
//
Функция ОпределитьТипСтрокиВКавычках(ОчищеннаяСтрока)
    Если НЕ (СтрНайти(ОчищеннаяСтрока, """") > 0 ИЛИ СтрНайти(ОчищеннаяСтрока, "'") > 0) Тогда
        Возврат "";
    КонецЕсли;
    
    // Строка начинается с кавычки - это скаляр
    Если СтрНачинаетсяС(ОчищеннаяСтрока, """") ИЛИ СтрНачинаетсяС(ОчищеннаяСтрока, "'") Тогда
        Лог.Отладка("Найдена строка в кавычках, обрабатываем как скаляр: " + ОчищеннаяСтрока);
        Возврат "Скаляр";
    КонецЕсли;
    
    // Анализируем кавычки в середине строки
    Возврат АнализироватьКавычкиВСередине(ОчищеннаяСтрока);
КонецФункции

// Анализирует кавычки в середине строки
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка для анализа
//
// Возвращаемое значение:
//   Строка - тип строки или пустая строка
//
Функция АнализироватьКавычкиВСередине(ОчищеннаяСтрока)
    ПозицияПервойКавычки = Макс(СтрНайти(ОчищеннаяСтрока, """"), СтрНайти(ОчищеннаяСтрока, "'"));
    
    Если ПозицияПервойКавычки = 0 Тогда
        Возврат "";
    КонецЕсли;
    
    ТипКавычки = Сред(ОчищеннаяСтрока, ПозицияПервойКавычки, 1);
    ПозицияПоследнейКавычки = СтрНайти(ОчищеннаяСтрока, ТипКавычки, НаправлениеПоиска.СКонца);
    
    Если ПозицияПоследнейКавычки > ПозицияПервойКавычки Тогда
        Лог.Отладка("Найдена закрытая строка в кавычках, обрабатываем как скаляр: " + ОчищеннаяСтрока);
        Возврат "Скаляр";
    ИначеЕсли ПозицияПоследнейКавычки = ПозицияПервойКавычки Тогда
        Лог.Отладка("Найдена незакрытая строка в кавычках, обрабатываем как скаляр: " + ОчищеннаяСтрока);
        Возврат "Скаляр";
    Иначе
        Лог.Отладка("Кавычки найдены, но не определен точный тип, продолжаем обработку");
        Возврат "";
    КонецЕсли;
КонецФункции

// Проверяет корректность позиции знака вопроса
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция символа
//
// Возвращаемое значение:
//   Булево - Истина, если позиция корректна
Функция ПроверитьПозициюЗнакаВопроса(Строка, Позиция)
    ОтступСтроки = ОпределитьОтступ(Строка);
    // Знак вопроса считается управляющим только если он идет сразу после отступа
    Возврат Позиция = ОтступСтроки + 1;
КонецФункции

// Проверяет недопустимые табы после структурных символов
//
// Параметры:
//   Строка - Строка - исходная строка
//   Символ - Строка - структурный символ
//   Позиция - Число - позиция символа
Процедура ПроверитьТабыПослеСтруктурныхСимволов(Строка, Символ, Позиция)
    // Проверка на табы после структурных символов только в начале строки
    // (после отступа) - запрещено YAML спецификацией
    Если НЕ (Символ = "?" ИЛИ Символ = ":") ИЛИ Позиция >= СтрДлина(Строка) Тогда
        Возврат;
    КонецЕсли;
    
    // Проверяем, что символ в начале строки (после пробелов)
    ОтступСтроки = ОпределитьОтступ(Строка);
    Если Позиция = ОтступСтроки + 1 Тогда // Символ сразу после отступа
        СледующийСимвол = Сред(Строка, Позиция + 1, 1);
        Если СледующийСимвол = Символы.Таб Тогда
            СообщениеОшибки = "YAML Error: Использование символов табуляции после структурных символов (" + Символ + 
                ") в начале строки запрещено спецификацией YAML";
            ВызватьИсключение(СообщениеОшибки);
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

// Проверяет, нужно ли пропустить найденный символ при анализе
//
// Параметры:
//   Строка - Строка - исходная строка
//   Символ - Строка - найденный символ
//   НайденнаяПозиция - Число - позиция найденного символа
//
// Возвращаемое значение:
//   Булево - Истина, если символ нужно пропустить
Функция НужноПропуститьСимвол(Строка, Символ, НайденнаяПозиция)
    
    // Специальная проверка для знака вопроса - он должен быть в начале строки
    Если Символ = "?" И НЕ ПроверитьПозициюЗнакаВопроса(Строка, НайденнаяПозиция) Тогда
        Возврат Истина;
    КонецЕсли;
    
    // Специальная проверка для тегов - ! должен быть в начале значения (после отступов)
    Если Символ = "!" Тогда
        ОчищеннаяСтрока = СокрЛП(Строка);
        Если НЕ СтрНачинаетсяС(ОчищеннаяСтрока, "!") Тогда
            Возврат Истина;
        КонецЕсли;
    КонецЕсли;
    
    // Специальная проверка для тире - оно должно быть в начале строки для списков
    Если Символ = "-" Тогда
        // Тире должно быть либо в начале строки (после отступов), либо после пробелов
        ЧастьДоТире = Лев(Строка, НайденнаяПозиция - 1);
        ОчищеннаяЧасть = СокрЛП(ЧастьДоТире);
        
        // Если перед тире есть другие символы кроме пробелов, то это не элемент списка
        Если НЕ ПустаяСтрока(ОчищеннаяЧасть) Тогда
            Возврат Истина;
        КонецЕсли;
    КонецЕсли;
    
    // Специальная проверка для символов многострочной строки - они не должны быть внутри тегов
    Если (Символ = ">" ИЛИ Символ = "|") И ПозицияВнутриТега(Строка, НайденнаяПозиция) Тогда
        Возврат Истина;
    КонецЕсли;
    
    Возврат Ложь;
    
КонецФункции

// Находит управляющий символ YAML в строке и его позицию
//
// Параметры:
//   Строка - Строка - строка YAML для анализа
//
// Возвращаемое значение:
//   Структура - данные управляющего символа
Функция НайтиУправляющийСимволИЕгоПозицию(Знач Строка)
    // ОПТИМИЗАЦИЯ: Используем кэшированный массив управляющих символов
    СтруктураВозврата = СоздатьСтруктуруУправляющегоСимвола();
    
    // Используем кэшированный массив управляющих символов
    МинимальнаяНайденнаяПозиция = 9999999;
    
    // Ищем каждый символ с помощью оптимизированной функции
    Для каждого Символ Из СтатическийМассивУправляющихСимволов Цикл
        НайденнаяПозиция = ПозицияНеЭкранированногоСимвола(Строка, Символ);
        
        Если НайденнаяПозиция > 0 И МинимальнаяНайденнаяПозиция > НайденнаяПозиция Тогда
            
            Если НужноПропуститьСимвол(Строка, Символ, НайденнаяПозиция) Тогда
                Продолжить;
            КонецЕсли;
            
            // Проверка на табы после структурных символов
            ПроверитьТабыПослеСтруктурныхСимволов(Строка, Символ, НайденнаяПозиция);
            
            СтруктураВозврата.Символ = Символ;
            СтруктураВозврата.Позиция = НайденнаяПозиция;
            МинимальнаяНайденнаяПозиция = НайденнаяПозиция;
        КонецЕсли;
    КонецЦикла;
    
    Возврат СтруктураВозврата;
КонецФункции

// Проверяет, что символ не находится в кавычках и не экранирован
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция символа для проверки
//
// Возвращаемое значение:
//   Булево - Истина, если символ не в кавычках и не экранирован
//
Функция НеВКавычкахИНеЭкранирован(Строка, Позиция)
    // Используем более простой и надежный алгоритм
    // посимвольного анализа для корректной обработки экранирования
    
    ВКавычках = Ложь;
    ТипКавычек = "";
    ДлинаСтроки = СтрДлина(Строка);
    
    Для Индекс = 1 По Позиция Цикл
        Символ = Сред(Строка, Индекс, 1);
        
        // Если мы не в кавычках и встречаем кавычку
        Если НЕ ВКавычках И (Символ = """" ИЛИ Символ = "'") Тогда
            // Проверяем, что кавычка стоит правильно (в начале строки или после пробела/таба)
            Если Индекс = 1 ИЛИ (Индекс > 1 И (Сред(Строка, Индекс - 1, 1) = " " ИЛИ Сред(Строка, Индекс - 1, 1) = Символы.Таб)) Тогда
                ВКавычках = Истина;
                ТипКавычек = Символ;
                Продолжить;
            КонецЕсли;
        КонецЕсли;
        
        // Если мы в кавычках и встречаем закрывающую кавычку
        Если ВКавычках И Символ = ТипКавычек Тогда
            // Проверяем экранирование для двойных кавычек
            Если ТипКавычек = """" Тогда
                // Подсчитываем количество обратных слешей перед кавычкой
                КоличествоСлешей = 0;
                ПроверочныйИндекс = Индекс - 1;
                Пока ПроверочныйИндекс >= 1 И Сред(Строка, ПроверочныйИндекс, 1) = "\" Цикл
                    КоличествоСлешей = КоличествоСлешей + 1;
                    ПроверочныйИндекс = ПроверочныйИндекс - 1;
                КонецЦикла;
                
                // Если четное количество слешей, то кавычка не экранирована
                Если КоличествоСлешей % 2 = 0 Тогда
                    ВКавычках = Ложь;
                    ТипКавычек = "";
                КонецЕсли;
            Иначе
                // Для одинарных кавычек экранирование работает по-другому
                // Проверяем, не удвоена ли кавычка
                Если Индекс < ДлинаСтроки И Сред(Строка, Индекс + 1, 1) = "'" Тогда
                    // Пропускаем удвоенную кавычку
                    Продолжить;
                Иначе
                    ВКавычках = Ложь;
                    ТипКавычек = "";
                КонецЕсли;
            КонецЕсли;
        КонецЕсли;
        
        // Если достигли искомой позиции, возвращаем результат
        Если Индекс = Позиция Тогда
            Возврат НЕ ВКавычках;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Истина; // Символ не в кавычках
КонецФункции

// Проверяет, находится ли позиция внутри тега, заключенного в угловые скобки
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция символа для проверки
//
// Возвращаемое значение:
//   Булево - Истина, если позиция находится внутри тега в угловых скобках
//
Функция ПозицияВнутриТега(Строка, Позиция)
    // Ищем ближайшую открывающую угловую скобку слева от позиции
    ПозицияОткрывающейСкобки = 0;
    i = Позиция - 1;
    Пока i >= 1 Цикл
        Символ = Сред(Строка, i, 1);
        Если Символ = "<" Тогда
            ПозицияОткрывающейСкобки = i;
            Прервать;
        КонецЕсли;
        
        Если Символ = ">" Тогда
            // Если нашли закрывающую скобку раньше открывающей, то мы не внутри тега
            Возврат Ложь;
        КонецЕсли;
        i = i - 1;
    КонецЦикла;
    
    // Если не нашли открывающую скобку, то не внутри тега
    Если ПозицияОткрывающейСкобки = 0 Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Ищем ближайшую закрывающую угловую скобку справа от позиции
    ПозицияЗакрывающейСкобки = 0;
    Для i = Позиция По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, i, 1);
        Если Символ = ">" Тогда
            ПозицияЗакрывающейСкобки = i;
            Прервать;
        КонецЕсли;
        
        Если Символ = "<" Тогда
            // Если нашли открывающую скобку раньше закрывающей, то тег не закрыт
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;
    
    // Если нашли и открывающую, и закрывающую скобки, то мы внутри тега
    Возврат ПозицияЗакрывающейСкобки > 0;
КонецФункции


// Быстрая проверка значащего символа для частых случаев
//
// Параметры:
//   ИскомыйСимвол - Строка - искомый символ
//   Позиция - Число - позиция символа
//   Строка - Строка - исходная строка
//   ЭтоFlowСтиль - Булево - флаг flow стиля  
//   ДлинаСтроки - Число - длина строки
//
// Возвращаемое значение:
//   Булево - Истина, если символ значащий
//
Функция БыстраяПроверкаЗначащегоСимвола(ИскомыйСимвол, Позиция, Строка, ЭтоFlowСтиль, ДлинаСтроки)
    // Используем кэшированные регулярные выражения для более эффективной проверки
    
    Если ИскомыйСимвол = "#" Тогда
        // Комментарий должен быть в начале или после пробела/таба
        Если Позиция = 1 Тогда
            Возврат Истина;
        КонецЕсли;
        
        // Проверяем предыдущий символ с помощью кэшированного регулярного выражения
        ПредыдущийСимвол = Сред(Строка, Позиция - 1, 1);
        РегВыражение = КэшРегулярныхВыражений.Получить("пробелы");
        Возврат РегВыражение.Совпадает(ПредыдущийСимвол);
        
    ИначеЕсли ИскомыйСимвол = ":" Тогда
        Если ЭтоFlowСтиль Тогда
            // В flow стиле двоеточие не должно быть первым символом
            Возврат (Позиция > 1);
        Иначе
            // В блок-стиле двоеточие должно иметь пробел после или быть в конце
            Если Позиция = ДлинаСтроки Тогда
                Возврат Истина;
            КонецЕсли;
            
            // Проверяем следующий символ с помощью кэшированного регулярного выражения
            СледующийСимвол = Сред(Строка, Позиция + 1, 1);
            РегВыражение = КэшРегулярныхВыражений.Получить("пробелы");
            Возврат РегВыражение.Совпадает(СледующийСимвол);
        КонецЕсли;
    Иначе
        // Для других символов используем полную проверку
        Возврат ЭтоЗначащийСимвол(Строка, Позиция, ИскомыйСимвол, ЭтоFlowСтиль);
    КонецЕсли;
КонецФункции

Функция ПозицияНеЭкранированногоСимвола(Строка, ИскомыйСимвол, ЭтоFlowСтиль = Ложь)
    // ОПТИМИЗАЦИЯ: Используем кэшированные регулярные выражения и оптимизированный поиск
    
    // Экранируем специальные символы регулярных выражений
    ЭкранированныйСимвол = ИскомыйСимвол;
    СпециальныеСимволы = КэшРегулярныхВыражений.Получить("спецСимволы");
    Если СтрНайти(СпециальныеСимволы, ИскомыйСимвол) > 0 Тогда
        ЭкранированныйСимвол = "\" + ИскомыйСимвол;
    КонецЕсли;
    
    // Быстрый путь для строк без кавычек  
    Если СтрНайти(Строка, """") = 0 И СтрНайти(Строка, "'") = 0 Тогда
        // Используем простое регулярное выражение для поиска
        ПаттернПростойПоиск = ЭкранированныйСимвол;
        
        // Попробуем получить регулярное выражение из кэша
        КлючКэша = "символ_" + ИскомыйСимвол;
        РегВыражение = КэшРегулярныхВыражений.Получить(КлючКэша);
        Если РегВыражение = Неопределено Тогда
            РегВыражение = Новый РегулярноеВыражение(ПаттернПростойПоиск);
            КэшРегулярныхВыражений.Вставить(КлючКэша, РегВыражение);
        КонецЕсли;
        
        Совпадения = РегВыражение.НайтиСовпадения(Строка);
        Для каждого Совпадение Из Совпадения Цикл
            Позиция = Совпадение.Индекс + 1; // +1 для перевода из индексации с 0 в индексацию с 1
            ДлинаСтроки = СтрДлина(Строка);
            Если БыстраяПроверкаЗначащегоСимвола(ИскомыйСимвол, Позиция, Строка, ЭтоFlowСтиль, ДлинаСтроки) Тогда
                Возврат Позиция;
            КонецЕсли;
        КонецЦикла;
        Возврат 0;
    КонецЕсли;
    
    // Для строк с кавычками используем улучшенный алгоритм
    Возврат НайтиСимволВнеКавычек(Строка, ИскомыйСимвол, ЭтоFlowСтиль);
КонецФункции

// Находит символ вне кавычек с использованием регулярных выражений
//
// Параметры:
//   Строка - Строка - исходная строка
//   ИскомыйСимвол - Строка - искомый символ  
//   ЭтоFlowСтиль - Булево - флаг flow стиля
//
// Возвращаемое значение:
//   Число - позиция найденного символа или 0
//
Функция НайтиСимволВнеКавычек(Строка, ИскомыйСимвол, ЭтоFlowСтиль)
    // Экранируем специальные символы регулярных выражений
    ЭкранированныйСимвол = ИскомыйСимвол;
    СпециальныеСимволы = КэшРегулярныхВыражений.Получить("спецСимволы");
    Если СтрНайти(СпециальныеСимволы, ИскомыйСимвол) > 0 Тогда
        ЭкранированныйСимвол = "\" + ИскомыйСимвол;
    КонецЕсли;
    
    // Паттерн для поиска символа вне кавычек
    // Используем кэшированные регулярные выражения
    КлючКэша = "вне_кавычек_" + ИскомыйСимвол;
    РегВыражение = КэшРегулярныхВыражений.Получить(КлючКэша);
    Если РегВыражение = Неопределено Тогда
        РегВыражение = Новый РегулярноеВыражение(ЭкранированныйСимвол);
        КэшРегулярныхВыражений.Вставить(КлючКэша, РегВыражение);
    КонецЕсли;
    
    Совпадения = РегВыражение.НайтиСовпадения(Строка);
    ДлинаСтроки = СтрДлина(Строка);
    
    Для каждого Совпадение Из Совпадения Цикл
        Позиция = Совпадение.Индекс + 1; // +1 для перевода из индексации с 0 в индексацию с 1
        
        // Проверяем, что символ не в кавычках
        Если НеВКавычкахИНеЭкранирован(Строка, Позиция) Тогда
            Если БыстраяПроверкаЗначащегоСимвола(ИскомыйСимвол, Позиция, Строка, ЭтоFlowСтиль, ДлинаСтроки) Тогда
                Возврат Позиция;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    
    Возврат 0;
КонецФункции

// Проверяет, является ли Символ Значащим
// (должно быть в конце строки или с пробелом/табом после него)
//
// Параметры:
//   Строка - Строка - строка для анализа
//   Позиция - Число - позиция Символа в строке
//   ИскомыйСимвол - Строка - символ, который мы ищем
//   ЭтоFlowСтиль - Булево - флаг обработки в flow-стиле (по умолчанию Ложь)
//
// Возвращаемое значение:
//   Булево - Истина, если Символ является разделителем ключ-значение
//

// Проверяет является ли символ "#" значащим комментарием
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция символа в строке
//
// Возвращаемое значение:
//   Булево - Истина, если символ является началом комментария
Функция ЭтоЗначащийКомментарий(Строка, Позиция)
    // Используем регулярные выражения для проверки предыдущего символа
    Если Позиция = 1 Тогда
        Возврат Истина; // Комментарий в начале строки
    КонецЕсли;
    
    ПредыдущийСимвол = Сред(Строка, Позиция - 1, 1);
    ПаттернПробелов = "[ \t]";
    РегВыражение = Новый РегулярноеВыражение(ПаттернПробелов);
    
    Возврат РегВыражение.Совпадает(ПредыдущийСимвол);
КонецФункции

// Проверяет является ли двоеточие значащим в flow стиле
//
// Параметры:
//   Позиция - Число - позиция двоеточия в строке
//
// Возвращаемое значение:
//   Булево - Истина, если двоеточие является разделителем ключ-значение
Функция ЭтоЗначащееДвоеточиеВFlowСтиле(Позиция)
    // В flow стиле двоеточие должно быть разделителем ключ-значение
    // Не должно быть в начале строки как первый символ
    Если Позиция = 1 Тогда
        Возврат Ложь; // Двоеточие в начале не является разделителем
    КонецЕсли;
    
    Возврат Истина;
КонецФункции

// Проверяет является ли двоеточие значащим в блок стиле
//
// Параметры:
//   Строка - Строка - исходная строка
//   Позиция - Число - позиция двоеточия в строке
//
// Возвращаемое значение:
//   Булево - Истина, если двоеточие является разделителем ключ-значение
Функция ЭтоЗначащееДвоеточиеВБлокСтиле(Строка, Позиция)
    // В блок-стиле двоеточие должно иметь пробел после себя или быть в конце строки
    Если Позиция = СтрДлина(Строка) Тогда
        Возврат Истина; // Двоеточие в конце строки
    КонецЕсли;
    
    // Используем регулярные выражения для проверки следующего символа
    СледующийСимвол = Сред(Строка, Позиция + 1, 1);
    ПаттернПробелов = "[ \t]";
    РегВыражение = Новый РегулярноеВыражение(ПаттернПробелов);
    
    Возврат РегВыражение.Совпадает(СледующийСимвол);
КонецФункции

Функция ЭтоЗначащийСимвол(Строка, Позиция, ИскомыйСимвол, ЭтоFlowСтиль = Ложь)

    Если ИскомыйСимвол = "#" Тогда
        Возврат ЭтоЗначащийКомментарий(Строка, Позиция);
    КонецЕсли;
    
    // Для двоеточия в flow стиле особая обработка
    Если ИскомыйСимвол = ":" И ЭтоFlowСтиль Тогда
        Возврат ЭтоЗначащееДвоеточиеВFlowСтиле(Позиция);
    КонецЕсли;
    
    // Для двоеточия в блок-стиле особая обработка
    Если ИскомыйСимвол = ":" И НЕ ЭтоFlowСтиль Тогда
        Возврат ЭтоЗначащееДвоеточиеВБлокСтиле(Строка, Позиция);
    КонецЕсли;
     
    ЭтоМногострочнаяСтрока = ИскомыйСимвол = "|" ИЛИ ИскомыйСимвол = ">";
    ЭтоЯкорьИлиАлиас = ИскомыйСимвол = "&" Или ИскомыйСимвол = "*";
    ЭтоНачалоFlowПоследовательности = ИскомыйСимвол = "{" Или ИскомыйСимвол = "[";
    
    Если ЭтоНачалоFlowПоследовательности Тогда
        // Для flow стиля проверяем, что символ находится в начале строки (после отступа)
        Возврат СтрНачинаетсяС(СокрЛП(Строка), ИскомыйСимвол);
    КонецЕсли;
    
    Если ЭтоЯкорьИлиАлиас Тогда
        Имя = ИзвлечьИмяЯкоряИлиАлиаса(Строка);
        Возврат Не Имя = "";
    Иначе
        // Обработка других символов
        Если Позиция = СтрДлина(Строка) Тогда
            Возврат Истина; 
        КонецЕсли;
    КонецЕсли;
    
    СледующийСимвол = Сред(Строка, Позиция + 1, 1);
    
    // Используем регулярные выражения для проверки допустимых символов
    Если ЭтоМногострочнаяСтрока Тогда
        // Паттерн для многострочных строк: пробелы, табы, цифры, + и -
        ПаттернДопустимых = "[ \t0-9\+\-]";
    Иначе
        // Паттерн для обычных случаев: только пробелы и табы
        ПаттернДопустимых = "[ \t]";
    КонецЕсли;
    
    РегВыражение = Новый РегулярноеВыражение(ПаттернДопустимых);
    ЭтоЗначащийСимвол = РегВыражение.Совпадает(СледующийСимвол);
    
    Возврат ЭтоЗначащийСимвол;

КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ОСНОВНЫЕ ПАРСЕРЫ ТИПОВ ДАННЫХ
////////////////////////////////////////////////////////////////////////////////

// Обрабатывает скалярное значение YAML
//
// Параметры:
//   Строки - Массив - массив строк для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное скалярное значение
//
Функция ОбработатьСкалярноеЗначение(Строки)
    Лог.Отладка("Обработка скалярного значения");
    
    // Проверяем на недопустимые комментарии в plain scalar
    ПроверитьКомментарииВPlainScalar(Строки);
    
    // Очищаем и объединяем строки
    ИтоговаяСтрока = ПолучитьОбъединеннуюСтроку(Строки);
    
    // Обрабатываем кавычки и специальные значения
    БылаВКавычках = ЭтоСтрокаВКавычках(ИтоговаяСтрока);
    ИтоговаяСтрока = УбратьКавычки(ИтоговаяСтрока);
    
    // Проверяем специальные значения
    СпециальноеЗначение = Неопределено;
    Если ПреобразоватьСпециальноеЗначение(ИтоговаяСтрока, СпециальноеЗначение) Тогда
        Лог.Отладка("Скаляр преобразован в специальное значение: " + СпециальноеЗначение);
        Возврат СпециальноеЗначение;
    КонецЕсли;
    
    // Преобразуем в число, если возможно
    Если НЕ БылаВКавычках И ЭтоЧисло(ИтоговаяСтрока) Тогда
        Возврат ОбработатьЧисловоеЗначение(ИтоговаяСтрока);
    КонецЕсли;
    
    Лог.Отладка("Скаляр обработан как строка: " + ИтоговаяСтрока);
    Возврат ИтоговаяСтрока;
КонецФункции

// Проверяет комментарии в plain scalar значениях
//
// Параметры:
//   Строки - Массив - массив строк для проверки
//
Процедура ПроверитьКомментарииВPlainScalar(Строки)
    ПерваяСтрока = ПолучитьПервуюСтроку(Строки);
    
    // Проверяем только для plain scalar (не quoted и не блочных)
    Если НЕ ЭтоQuotedИлиБлочныйСкаляр(ПерваяСтрока) И Строки.Количество() > 1 Тогда
        КоличествоЗначимыхСтрок = ПодсчитатьЗначимыеСтроки(Строки);
        
        Если КоличествоЗначимыхСтрок > 1 Тогда
            ПроверитьКомментарииВнутриЗначения(Строки);
            ПроверитьПоследовательностьКомментариев(Строки);
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

// Получает первую строку из массива
//
// Параметры:
//   Строки - Массив - массив строк
//
// Возвращаемое значение:
//   Строка - первая строка или пустая строка
//
Функция ПолучитьПервуюСтроку(Строки)
    Если Строки.Количество() > 0 Тогда
        Возврат СокрЛП(Строки[0]);
    КонецЕсли;
    Возврат "";
КонецФункции

// Проверяет, является ли строка quoted или блочным скаляром
//
// Параметры:
//   ПерваяСтрока - Строка - строка для проверки
//
// Возвращаемое значение:
//   Булево - Истина, если это quoted или блочный скаляр
//
Функция ЭтоQuotedИлиБлочныйСкаляр(ПерваяСтрока)
    Возврат СтрНачинаетсяС(ПерваяСтрока, """") 
        ИЛИ СтрНачинаетсяС(ПерваяСтрока, "'") 
        ИЛИ СтрНачинаетсяС(ПерваяСтрока, "|") 
        ИЛИ СтрНачинаетсяС(ПерваяСтрока, ">");
КонецФункции

// Подсчитывает количество значимых строк
//
// Параметры:
//   Строки - Массив - массив строк для подсчета
//
// Возвращаемое значение:
//   Число - количество значимых строк
//
Функция ПодсчитатьЗначимыеСтроки(Строки)
    КоличествоЗначимыхСтрок = 0;
    
    Для Индекс = 0 По Строки.ВГраница() Цикл
        СтрокаДляПроверки = СокрЛП(Строки[Индекс]);
        Если НЕ ЭтоПустаяСтрокаПослеОбрезки(СтрокаДляПроверки) И НЕ СтрНачинаетсяС(СтрокаДляПроверки, "#") Тогда
            КоличествоЗначимыхСтрок = КоличествоЗначимыхСтрок + 1;
        КонецЕсли;
    КонецЦикла;
    
    Возврат КоличествоЗначимыхСтрок;
КонецФункции

// Проверяет комментарии внутри значений
//
// Параметры:
//   Строки - Массив - массив строк для проверки
//
Процедура ПроверитьКомментарииВнутриЗначения(Строки)
    Для Индекс = 0 По Строки.ВГраница() Цикл
        СтрокаДляПроверки = СокрЛП(Строки[Индекс]);
        
        Если НЕ ЭтоПустаяСтрокаПослеОбрезки(СтрокаДляПроверки) И НЕ СтрНачинаетсяС(СтрокаДляПроверки, "#") Тогда
            ПозицияКомментария = ПозицияНеЭкранированногоСимвола(СтрокаДляПроверки, "#");
            Если ПозицияКомментария > 0 Тогда
                ВызватьИсключение "Комментарий недопустим внутри plain scalar значения";
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

// Проверяет последовательность комментариев
//
// Параметры:
//   Строки - Массив - массив строк для проверки
//
Процедура ПроверитьПоследовательностьКомментариев(Строки)
    ИндексПервойЗначимойСтроки = НайтиПервуюЗначимуюСтроку(Строки);
    
    Если ИндексПервойЗначимойСтроки >= 0 Тогда
        ПроверитьОтсутствиеЗначимыхСтрокПослеКомментариев(Строки, ИндексПервойЗначимойСтроки);
    КонецЕсли;
КонецПроцедуры

// Находит первую значимую строку
//
// Параметры:
//   Строки - Массив - массив строк для поиска
//
// Возвращаемое значение:
//   Число - индекс первой значимой строки или -1
//
Функция НайтиПервуюЗначимуюСтроку(Строки)
    Для Индекс = 0 По Строки.ВГраница() Цикл
        ОбрезаннаяСтрока = СокрЛП(Строки[Индекс]);
        Если НЕ ЭтоПустаяСтрокаПослеОбрезки(Строки[Индекс]) И Лев(ОбрезаннаяСтрока, 1) <> "#" Тогда
            Возврат Индекс;
        КонецЕсли;
    КонецЦикла;
    
    Возврат -1;
КонецФункции

// Проверяет отсутствие значимых строк после комментариев
//
// Параметры:
//   Строки - Массив - массив строк для проверки
//   НачальныйИндекс - Число - индекс начала проверки
//
Процедура ПроверитьОтсутствиеЗначимыхСтрокПослеКомментариев(Строки, НачальныйИндекс)
    ВстретилиКомментарий = Ложь;
    
    Для Индекс = НачальныйИндекс + 1 По Строки.ВГраница() Цикл
        ОбрезаннаяСтрока = СокрЛП(Строки[Индекс]);
        
        Если НЕ ЭтоПустаяСтрокаПослеОбрезки(Строки[Индекс]) Тогда
            Если Лев(ОбрезаннаяСтрока, 1) = "#" Тогда
                ВстретилиКомментарий = Истина;
            ИначеЕсли ВстретилиКомментарий Тогда
                ВызватьИсключение "Комментарий недопустим внутри plain scalar значения";
            Иначе
                // Продолжаем обработку обычной строки
                ВстретилиКомментарий = Ложь;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

// Получает объединенную строку из массива строк
//
// Параметры:
//   Строки - Массив - массив строк для объединения
//
// Возвращаемое значение:
//   Строка - объединенная строка
//
Функция ПолучитьОбъединеннуюСтроку(Строки)
    ОчищенныеСтроки = ОчиститьСтроки(Строки);
    ПерваяСтрока = ПолучитьПервуюСтроку(ОчищенныеСтроки);
    
    // Выбираем способ объединения в зависимости от типа кавычек
    Если СтрНачинаетсяС(ПерваяСтрока, """") Тогда
        Возврат СобратьDoubleQuotedСтрокуИзМассива(ОчищенныеСтроки);
    Иначе
        Возврат СобратьСтрокуИзМассива(ОчищенныеСтроки);
    КонецЕсли;
КонецФункции

// Обрабатывает числовое значение YAML
//
// Параметры:
//   ИтоговаяСтрока - Строка - строка для преобразования в число
//
// Возвращаемое значение:
//   Число - преобразованное числовое значение
Функция ОбработатьЧисловоеЗначение(ИтоговаяСтрока)
    // Проверяем, что строка не является null или неопределено
    Если ИтоговаяСтрока = Неопределено Или ТипЗнч(ИтоговаяСтрока) <> Тип("Строка") Тогда
        ВызватьИсключение("Невозможно преобразовать null или неопределено в число");
    КонецЕсли;
    
    // Проверяем на шестнадцатеричное число
    Если СтрНачинаетсяС(ВРег(СокрЛП(ИтоговаяСтрока)), "0X") Тогда
        Результат = ПреобразоватьИзШестнадцатеричной(ИтоговаяСтрока);
        Лог.Отладка("Скаляр преобразован из шестнадцатеричного в число: " + Результат);
        Возврат Результат;
    Иначе
        Результат = Число(ИтоговаяСтрока);
        Лог.Отладка("Скаляр преобразован в число: " + Результат);
        Возврат Результат;
    КонецЕсли;
КонецФункции

// Обрабатывает данные из массива строк в зависимости от типа содержимого
//
// Параметры:
//   Строки - Массив - массив строк для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанные данные
Функция ДанныеИзМассиваСтрок(Строки) 
    ТипСодержимого = ОпределитьТипСодержимого(Строки);
    Лог.Отладка("Обработка данных типа: " + ТипСодержимого);
    
    Если ТипСодержимого = "Объект" Тогда
        Возврат ПарсерОбъектов(Строки);
    ИначеЕсли ТипСодержимого = "Массив" Тогда
        Возврат ПарсерМассивов(Строки);
    ИначеЕсли ТипСодержимого = "FlowПоследовательность" Тогда
        Возврат ПарсерFlowПоследовательности(Строки);
    ИначеЕсли ТипСодержимого = "FlowОбъект" Тогда
        Возврат ПарсерFlowОбъекта(Строки);
    ИначеЕсли ТипСодержимого = "МногострочнаяСтрока" Тогда
        Возврат ПарсерМногострочныхСтрок(Строки);
    ИначеЕсли ТипСодержимого = "Якорь" Тогда
        Возврат ПарсерЯкорей(Строки);
    ИначеЕсли ТипСодержимого = "Алиас" Тогда
        Возврат ПарсерАлиасов(Строки);
    ИначеЕсли ТипСодержимого = "Тег" Тогда
        Возврат ПарсерТегов(Строки);
    ИначеЕсли ТипСодержимого = "Скаляр" Тогда
        Возврат ОбработатьСкалярноеЗначение(Строки);
    Иначе
        Лог.Предупреждение("Неопределенный тип содержимого, возвращаем Неопределено");
        Возврат Неопределено; // Если не определено, то возвращаем неопределено
    КонецЕсли;
    
КонецФункции

// Проверяет, является ли строка заключенной в кавычки
//
// Параметры:
//   Строка - Строка - строка для проверки
//
// Возвращаемое значение:
//   Булево - Истина, если строка в кавычках
//
Функция ЭтоСтрокаВКавычках(Строка)
    
    // Проверяем одинарные кавычки
    Если СтрНачинаетсяС(Строка, "'") Тогда
        // Если строка содержит только одну кавычку, это ошибка
        Если СтрДлина(Строка) = 1 Тогда
            ВызватьИсключение("Незакрытая одинарная кавычка в строке: " + Строка);
        КонецЕсли;
        
        // Проверяем, что есть закрывающая кавычка (не та же самая)
        Если НЕ СтрЗаканчиваетсяНа(Строка, "'") Тогда
            ВызватьИсключение("Незакрытая одинарная кавычка в строке: " + Строка);
        КонецЕсли;
        
        Возврат Истина;
    КонецЕсли;
    
    // Проверяем двойные кавычки
    Если СтрНачинаетсяС(Строка, """") Тогда
        // Если строка содержит только одну кавычку, это ошибка
        Если СтрДлина(Строка) = 1 Тогда
            ВызватьИсключение("Незакрытая двойная кавычка в строке: " + Строка);
        КонецЕсли;
        
        // Проверяем, что есть закрывающая кавычка (не та же самая)
        Если НЕ СтрЗаканчиваетсяНа(Строка, """") Тогда
            ВызватьИсключение("Незакрытая двойная кавычка в строке: " + Строка);
        КонецЕсли;
        
        Возврат Истина;
    КонецЕсли;
    
    Возврат Ложь;
    
КонецФункции

Функция УбратьКавычки(Строка)
    // Убираем кавычки из строки, если они есть
    Если ЭтоСтрокаВКавычках(Строка) Тогда
        Результат = УдалитьПервыйИПоследнийСимволы(Строка);
        
        // Обрабатываем экранированные символы в зависимости от типа кавычек
        Если СтрНачинаетсяС(Строка, """") Тогда
            Результат = ОбработатьЭкранирующиеПоследовательности(Результат, ТИП_КАВЫЧЕК_ДВОЙНЫЕ);
        КонецЕсли;
        
        Если СтрНачинаетсяС(Строка, "'") Тогда
            Результат = ОбработатьЭкранирующиеПоследовательности(Результат, ТИП_КАВЫЧЕК_ОДИНАРНЫЕ);
        КонецЕсли;
        
        Возврат Результат;
    КонецЕсли;
    
    Возврат Строка; // Если кавычек нет, возвращаем строку как есть
    
КонецФункции

// Преобразует специальные значения YAML (булевы, null и т.д.)
//
// Параметры:
//   Строка - Строка - строка для проверки и преобразования
//   Результат - Произвольный - результат преобразования (возвращается по ссылке)
//
// Возвращаемое значение:
//   Булево - Истина, если строка была преобразована в специальное значение
//
Функция ПреобразоватьСпециальноеЗначение(Строка, Результат)
    
    ВерхнийРегистр = ВРег(Строка);
    
    Если ВерхнийРегистр = "TRUE" Тогда
        Результат = Истина;
        Возврат Истина;
    ИначеЕсли ВерхнийРегистр = "FALSE" Тогда
        Результат = Ложь;
        Возврат Истина;
    ИначеЕсли ВерхнийРегистр = "NULL" Или Строка = "~" Тогда
        Результат = Неопределено;
        Возврат Истина;
    Иначе
        Возврат Ложь;
    КонецЕсли;
    
КонецФункции

// Проверяет, является ли строка числом
// Параметры:
//   Строка - Строка - строка для проверки
// Возвращаемое значение:
//   Булево - Истина, если строка является числом
//
Функция ЭтоЧисло(Знач Строка)
    
    Если ПустаяСтрока(Строка) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Убираем пробелы в начале и конце
    Строка = СокрЛП(Строка);
    
    // Проверяем на шестнадцатеричные числа
    Если ЭтоШестнадцатеричноеЧисло(Строка) Тогда
        Возврат Истина;
    КонецЕсли;
    
    // Проверяем на специальные значения
    Если ЭтоСпециальноеЗначение(Строка) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем на соответствие обычному числу
    Возврат ВалидироватьОбычноеЧисло(Строка);
    
КонецФункции

// Проверяет является ли строка шестнадцатеричным числом
//
// Параметры:
//   Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//   Булево - Истина, если строка является шестнадцатеричным числом
//
Функция ЭтоШестнадцатеричноеЧисло(Строка)
    Если НЕ (СтрНачинаетсяС(ВРег(Строка), "0X") И СтрДлина(Строка) > ДЛИНА_ПРЕФИКСА_ШЕСТНАДЦАТЕРИЧНОГО_ЧИСЛА) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем остальные символы как шестнадцатеричные
    Для Позиция = 3 По СтрДлина(Строка) Цикл
        Символ = ВРег(Сред(Строка, Позиция, 1));
        Если НЕ ((Символ >= "0" И Символ <= "9") ИЛИ (Символ >= "A" И Символ <= "F")) Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Истина;
КонецФункции

// Проверяет является ли строка специальным значением (true, false, null)
//
// Параметры:
//   Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//   Булево - Истина, если строка является специальным значением
//
Функция ЭтоСпециальноеЗначение(Строка)
    ВерхняяСтрока = ВРег(Строка);
    Возврат ВерхняяСтрока = "TRUE" Или ВерхняяСтрока = "FALSE" Или ВерхняяСтрока = "NULL";
КонецФункции

// Проверяет является ли строка обычным числом (десятичным, с экспонентой)
//
// Параметры:
//   Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//   Булево - Истина, если строка является обычным числом
//
Функция ВалидироватьОбычноеЧисло(Строка)
    // Проверяем, что строка не является просто символом экспоненты
    Если ВРег(Строка) = "E" Или ВРег(Строка) = "E+" Или ВРег(Строка) = "E-" Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем, что есть хотя бы одна цифра
    СодержитЦифру = Ложь;
    Для Позиция = 1 По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, Позиция, 1);
        Если Символ >= "0" И Символ <= "9" Тогда
            СодержитЦифру = Истина;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Если НЕ СодержитЦифру Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем каждый символ
    Для Позиция = 1 По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, Позиция, 1);
        Если НЕ ДопустимыйСимволЧисла(Символ, Позиция) Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;
    
    Если СтрНайти(Строка, ".",,,2) > 0 Тогда
        Возврат Ложь; // Несколько точек в числе недопустимо
    КонецЕсли;
    
    Возврат Истина;
КонецФункции

// Проверяет является ли символ допустимым в числе
//
// Параметры:
//   Символ - Строка - проверяемый символ
//   Позиция - Число - позиция символа в строке
//
// Возвращаемое значение:
//   Булево - Истина, если символ допустим
//
Функция ДопустимыйСимволЧисла(Символ, Позиция)
    Если Позиция = 1 И (Символ = "+" Или Символ = "-") Тогда
        Возврат Истина; // Знак в начале допустим
    ИначеЕсли Символ >= "0" И Символ <= "9" Тогда
        Возврат Истина; // Цифра допустима
    ИначеЕсли Символ = "." Тогда
        Возврат Истина; // Десятичная точка допустима
    ИначеЕсли ВРег(Символ) = "E" Тогда
        Возврат Истина; // Экспонента допустима
    Иначе
        Возврат Ложь; // Недопустимый символ
    КонецЕсли;
КонецФункции

// Преобразует шестнадцатеричную строку в десятичное число
//
// Параметры:
//   ШестнадцатеричнаяСтрока - Строка - строка вида "0xFFEEBB"
//
// Возвращаемое значение:
//   Число - десятичное представление числа
//
Функция ПреобразоватьИзШестнадцатеричной(ШестнадцатеричнаяСтрока)
    Строка = ВРег(СокрЛП(ШестнадцатеричнаяСтрока));
    
    Если НЕ СтрНачинаетсяС(Строка, "0X") Тогда
        Возврат 0;
    КонецЕсли;
    
    // Убираем префикс "0X"
    ШестнадцатеричныеЦифры = Сред(Строка, 3);
    
    Результат = 0;
    Основание = 1; // 16^0
    
    // Идем справа налево
    Позиция = СтрДлина(ШестнадцатеричныеЦифры);
    Пока Позиция >= 1 Цикл
        Символ = Сред(ШестнадцатеричныеЦифры, Позиция, 1);
        
        ЗначениеЦифры = 0;
        Если Символ >= "0" И Символ <= "9" Тогда
            ЗначениеЦифры = КодСимвола(Символ) - КодСимвола("0");
        ИначеЕсли Символ >= "A" И Символ <= "F" Тогда
            ЗначениеЦифры = КодСимвола(Символ) - КодСимвола("A") + ОСНОВАНИЕ_ДЕСЯТИЧНОЙ_СИСТЕМЫ;
        Иначе
            // Недопустимый символ
            Возврат 0;
        КонецЕсли;
        
        Результат = Результат + ЗначениеЦифры * Основание;
        Основание = Основание * ОСНОВАНИЕ_ШЕСТНАДЦАТЕРИЧНОЙ_СИСТЕМЫ;
        Позиция = Позиция - 1;
    КонецЦикла;
    
    Возврат Результат;
КонецФункции

// Парсер объектов
//
// Параметры:
//   Строки - Массив - массив строк для парсинга
//
// Возвращаемое значение:
//   Соответствие - результат парсинга объектов
//
Функция ПарсерОбъектов(Строки)
    Лог.Отладка("Начало парсинга объектов");
    
    МассивОбъектов = ПолучитьМассивСущностей(Строки);
    СоответствиеОбъектов = Новый Соответствие();
    
    Лог.Отладка("Найдено " + МассивОбъектов.Количество() + " объектов для обработки");

    // Обрабатываем объекты в порядке документа
    Для Каждого Объект Из МассивОбъектов Цикл
        ОбработатьОбъект(Объект, СоответствиеОбъектов);
    КонецЦикла;
    
    Лог.Отладка("Парсинг объектов завершен, получено " + СоответствиеОбъектов.Количество() + " свойств");
    Возврат СоответствиеОбъектов;
    
КонецФункции

// Обрабатывает один объект и добавляет его в соответствие
//
// Параметры:
//   Объект - Структура - объект для обработки
//   СоответствиеОбъектов - Соответствие - результирующее соответствие
//
Процедура ОбработатьОбъект(Объект, СоответствиеОбъектов)
    Если Объект.ИмяОбъекта = "<<" Тогда
        ОбработатьОбъектЯкорь(Объект, СоответствиеОбъектов);
    ИначеЕсли Объект.ТипОбъекта = "ОбъектЯвныйКлюч" Тогда
        ОбработатьОбъектЯвныйКлюч(Объект, СоответствиеОбъектов);
    Иначе
        ОбработатьОбычныйОбъект(Объект, СоответствиеОбъектов);
    КонецЕсли;
КонецПроцедуры

// Обрабатывает объект-якорь (merge key)
//
// Параметры:
//   Объект - Структура - объект-якорь
//   СоответствиеОбъектов - Соответствие - результирующее соответствие
//
Процедура ОбработатьОбъектЯкорь(Объект, СоответствиеОбъектов)
    Лог.Отладка("Обработка якоря");
    // Это якорь. Разыменуем его.
    Данные = ДанныеИзМассиваСтрок(Объект.Содержимое);
    Если не ТипЗнч(Данные) = Тип("Соответствие") Тогда
        Лог.Ошибка("Якорь должен быть объектом, а получено: " + ТипЗнч(Данные));
        ВызватьИсключение "Якорь должен быть объектом, а получено: " + ТипЗнч(Данные);
    КонецЕсли;
    // Добавляем все ключи и значения из якоря в текущее соответствие    
    Для каждого КлючИЗначение Из Данные Цикл
        СоответствиеОбъектов.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
    КонецЦикла;
КонецПроцедуры

// Обрабатывает объект с явным ключом
//
// Параметры:
//   Объект - Структура - объект с явным ключом
//   СоответствиеОбъектов - Соответствие - результирующее соответствие
//
Процедура ОбработатьОбъектЯвныйКлюч(Объект, СоответствиеОбъектов)
    Лог.Отладка("Обработка объекта с явным ключом");
    РезультатПарсинга = РазобратьЯвныйКлюч(Объект);
    СоответствиеОбъектов.Вставить(РезультатПарсинга.Ключ, РезультатПарсинга.Значение);
КонецПроцедуры

// Обрабатывает обычный объект с простым ключом
//
// Параметры:
//   Объект - Структура - обычный объект
//   СоответствиеОбъектов - Соответствие - результирующее соответствие
//
Процедура ОбработатьОбычныйОбъект(Объект, СоответствиеОбъектов)
    Лог.Отладка("Обработка объекта с ключом: " + Объект.ИмяОбъекта);
    
    // Проверяем, есть ли якорь в ключе объекта
    ЕстьЯкорьВКлюче = СтрНайти(Объект.ИмяОбъекта, "&") > 0;
    
    // Если ключ объекта содержит якорь, проверяем, что в содержимом нет других якорей
    Если ЕстьЯкорьВКлюче Тогда
        ПроверитьОтсутствиеЯкорейВСодержимом(Объект.Содержимое);
    КонецЕсли;
    
    ИтоговыйКлюч = ОпределитьКлючОбъекта(Объект.ИмяОбъекта);
    СоответствиеОбъектов.Вставить(ИтоговыйКлюч, ДанныеИзМассиваСтрок(Объект.Содержимое));  
КонецПроцедуры

// Определяет итоговый ключ объекта с учетом возможных тегов
//
// Параметры:
//   ИмяОбъекта - Строка - исходное имя объекта
//
// Возвращаемое значение:
//   Строка - итоговый ключ для использования
//
Функция ОпределитьКлючОбъекта(ИмяОбъекта)
    // Обрабатываем ключ как YAML значение (может содержать теги) только если он содержит тег
    Если СтрНайти(ИмяОбъекта, "!") > 0 Тогда
        МассивКлюча = Новый Массив;
        МассивКлюча.Добавить(ИмяОбъекта);
        ОбработанныйКлюч = ДанныеИзМассиваСтрок(МассивКлюча);
        
        // Если ключ был обработан как примитивное значение, используем его
        Если ТипЗнч(ОбработанныйКлюч) = Тип("Строка") 
                ИЛИ ТипЗнч(ОбработанныйКлюч) = Тип("Число") 
                ИЛИ ТипЗнч(ОбработанныйКлюч) = Тип("Булево") Тогда
            Возврат Строка(ОбработанныйКлюч);
        Иначе
            Возврат УбратьКавычки(ИмяОбъекта);
        КонецЕсли;
    Иначе
        Возврат УбратьКавычки(ИмяОбъекта);
    КонецЕсли;
КонецФункции

// Проверяет отсутствие якорей в содержимом объекта, который уже имеет якорь
//
// Параметры:
//   СтрокиСодержимого - Массив - строки содержимого объекта
//
// Исключения:
//   ВызватьИсключение - если в содержимом найдены якоря
//
Процедура ПроверитьОтсутствиеЯкорейВСодержимом(СтрокиСодержимого)
    Для Каждого Строка Из СтрокиСодержимого Цикл
        ОчищеннаяСтрока = СокрЛП(Строка);
        Если СтрНайти(ОчищеннаяСтрока, "&") > 0 Тогда
            // Проверяем, что это именно якорь, а не ссылка
            Если СтрНачинаетсяС(ОчищеннаяСтрока, "&") ИЛИ СтрНайти(ОчищеннаяСтрока, " &") > 0 Тогда
                ВызватьИсключение "Узел не может иметь несколько якорей";
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

// Формирует ключ из массива строк с учетом многострочных литералов
//
// Параметры:
//   СтрокиКлюча - Массив - строки ключа
//
// Возвращаемое значение:
//   Строка - сформированный ключ
Функция СформироватьКлючИзСтрок(СтрокиКлюча)
    Если СтрокиКлюча.Количество() = 0 Тогда
        Возврат "";
    ИначеЕсли СтрокиКлюча.Количество() = 1 Тогда
        Возврат СтрокиКлюча[0];
    Иначе
        // Проверяем, есть ли символы многострочного литерала в первой строке
        ПерваяСтрока = СтрокиКлюча[0];
        Если ПерваяСтрока = "|" И СтрокиКлюча.Количество() >= МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ Тогда
            // Литеральный стиль - соединяем строки через символ новой строки
            СтрокиДляСоединения = Новый Массив();
            Для ИндексСтроки = 1 По СтрокиКлюча.Количество() - 1 Цикл
                СтрокиДляСоединения.Добавить(СтрокиКлюча[ИндексСтроки]);
            КонецЦикла;
            Возврат СтрСоединить(СтрокиДляСоединения, Символы.ПС) + Символы.ПС;
        ИначеЕсли ПерваяСтрока = ">" И СтрокиКлюча.Количество() >= МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ Тогда
            // Складчатый стиль - соединяем строки через пробел
            СтрокиДляСоединения = Новый Массив();
            Для ИндексСтроки = 1 По СтрокиКлюча.Количество() - 1 Цикл
                СтрокиДляСоединения.Добавить(СтрокиКлюча[ИндексСтроки]);
            КонецЦикла;
            Возврат СтрСоединить(СтрокиДляСоединения, " ");
        Иначе
            // Обычный многострочный ключ - соединяем через пробел
            Возврат СтрСоединить(СтрокиКлюча, " ");
        КонецЕсли;
    КонецЕсли;
КонецФункции

// Обрабатывает строку с двоеточием, извлекая ключ и значение
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка без ведущих пробелов
//   СтрокиКлюча - Массив - массив строк ключа
//   СтрокиЗначения - Массив - массив строк значения
//
// Возвращаемое значение:
//   Соответствие - результат обработки с ключом и значением
//
Функция ОбработатьСтрокуСДвоеточием(СтрокаБезОтступов, СтрокиКлюча, СтрокиЗначения)
    ПозицияДвоеточия = ПозицияНеЭкранированногоСимвола(СтрокаБезОтступов, ":");
    Если ПозицияДвоеточия > 0 Тогда
        // Двоеточие найдено в строке - разделяем ключ и значение
        ЧастьКлюча = СокрЛП(Лев(СтрокаБезОтступов, ПозицияДвоеточия - 1));
        ЧастьЗначения = ИзвлечьЗначениеПослеДвоеточияСОчисткой(СтрокаБезОтступов, ПозицияДвоеточия);
        
        // Если эта строка начинается с "?", убираем его из ключа
        Если СтрНачинаетсяС(ЧастьКлюча, "?") Тогда
            ЧастьКлюча = УдалитьПервыйСимволСОчисткой(ЧастьКлюча);
        КонецЕсли;
        
        ДобавитьНепустоеЗначение(СтрокиКлюча, ЧастьКлюча);
        ДобавитьНепустоеЗначение(СтрокиЗначения, ЧастьЗначения);
        
        Возврат Истина;
    КонецЕсли;
    
    Возврат Ложь;
КонецФункции

// Обрабатывает случай с предопределенным именем ключа
//
// Параметры:
//   Объект - Структура - объект с именем и содержимым для обработки
//
// Возвращаемое значение:
//   Соответствие - результат обработки с ключом и значением
//
Функция ОбработатьПредопределенныйКлюч(Объект)
    РезультатРазбора = РазделитьКлючИЗначениеИзИмени(Объект.ИмяОбъекта);
    Ключ = РезультатРазбора.Ключ;
    СтрокиЗначения = РезультатРазбора.СтрокиЗначения;
    
    // Если значение не было найдено в имени, ищем в содержимом
    Если СтрокиЗначения.Количество() = 0 Тогда
        ОбработатьСодержимоеДляЗначения(Объект.Содержимое, Ключ, СтрокиЗначения);
    КонецЕсли;
    
    // Парсим значение
    Значение = СформироватьЗначениеИзСтрок(СтрокиЗначения);
    
    Результат = Новый Структура();
    Результат.Вставить("Ключ", Ключ);
    Результат.Вставить("Значение", Значение);
    Возврат Результат;
КонецФункции

Функция РазделитьКлючИЗначениеИзИмени(ИмяОбъекта)
    Ключ = "";
    СтрокиЗначения = Новый Массив();
    
    // Проверяем, есть ли двоеточие в самом имени объекта
    ПозицияДвоеточия = ПозицияНеЭкранированногоСимвола(ИмяОбъекта, ":");
    Если ПозицияДвоеточия > 0 Тогда
        // Двоеточие найдено в имени - разделяем ключ и значение
        Ключ = СокрЛП(Лев(ИмяОбъекта, ПозицияДвоеточия - 1));
        ЧастьЗначения = ИзвлечьЗначениеПослеДвоеточияСОчисткой(ИмяОбъекта, ПозицияДвоеточия);
        
        ДобавитьНепустоеЗначение(СтрокиЗначения, ЧастьЗначения);
    Иначе
        // Двоеточие не найдено в имени - используем имя как ключ
        Ключ = СокрЛП(ИмяОбъекта);
    КонецЕсли;
    
    Результат = Новый Структура();
    Результат.Вставить("Ключ", Ключ);
    Результат.Вставить("СтрокиЗначения", СтрокиЗначения);
    Возврат Результат;
КонецФункции

Процедура ОбработатьСодержимоеДляЗначения(Содержимое, Ключ, СтрокиЗначения)
    // Ищем значение в содержимом (строки, начинающиеся с ":")
    Для Каждого Строка Из Содержимое Цикл
        СтрокаБезОтступов = СокрЛП(Строка);
        Если СтрНачинаетсяС(СтрокаБезОтступов, ":") Тогда
            ОбработатьСтрокуСДвоеточиемВСодержимом(СтрокаБезОтступов, СтрокиЗначения);
        ИначеЕсли НЕ ЭтоПустаяСтрокаИлиКомментарий(Строка) 
                И НЕ СтрНачинаетсяС(СтрокаБезОтступов, ":") 
                И СтрокаБезОтступов <> Ключ Тогда
            // Для многострочных значений - строки с отступом больше базового (но не строки со значениями и не сам ключ)
            СтрокиЗначения.Добавить(Строка);
        Иначе
            // Пропускаем пустые строки, комментарии и строки с ключами
            Лог.Отладка("Пропускаем строку при обработке многострочного значения: %1", Строка);
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

Процедура ОбработатьСтрокуСДвоеточиемВСодержимом(СтрокаБезОтступов, СтрокиЗначения)
    // Проверяем на табы после двоеточия - это запрещено YAML спецификацией
    ПроверитьОтсутствиеТабуляцииПослеДвоеточия(СтрокаБезОтступов);
    // Извлекаем значение после ":"
    ЧастьЗначения = ИзвлечьЗначениеПослеДвоеточия(СтрокаБезОтступов);
    ДобавитьНепустоеЗначение(СтрокиЗначения, ЧастьЗначения);
КонецПроцедуры

Функция СформироватьЗначениеИзСтрок(СтрокиЗначения)
    // Парсим значение
    Возврат СпарситьЗначениеИзМассиваСтрок(СтрокиЗначения);
КонецФункции

// Обрабатывает цикл разбора содержимого для извлечения ключа и значения
//
// Параметры:
//   Объект - Структура - объект для обработки
//   СтрокиКлюча - Массив - массив строк ключа (передается по ссылке)
//   СтрокиЗначения - Массив - массив строк значения (передается по ссылке)  
//   НайденДвоеточие - Булево - флаг найденного двоеточия (передается по ссылке)
//   МногострочныйКлюч - Булево - флаг многострочного ключа (передается по ссылке)
//   ПропуститьТекущуюСтроку - Булево - флаг пропуска текущей строки (передается по ссылке)
//
Процедура ОбработатьЦиклРазбораСодержимого(Объект,
                                            СтрокиКлюча,
                                            СтрокиЗначения,
                                            НайденДвоеточие,
                                            МногострочныйКлюч,
                                            ПропуститьТекущуюСтроку)
    Для Каждого Строка Из Объект.Содержимое Цикл
        СтрокаБезОтступов = СокрЛП(Строка);
        
        Если НЕ НайденДвоеточие Тогда
            ОбработатьПоискДвоеточия(СтрокаБезОтступов,
                                    Строка,
                                    СтрокиКлюча,
                                    СтрокиЗначения,
                                    НайденДвоеточие,
                                    МногострочныйКлюч,
                                    ПропуститьТекущуюСтроку);
        Иначе
            // Двоеточие уже найдено, все остальное - часть значения
            ОбработатьДобавлениеЗначений(Строка, СтрокиЗначения);
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

Процедура ОбработатьПоискДвоеточия(СтрокаБезОтступов,
                                    ПолнаяСтрока,
                                    СтрокиКлюча,
                                    СтрокиЗначения,
                                    НайденДвоеточие,
                                    МногострочныйКлюч,
                                    ПропуститьТекущуюСтроку)
    // Ищем двоеточие в строке
    Если СтрНачинаетсяС(СтрокаБезОтступов, ":") Тогда
        ОбработатьСтрокуСДвоеточиемВНачале(СтрокаБезОтступов, СтрокиЗначения);
        НайденДвоеточие = Истина;
    Иначе
        ОбработатьПоискДвоеточияВСтроке(СтрокаБезОтступов,
                                    ПолнаяСтрока,
                                    СтрокиКлюча,
                                    СтрокиЗначения,
                                    НайденДвоеточие,
                                    МногострочныйКлюч,
                                    ПропуститьТекущуюСтроку);
    КонецЕсли;
КонецПроцедуры

Процедура ОбработатьСтрокуСДвоеточиемВНачале(СтрокаБезОтступов, СтрокиЗначения)
    // Строка начинается с двоеточия - это значение для многострочного ключа
    ЧастьЗначения = ИзвлечьЗначениеПослеДвоеточия(СтрокаБезОтступов);
    ДобавитьНепустоеЗначение(СтрокиЗначения, ЧастьЗначения);
КонецПроцедуры

Процедура ОбработатьПоискДвоеточияВСтроке(СтрокаБезОтступов,
                                    ПолнаяСтрока,
                                    СтрокиКлюча,
                                    СтрокиЗначения,
                                    НайденДвоеточие,
                                    МногострочныйКлюч,
                                    ПропуститьТекущуюСтроку)
    // Ищем двоеточие внутри строки (для однострочных ключей)
    НайденДвоеточие = ОбработатьСтрокуСДвоеточием(СтрокаБезОтступов, СтрокиКлюча, СтрокиЗначения);
    
    Если НЕ НайденДвоеточие И НЕ ЭтоПустаяСтрокаИлиКомментарий(ПолнаяСтрока) Тогда
        // Часть многострочного ключа
        ОбработатьМногострочныйКлюч(СтрокаБезОтступов, СтрокиКлюча, МногострочныйКлюч, ПропуститьТекущуюСтроку);
    ИначеЕсли НЕ НайденДвоеточие Тогда
        // Пустая строка или комментарий в процессе анализа ключа - игнорируем
        Лог.Отладка("Игнорируем пустую строку или комментарий при анализе ключа");
    Иначе
        // Двоеточие найдено - обработка завершена
        Лог.Отладка("Двоеточие найдено, продолжаем обработку");
    КонецЕсли;
КонецПроцедуры

// Инициализирует переменные для разбора явного ключа
//
// Возвращаемое значение:
//   Структура - структура с инициализированными переменными для разбора
//
Функция ИнициализироватьПеременныеРазбораКлюча()
    Результат = Новый Структура();
    Результат.Вставить("СтрокиКлюча", Новый Массив());
    Результат.Вставить("СтрокиЗначения", Новый Массив());
    Результат.Вставить("НайденДвоеточие", Ложь);
    Результат.Вставить("МногострочныйКлюч", Ложь);
    Результат.Вставить("ПропуститьТекущуюСтроку", Ложь);
    Возврат Результат;
КонецФункции

// Обрабатывает добавление строк значения после найденного двоеточия
//
// Параметры:
//   Строка - Строка - строка для добавления к значению
//   СтрокиЗначения - Массив - массив строк значения (передается по ссылке)
//
Процедура ОбработатьДобавлениеЗначений(Строка, СтрокиЗначения)
    СтрокаБезОтступов = СокрЛП(Строка);
    Если НЕ ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
        СтрокиЗначения.Добавить(СтрокаБезОтступов);
    КонецЕсли;
КонецПроцедуры

// Обрабатывает строку многострочного ключа
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка без ведущих пробелов
//   СтрокиКлюча - Массив - массив строк ключа (передается по ссылке)
//   МногострочныйКлюч - Булево - флаг многострочного ключа (передается по ссылке)
//   ПропуститьТекущуюСтроку - Булево - флаг пропуска текущей строки (передается по ссылке)
//
Процедура ОбработатьМногострочныйКлюч(СтрокаБезОтступов, СтрокиКлюча, МногострочныйКлюч, ПропуститьТекущуюСтроку)
    Если СтрНачинаетсяС(СтрокаБезОтступов, "?") Тогда
        ОбработатьКлючСВопросом(СтрокаБезОтступов, СтрокиКлюча, МногострочныйКлюч, ПропуститьТекущуюСтроку);
    Иначе
        ОбработатьКлючБезВопроса(СтрокаБезОтступов, СтрокиКлюча, МногострочныйКлюч, ПропуститьТекущуюСтроку);
    КонецЕсли;
КонецПроцедуры

Процедура ОбработатьКлючСВопросом(СтрокаБезОтступов, СтрокиКлюча, МногострочныйКлюч, ПропуститьТекущуюСтроку)
    // Убираем символ "?" и пробел
    СтрокаКлюча = ОчиститьСтрокуОтКомментариев(Сред(СтрокаБезОтступов, МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ));
    
    // Проверяем на многострочный литерал (символы | и >)
    Если СтрокаКлюча = "|" ИЛИ СтрокаКлюча = ">" Тогда
        // Это многострочный литерал - собираем все последующие строки до двоеточия
        МногострочныйКлюч = "";
        ПропуститьТекущуюСтроку = Истина;
    Иначе
        ДобавитьНепустоеЗначение(СтрокиКлюча, СтрокаКлюча);
        Если ПустаяСтрока(СтрокаКлюча) Тогда
            // Пустая строка ключа - игнорируем
            // Ничего не делаем, переходим к следующей строке
            Лог.Отладка("Пропускаем пустую строку в ключе");
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

Процедура ОбработатьКлючБезВопроса(СтрокаБезОтступов, СтрокиКлюча, МногострочныйКлюч, ПропуститьТекущуюСтроку)
    // Если активен многострочный литерал, добавляем эту строку к нему
    Если ПропуститьТекущуюСтроку Тогда
        ОбработатьАктивныйМногострочныйКлюч(СтрокаБезОтступов, МногострочныйКлюч);
    Иначе
        ОбработатьОбычнуюСтрокуКлюча(СтрокаБезОтступов, СтрокиКлюча);
    КонецЕсли;
КонецПроцедуры

Процедура ОбработатьАктивныйМногострочныйКлюч(СтрокаБезОтступов, МногострочныйКлюч)
    СтрокаКлючаБезКомментариев = ОчиститьСтрокуОтКомментариев(СтрокаБезОтступов);
    Если НЕ ПустаяСтрока(СтрокаКлючаБезКомментариев) Тогда
        Если НЕ ПустаяСтрока(МногострочныйКлюч) Тогда
            МногострочныйКлюч = МногострочныйКлюч + Символы.ПС;
        КонецЕсли;
        МногострочныйКлюч = МногострочныйКлюч + СтрокаКлючаБезКомментариев;
    КонецЕсли;
КонецПроцедуры

Процедура ОбработатьОбычнуюСтрокуКлюча(СтрокаБезОтступов, СтрокиКлюча)
    СтрокаКлючаБезКомментариев = ОчиститьСтрокуОтКомментариев(СтрокаБезОтступов);
    ДобавитьНепустоеЗначение(СтрокиКлюча, СтрокаКлючаБезКомментариев);
КонецПроцедуры

// Создает финальный результат для явного ключа
//
// Параметры:
//   СтрокиКлюча - Массив - массив строк ключа
//   СтрокиЗначения - Массив - массив строк значения
//   МногострочныйКлюч - Строка - многострочный ключ
//
// Возвращаемое значение:
//   Структура - структура с полями "Ключ" и "Значение"
//
Функция СоздатьФинальныйРезультат(СтрокиКлюча, СтрокиЗначения, МногострочныйКлюч)
    // Если был многострочный ключ, добавляем его
    Если НЕ ПустаяСтрока(МногострочныйКлюч) Тогда
        СтрокиКлюча.Добавить(МногострочныйКлюч);
    КонецЕсли;
    
    // Собираем ключ из строк
    Ключ = СформироватьКлючИзСтрок(СтрокиКлюча);
    
    // Парсим значение
    Значение = СпарситьЗначениеИзМассиваСтрок(СтрокиЗначения);
    
    // Обрабатываем ключ как полноценный YAML (может содержать теги) только если он содержит тег
    Если СтрНайти(Ключ, "!") > 0 Тогда
        МассивКлюча = Новый Массив;
        МассивКлюча.Добавить(Ключ);
        ОбработанныйКлюч = СпарситьЗначениеИзМассиваСтрок(МассивКлюча);
        
        // Если ключ был обработан как примитивное значение, используем его
        Если ТипЗнч(ОбработанныйКлюч) = Тип("Строка") 
                ИЛИ ТипЗнч(ОбработанныйКлюч) = Тип("Число") 
                ИЛИ ТипЗнч(ОбработанныйКлюч) = Тип("Булево") Тогда
            ИтоговыйКлюч = Строка(ОбработанныйКлюч);
        Иначе
            ИтоговыйКлюч = УбратьКавычки(Ключ);
        КонецЕсли;
    Иначе
        ИтоговыйКлюч = УбратьКавычки(Ключ);
    КонецЕсли;
    
    Результат = Новый Структура();
    Результат.Вставить("Ключ", ИтоговыйКлюч);
    Результат.Вставить("Значение", Значение);
    
    Лог.Отладка("Явный ключ разобран: ключ='" + Результат.Ключ + "', тип значения=" + ТипЗнч(Результат.Значение));
    Возврат Результат;
КонецФункции

// Разбирает явный ключ на ключ и значение
//
// Параметры:
//   Объект - Структура - объект с явным ключом
//
// Возвращаемое значение:
//   Структура - с полями Ключ и Значение
//
Функция РазобратьЯвныйКлюч(Объект)
    
    // Если имя ключа уже определено в первой строке (после ?), используем его
    Если НЕ ПустаяСтрока(Объект.ИмяОбъекта) Тогда
        Возврат ОбработатьПредопределенныйКлюч(Объект);
    Иначе
        // Инициализация переменных для обработки
        Переменные = ИнициализироватьПеременныеРазбораКлюча();
        СтрокиКлюча = Переменные.СтрокиКлюча;
        СтрокиЗначения = Переменные.СтрокиЗначения;
        НайденДвоеточие = Переменные.НайденДвоеточие;
        ПропуститьТекущуюСтроку = Переменные.ПропуститьТекущуюСтроку;
        МногострочныйКлюч = "";
        
        // Обрабатываем содержимое для извлечения ключа и значения
        ОбработатьЦиклРазбораСодержимого(Объект,
                                    СтрокиКлюча,
                                    СтрокиЗначения,
                                    НайденДвоеточие,
                                    МногострочныйКлюч,
                                    ПропуститьТекущуюСтроку);

        Возврат СоздатьФинальныйРезультат(СтрокиКлюча, СтрокиЗначения, МногострочныйКлюч);
    КонецЕсли;
КонецФункции

// Парсер якорей
//
// Параметры:
//   Строки - Массив - массив строк для парсинга якоря
//
// Возвращаемое значение:
//   Соответствие - результат парсинга объекта с якорем
//
Функция ПарсерЯкорей(Строки)
    Лог.Отладка("Начало парсинга якоря");
    
    // Находим параметры якоря
    ПараметрыЯкоря = НайтиПараметрыЯкоря(Строки);
    
    Если ПараметрыЯкоря = Неопределено Тогда
        Лог.Ошибка("Не найдено определение якоря");
        ВызватьИсключение "Не найдено определение якоря";
    КонецЕсли;
    
    Лог.Отладка("Найден якорь с именем: " + ПараметрыЯкоря.ИмяЯкоря);
    
    // Проверяем исходные строки на недопустимые вложенные якоря
    ПроверитьИсходныеСтрокиНаВложенныеЯкори(Строки, ПараметрыЯкоря);
    
    // Извлекаем строки содержимого (без строки с определением якоря)
    СтрокиСодержимого = ИзвлечьСодержимоеЯкоря(Строки, ПараметрыЯкоря);
    
    // Проверяем на недопустимые вложенные якоря для скаляров
    ПроверитьНедопустимыеВложенныеЯкори(СтрокиСодержимого);
    
    // Парсим содержимое как объект
    РезультатПарсинга = ДанныеИзМассиваСтрок(СтрокиСодержимого);
    
    // Сохраняем результат под якорем
    СохранитьЯкорь(ПараметрыЯкоря.ИмяЯкоря, РезультатПарсинга);
    Лог.Отладка("Якорь сохранен в менеджере якорей");
    
    // Возвращаем результат парсинга
    Возврат РезультатПарсинга;
    
КонецФункции

// Проверяет наличие недопустимых вложенных якорей для скаляров
//
// Параметры:
//   СтрокиСодержимого - Массив - строки содержимого якоря
//
// Исключения:
//   При обнаружении недопустимого вложенного якоря для скаляра
//
Процедура ПроверитьНедопустимыеВложенныеЯкори(СтрокиСодержимого)
    // Проверяем только простые случаи: когда содержимое якоря представляет
    // единственный скаляр с другим якорем
    Если СтрокиСодержимого.Количество() = 1 Тогда
        СтрокаСодержимого = СокрЛП(СтрокиСодержимого[0]);
        
        // Пропускаем пустые строки
        Если ПустаяСтрока(СтрокаСодержимого) Тогда
            Возврат;
        КонецЕсли;
        
        Лог.Отладка("Проверка содержимого якоря: '" + СтрокаСодержимого + "'");
        
        // Проверяем, является ли это простым скаляром с якорем (без двоеточия)
        Если СтрНачинаетсяС(СтрокаСодержимого, "&") И СтрНайти(СтрокаСодержимого, ":") = 0 Тогда
            // Это попытка создать якорь для простого скаляра, который уже имеет якорь
            Лог.Ошибка("Недопустимо назначать якорь для узла, который уже имеет якорь");
            ВызватьИсключение "Недопустимо назначать якорь для узла, который уже имеет якорь";
        КонецЕсли;
        
        // Проверяем, является ли это алиасом - недопустимо назначать якорь алиасу
        Если СтрНачинаетсяС(СтрокаСодержимого, "*") Тогда
            // Это попытка создать якорь для алиаса, что недопустимо
            Лог.Ошибка("Недопустимо назначать якорь для алиаса");
            ВызватьИсключение "Недопустимо назначать якорь для алиаса";
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

// Проверяет строки до извлечения содержимого якоря на наличие недопустимых вложенных якорей
//
// Параметры:
//   МассивСтрок - Массив - исходные строки якоря до обработки
//   ПараметрыЯкоря - Структура - параметры якоря
//
// Исключения:
//   При обнаружении недопустимого вложенного якоря для скаляра
//
Процедура ПроверитьИсходныеСтрокиНаВложенныеЯкори(МассивСтрок, ПараметрыЯкоря)
    СтрокаСЯкорем = МассивСтрок[ПараметрыЯкоря.ИндексСтрокиСЯкорем];
    
    ПроверитьСодержимоеПослеЯкоря(СтрокаСЯкорем);
    ПроверитьСодержимоеНаВложенныеЯкори(МассивСтрок, ПараметрыЯкоря);
КонецПроцедуры

// Проверяет содержимое после якоря в той же строке
//
// Параметры:
//   СтрокаСЯкорем - Строка - строка содержащая якорь
//
Процедура ПроверитьСодержимоеПослеЯкоря(СтрокаСЯкорем)
    // Получаем содержимое после якоря в той же строке
    СодержимоеПослеЯкоря = УдалитьОпределениеЯкоря(СтрокаСЯкорем);
    СодержимоеПослеЯкоря = СокрЛП(СодержимоеПослеЯкоря);
    
    Лог.Отладка("Проверка содержимого после якоря в строке: '" + СодержимоеПослеЯкоря + "'");
    
    // Если в той же строке с якорем есть содержимое, которое тоже является якорем для скаляра
    // И это НЕ скалярное значение (нет двоеточия в строке), то это ошибка
    Если ЭтоДвойнойЯкорьДляСкаляра(СодержимоеПослеЯкоря) Тогда
        Лог.Ошибка("Узел не может иметь несколько якорей");
        ВызватьИсключение "Узел не может иметь несколько якорей";
    КонецЕсли;
КонецПроцедуры

// Проверяет является ли содержимое двойным якорем для скаляра
//
// Параметры:
//   Содержимое - Строка - содержимое для проверки
//
// Возвращаемое значение:
//   Булево - Истина если это двойной якорь для скаляра
//
Функция ЭтоДвойнойЯкорьДляСкаляра(Содержимое)
    Возврат НЕ ПустаяСтрока(Содержимое) 
        И СтрНачинаетсяС(Содержимое, "&") 
        И СтрНайти(Содержимое, ":") = 0;
КонецФункции

// Проверяет содержимое якоря на наличие вложенных якорей
//
// Параметры:
//   МассивСтрок - Массив - массив всех строк
//   ПараметрыЯкоря - Структура - параметры якоря
//
Процедура ПроверитьСодержимоеНаВложенныеЯкори(МассивСтрок, ПараметрыЯкоря)
    УровеньОтступаЯкоря = ПараметрыЯкоря.УровеньОтступа;
    
    Для Индекс = ПараметрыЯкоря.ИндексСтрокиСЯкорем + 1 По МассивСтрок.ВГраница() Цикл
        СтрокаСодержимого = МассивСтрок[Индекс];
        
        // Прекращаем проверку, если дошли до строки с уровнем отступа меньше или равно якорю
        Если ДостигнутКонецОбластиЯкоря(СтрокаСодержимого, УровеньОтступаЯкоря) Тогда
            Прервать;
        КонецЕсли;
        
        ПроверитьСтрокуНаВложенныйЯкорь(СтрокаСодержимого);
    КонецЦикла;
КонецПроцедуры

// Проверяет достигнут ли конец области якоря
//
// Параметры:
//   Строка - Строка - проверяемая строка
//   УровеньОтступаЯкоря - Число - уровень отступа якоря
//
// Возвращаемое значение:
//   Булево - Истина если достигнут конец области
//
Функция ДостигнутКонецОбластиЯкоря(Строка, УровеньОтступаЯкоря)
    УровеньОтступаСтроки = ОпределитьОтступ(Строка);
    Возврат УровеньОтступаСтроки <= УровеньОтступаЯкоря И НЕ ПустаяСтрока(СокрЛП(Строка));
КонецФункции

// Проверяет строку на наличие вложенного якоря
//
// Параметры:
//   СтрокаСодержимого - Строка - строка для проверки
//
Процедура ПроверитьСтрокуНаВложенныйЯкорь(СтрокаСодержимого)
    // Пропускаем пустые строки и комментарии
    ОчищеннаяСтрока = СокрЛП(СтрокаСодержимого);
    Если ПустаяСтрока(ОчищеннаяСтрока) ИЛИ СтрНачинаетсяС(ОчищеннаяСтрока, "#") Тогда
        Возврат;
    КонецЕсли;
    
    Лог.Отладка("Проверка строки содержимого якоря: '" + ОчищеннаяСтрока + "'");
    
    // Проверяем, содержит ли строка якорь для скалярного значения
    Если ЕстьНевалидныйВложенныйЯкорь(ОчищеннаяСтрока) Тогда
        Лог.Ошибка("Узел не может иметь несколько якорей");
        ВызватьИсключение "Узел не может иметь несколько якорей";
    КонецЕсли;
КонецПроцедуры

// Проверяет есть ли в строке невалидный вложенный якорь
//
// Параметры:
//   Строка - Строка - строка для проверки
//
// Возвращаемое значение:
//   Булево - Истина если есть невалидный вложенный якорь
//
Функция ЕстьНевалидныйВложенныйЯкорь(Строка)
    // Проверяем, содержит ли строка якорь
    Если СтрНайти(Строка, "&") = 0 Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Убеждаемся, что это именно определение якоря, а не ссылка
    Если НЕ СтрНачинаетсяС(Строка, "&") Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Если это якорь, но НЕ для ключа (нет двоеточия), то это ошибка
    Возврат СтрНайти(Строка, ":") = 0;
КонецФункции

Функция ПарсерАлиасов(Строки)
    Лог.Отладка("Начало парсинга алиаса");
    
    Для каждого Строка Из Строки Цикл
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
            Продолжить;
        КонецЕсли;
        ДанныеУправляющегоСимвола = НайтиУправляющийСимволИЕгоПозицию(Строка);
        Если ДанныеУправляющегоСимвола.Символ <> "*" Тогда
            Лог.Ошибка("Ожидался алиас, а найдено: " + Строка);
            ВызватьИсключение "Ожидался алиас, а найдено: " + Строка;
        КонецЕсли;
        ИмяАлиаса = ИзвлечьИмяЯкоряИлиАлиаса(Строка);
        Если ПустаяСтрока(ИмяАлиаса) Тогда
            Лог.Ошибка("Не указано имя алиаса в строке: " + Строка);
            ВызватьИсключение "Не указано имя алиаса в строке: " + Строка;
        КонецЕсли;
        Лог.Отладка("Найден алиас с именем: " + ИмяАлиаса);
        Прервать;
    КонецЦикла;
    
    // Получаем значение алиаса из менеджера якорей
    Если НЕ ЯкорьСуществует(ИмяАлиаса) Тогда
        Лог.Ошибка("Не найден алиас: " + ИмяАлиаса);
        ВызватьИсключение "Не найден алиас: " + ИмяАлиаса;
    КонецЕсли;
    
    ЗначениеАлиаса = ПолучитьЗначениеЯкоря(ИмяАлиаса);
    
    Лог.Отладка("Алиас успешно разрешен");
    Возврат ЗначениеАлиаса;
КонецФункции

// Парсер тегов
//
// Параметры:
//   Строки - Массив - массив строк для парсинга
//
// Возвращаемое значение:
//   Произвольный - результат парсинга тегированного значения
//
Функция ПарсерТегов(Строки)
    Лог.Отладка("Начало парсинга тега");
    
    ТегИЗначение = Неопределено;
    
    Для каждого Строка Из Строки Цикл
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
            Продолжить;
        КонецЕсли;
        
        ТегИЗначение = РазобратьТегИЗначение(Строка);
        Лог.Отладка("Разобран тег: " + ТегИЗначение.Тег + " со значением: " + ТегИЗначение.Значение);
        Прервать;
    КонецЦикла;
    
    Если ТегИЗначение = Неопределено Тогда
        Лог.Ошибка("Не удалось разобрать тег");
        ВызватьИсключение "Не удалось разобрать тег";
    КонецЕсли;
    
    // Проверяем, содержит ли значение якорь (приоритет перед проверкой двоеточия)
    Если СтрНачинаетсяС(СокрЛП(ТегИЗначение.Значение), "&") Тогда
        Возврат ОбработатьТегСЯкорем(ТегИЗначение, Строки);
    // Проверяем, есть ли в значении структурные элементы
    ИначеЕсли СтрНайти(ТегИЗначение.Значение, ":") > 0 Тогда
        Возврат ОбработатьТегированныйКлючОбъекта(ТегИЗначение, Строки);
    ИначеЕсли (СтрНачинаетсяС(СокрЛП(ТегИЗначение.Значение), "{") 
            ИЛИ СтрНачинаетсяС(СокрЛП(ТегИЗначение.Значение), "[")) 
            И Строки.Количество() > 1 Тогда
        Возврат ОбработатьТегированныйFlowОбъект(ТегИЗначение, Строки);
    ИначеЕсли ПустаяСтрока(ТегИЗначение.Значение) И Строки.Количество() > 1 Тогда
        Возврат ОбработатьТегБезЗначения(ТегИЗначение, Строки);
    Иначе
        Возврат ОбработатьПростойТегированныйСкаляр(ТегИЗначение, Строки);
    КонецЕсли;
КонецФункции

// Обрабатывает тег со значением, содержащим якорь
//
// Параметры:
//   ТегИЗначение - Структура - тег и значение
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Произвольный - обработанное значение с якорем
//
Функция ОбработатьТегСЯкорем(ТегИЗначение, Строки)
    Лог.Отладка("DEBUG: УСЛОВИЕ ЯКОРЯ СРАБОТАЛО! Значение: '" + ТегИЗначение.Значение + "'");
    // Значение тега содержит якорь - нужно обработать якорь и взять значение
    Лог.Отладка("Значение тега содержит якорь: " + ТегИЗначение.Значение);
    
    РазборЯкоря = РазобратьЯкорьИЗначение(ТегИЗначение.Значение);
    
    // Определяем значение для парсинга
    РезультатПарсинга = ПолучитьЗначениеДляЯкоря(РазборЯкоря, Строки);
    
    // Применяем тег к результату
    РезультатПрименения = ПрименитьТегКЗначению(ТегИЗначение.Тег, РезультатПарсинга);
    
    // Сохраняем якорь в менеджере якорей
    СохранитьЯкорь(РазборЯкоря.ИмяЯкоря, РезультатПрименения);
    
    Возврат РезультатПрименения;
КонецФункции

// Разбирает строку значения на имя якоря и значение после якоря
//
// Параметры:
//   ЗначениеСЯкорем - Строка - строка с якорем
//
// Возвращаемое значение:
//   Структура - ИмяЯкоря, ЗначениеПослеЯкоря
//
Функция РазобратьЯкорьИЗначение(ЗначениеСЯкорем)
    // Ищем позицию пробела после якоря
    СтрокаЗначения = СокрЛП(ЗначениеСЯкорем);
    ПозицияПробела = СтрНайти(СтрокаЗначения, " ");
    ИмяЯкоря = "";
    ЗначениеПослеЯкоря = "";
    
    Если ПозицияПробела > 0 Тогда
        // Есть значение на той же строке после якоря
        ИмяЯкоря = Лев(СтрокаЗначения, ПозицияПробела - 1);
        ЗначениеПослеЯкоря = СокрЛП(Сред(СтрокаЗначения, ПозицияПробела + 1));
    Иначе
        // Якорь без значения на той же строке
        ИмяЯкоря = СтрокаЗначения;
    КонецЕсли;
    
    // Убираем символ & из имени якоря
    Если СтрНачинаетсяС(ИмяЯкоря, "&") Тогда
        ИмяЯкоря = Сред(ИмяЯкоря, 2);
    КонецЕсли;
    
    Результат = Новый Структура();
    Результат.Вставить("ИмяЯкоря", ИмяЯкоря);
    Результат.Вставить("ЗначениеПослеЯкоря", ЗначениеПослеЯкоря);
    
    Возврат Результат;
КонецФункции

// Получает значение для парсинга на основе разбора якоря
//
// Параметры:
//   РазборЯкоря - Структура - результат разбора якоря
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Произвольный - значение для парсинга
//
Функция ПолучитьЗначениеДляЯкоря(РазборЯкоря, Строки)
    РезультатПарсинга = Неопределено;
    
    Если НЕ ПустаяСтрока(РазборЯкоря.ЗначениеПослеЯкоря) Тогда
        // Используем значение с той же строки
        РезультатПарсинга = РазборЯкоря.ЗначениеПослеЯкоря;
        // Убираем двоеточие в конце, если это ключ объекта
        Если СтрЗаканчиваетсяНа(РезультатПарсинга, ":") Тогда
            РезультатПарсинга = Лев(РезультатПарсинга, СтрДлина(РезультатПарсинга) - 1);
            РезультатПарсинга = СокрП(РезультатПарсинга);
            Лог.Отладка("DEBUG: Убрали двоеточие, значение стало: '" + РезультатПарсинга + "'");
        КонецЕсли;
    Иначе
        // Парсим значение из следующих строк
        НовыеСтроки = Новый Массив();
        Для Инд = 1 По Строки.Количество() - 1 Цикл
            НовыеСтроки.Добавить(Строки[Инд]);
        КонецЦикла;
        РезультатПарсинга = ДанныеИзМассиваСтрок(НовыеСтроки);
    КонецЕсли;
    
    Возврат РезультатПарсинга;
КонецФункции

// Обрабатывает тегированный ключ объекта
//
// Параметры:
//   ТегИЗначение - Структура - тег и значение
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Соответствие - объект с тегированным ключом
//
Функция ОбработатьТегированныйКлючОбъекта(ТегИЗначение, Строки)
    // Это тегированный ключ объекта - нужно парсить как объект
    Лог.Отладка("Обнаружен тегированный ключ объекта");
    
    // Создаем новую строку без тега для парсинга объекта
    СтрокаБезТега = СокрЛП(ТегИЗначение.Значение);
    
    // Заменяем первую строку на строку без тега
    НовыеСтроки = Новый Массив();
    НовыеСтроки.Добавить(СтрокаБезТега);
    
    // Добавляем остальные строки
    Для Инд = 1 По Строки.Количество() - 1 Цикл
        НовыеСтроки.Добавить(Строки[Инд]);
    КонецЦикла;
    
    // Парсим как объект
    Объект = ПарсерОбъектов(НовыеСтроки);
    
    // Применяем тег к ключу объекта
    Если ТипЗнч(Объект) = Тип("Соответствие") И Объект.Количество() = 1 Тогда
        Для Каждого КлючЗначение Из Объект Цикл
            ТегированныйКлюч = ПрименитьТегКЗначению(ТегИЗначение.Тег, КлючЗначение.Ключ);
            НовыйОбъект = Новый Соответствие();
            НовыйОбъект.Вставить(ТегированныйКлюч, КлючЗначение.Значение);
            Возврат НовыйОбъект;
        КонецЦикла;
    КонецЕсли;
    
    Возврат Объект;
КонецФункции

// Обрабатывает тегированный flow объект или массив
//
// Параметры:
//   ТегИЗначение - Структура - тег и значение
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Произвольный - обработанный flow объект
//
Функция ОбработатьТегированныйFlowОбъект(ТегИЗначение, Строки)
    // Это начало flow object/array - нужно собрать весь flow из всех строк
    Лог.Отладка("Обнаружен flow object/array с тегом, собираем полное содержимое");
    
    // Объединяем все строки в одну для парсинга flow object
    ПолнаяСтрокаFlow = "";
    Для Инд = 0 По Строки.Количество() - 1 Цикл
        Если Инд = 0 Тогда
            // Первая строка содержит тег, берем только значение
            ПолнаяСтрокаFlow = ПолнаяСтрокаFlow + ТегИЗначение.Значение;
        Иначе
            ПолнаяСтрокаFlow = ПолнаяСтрокаFlow + " " + СокрЛП(Строки[Инд]);
        КонецЕсли;
    КонецЦикла;
    
    Лог.Отладка("Полная строка flow для парсинга: " + ПолнаяСтрокаFlow);
    
    // Парсим flow object/array
    РезультатПарсинга = ПарситьFlowОбъектИлиМассив(ПолнаяСтрокаFlow);
    
    // Применяем тег к результату
    Если ТегИЗначение.Тег = "!!map" И ТипЗнч(РезультатПарсинга) = Тип("Соответствие") Тогда
        Возврат РезультатПарсинга;
    ИначеЕсли ТегИЗначение.Тег = "!!seq" И ТипЗнч(РезультатПарсинга) = Тип("Массив") Тогда
        Возврат РезультатПарсинга;
    Иначе
        РезультатПрименения = ПрименитьТегКЗначению(ТегИЗначение.Тег, РезультатПарсинга);
        Возврат РезультатПрименения;
    КонецЕсли;
КонецФункции

// Парсит flow объект или массив из строки
//
// Параметры:
//   ПолнаяСтрокаFlow - Строка - строка с flow синтаксисом
//
// Возвращаемое значение:
//   Произвольный - распарсенный объект или массив
//
Функция ПарситьFlowОбъектИлиМассив(ПолнаяСтрокаFlow)
    РезультатПарсинга = Неопределено;
    
    Если СтрНачинаетсяС(СокрЛП(ПолнаяСтрокаFlow), "{") Тогда
        // Создаем массив из одной строки для парсера flow объекта
        СтрокиДляПарсинга = Новый Массив();
        СтрокиДляПарсинга.Добавить(ПолнаяСтрокаFlow);
        РезультатПарсинга = ПарсерFlowОбъекта(СтрокиДляПарсинга);
    ИначеЕсли СтрНачинаетсяС(СокрЛП(ПолнаяСтрокаFlow), "[") Тогда
        // Создаем массив из одной строки для парсера flow последовательности
        СтрокиДляПарсинга = Новый Массив();
        СтрокиДляПарсинга.Добавить(ПолнаяСтрокаFlow);
        РезультатПарсинга = ПарсерFlowПоследовательности(СтрокиДляПарсинга);
    Иначе
        // Неожиданный формат flow - возвращаем как есть
        РезультатПарсинга = ПолнаяСтрокаFlow;
    КонецЕсли;
    
    Возврат РезультатПарсинга;
КонецФункции

// Обрабатывает тег без значения на той же строке
//
// Параметры:
//   ТегИЗначение - Структура - тег и значение
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьТегБезЗначения(ТегИЗначение, Строки)
    // Тег без значения на той же строке, но есть следующие строки
    // Нужно определить тип содержимого по следующим строкам
    Лог.Отладка("Тег без значения, определяем тип по следующим строкам");
    
    // Создаем массив строк без первой (строки с тегом)
    НовыеСтроки = Новый Массив();
    Для Инд = 1 По Строки.Количество() - 1 Цикл
        НовыеСтроки.Добавить(Строки[Инд]);
    КонецЦикла;
    
    // Определяем тип содержимого
    ТипСодержимого = ОпределитьТипСодержимого(НовыеСтроки);
    
    // Парсим содержимое соответствующим парсером
    РезультатПарсинга = ПарситьСодержимоеПоТипу(ТипСодержимого, НовыеСтроки);
    
    // Применяем тег к результату
    Возврат ПрименитьТегКРезультатуПарсинга(ТегИЗначение.Тег, РезультатПарсинга);
КонецФункции

// Парсит содержимое по определенному типу
//
// Параметры:
//   ТипСодержимого - Строка - тип содержимого
//   НовыеСтроки - Массив - строки для парсинга
//
// Возвращаемое значение:
//   Произвольный - результат парсинга
//
Функция ПарситьСодержимоеПоТипу(ТипСодержимого, НовыеСтроки)
    РезультатПарсинга = Неопределено;
    
    Если ТипСодержимого = "Объект" Тогда
        РезультатПарсинга = ПарсерОбъектов(НовыеСтроки);
    ИначеЕсли ТипСодержимого = "Массив" Тогда
        РезультатПарсинга = ПарсерМассивов(НовыеСтроки);
    Иначе
        РезультатПарсинга = ДанныеИзМассиваСтрок(НовыеСтроки);
    КонецЕсли;
    
    Возврат РезультатПарсинга;
КонецФункции

// Применяет тег к результату парсинга с учетом типа тега
//
// Параметры:
//   Тег - Строка - YAML тег
//   РезультатПарсинга - Произвольный - результат парсинга
//
// Возвращаемое значение:
//   Произвольный - результат применения тега
//
Функция ПрименитьТегКРезультатуПарсинга(Тег, РезультатПарсинга)
    // Применяем тег к результату
    Если Тег = "!!map" И ТипЗнч(РезультатПарсинга) = Тип("Соответствие") Тогда
        Возврат РезультатПарсинга;
    ИначеЕсли Тег = "!!seq" И ТипЗнч(РезультатПарсинга) = Тип("Массив") Тогда
        Возврат РезультатПарсинга;
    ИначеЕсли Тег = "!!set" И ТипЗнч(РезультатПарсинга) = Тип("Соответствие") Тогда
        // Для !!set применяем тег к объекту Соответствие напрямую
        РезультатПрименения = ПрименитьТегКЗначению(Тег, РезультатПарсинга);
        Возврат РезультатПрименения;
    ИначеЕсли Тег = "!!omap" И ТипЗнч(РезультатПарсинга) = Тип("Массив") Тогда
        // Для !!omap применяем тег к объекту Массив напрямую
        РезультатПрименения = ПрименитьТегКЗначению(Тег, РезультатПарсинга);
        Возврат РезультатПрименения;
    Иначе
        // Для других тегов (включая пользовательские) передаем исходный объект
        // Особая обработка для !!str без значения
        Если Тег = "!!str" И РезультатПарсинга = Неопределено Тогда
            РезультатПрименения = ПрименитьТегКЗначению(Тег, "");
        Иначе
            РезультатПрименения = ПрименитьТегКЗначению(Тег, РезультатПарсинга);
        КонецЕсли;
        Возврат РезультатПрименения;
    КонецЕсли;
КонецФункции

// Обрабатывает простой тегированный скаляр
//
// Параметры:
//   ТегИЗначение - Структура - тег и значение
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Произвольный - обработанный скаляр
//
Функция ОбработатьПростойТегированныйСкаляр(ТегИЗначение, Строки)
    // Это простой тегированный скаляр
    // Проверяем, не является ли значение многострочной строкой в кавычках
    Если СтрНачинаетсяС(СокрЛП(ТегИЗначение.Значение), """") И НЕ СтрЗаканчиваетсяНа(СокрП(ТегИЗначение.Значение), """") И Строки.Количество() > 1 Тогда
        РезультатПрименения = ОбработатьМногострочнуюСтрокуВКавычках(ТегИЗначение, Строки);
    Иначе
        РезультатПрименения = ПрименитьТегКЗначению(ТегИЗначение.Тег, ТегИЗначение.Значение);
    КонецЕсли;
    
    Лог.Отладка("Тег успешно применен");
    Возврат РезультатПрименения;
КонецФункции

// Обрабатывает многострочную строку в кавычках
//
// Параметры:
//   ТегИЗначение - Структура - тег и значение
//   Строки - Массив - массив строк YAML
//
// Возвращаемое значение:
//   Произвольный - обработанная многострочная строка
//
Функция ОбработатьМногострочнуюСтрокуВКавычках(ТегИЗначение, Строки)
    Лог.Отладка("Обнаружена многострочная строка в кавычках, собираем полное содержимое");
    
    // Собираем полную многострочную строку в кавычках
    ПолнаяСтрока = ТегИЗначение.Значение;
    
    // Добавляем содержимое следующих строк до закрывающей кавычки
    Для Инд = 1 По Строки.Количество() - 1 Цикл
        СтрокаСодержимого = Строки[Инд];
        
        // Убираем отступы только для проверки, но сохраняем исходную строку для контента
        ОчищеннаяСтрока = СокрЛП(СтрокаСодержимого);
        
        // Пропускаем пустые строки и комментарии
        Если ПустаяСтрока(ОчищеннаяСтрока) ИЛИ СтрНачинаетсяС(ОчищеннаяСтрока, "#") Тогда
            Продолжить;
        КонецЕсли;
        
        // Добавляем строку к полному содержимому
        ПолнаяСтрока = ПолнаяСтрока + " " + СокрЛП(СтрокаСодержимого);
        
        // Если строка заканчивается закрывающей кавычкой, заканчиваем сбор
        Если СтрЗаканчиваетсяНа(СокрП(СтрокаСодержимого), """") Тогда
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Лог.Отладка("Собранная многострочная строка: " + ПолнаяСтрока);
    Возврат ПрименитьТегКЗначению(ТегИЗначение.Тег, ПолнаяСтрока);
КонецФункции

// Парсер массивов
//
// Параметры:
//   Строки - Массив - массив строк для парсинга
//
// Возвращаемое значение:
//   Массив - результат парсинга массива
//
Функция ПарсерМассивов(Строки)
    Лог.Отладка("Начало парсинга массива");
    
    МассивЭлементов = ПолучитьМассивСущностей(Строки);
    МассивРезультат = Новый Массив();
    
    Лог.Отладка("Найдено " + МассивЭлементов.Количество() + " элементов массива");
    
    Для Каждого Элемент Из МассивЭлементов Цикл
        Лог.Отладка("Обработка элемента массива");
        МассивРезультат.Добавить(ДанныеИзМассиваСтрок(Элемент.Содержимое));
    КонецЦикла;
    
    Лог.Отладка("Парсинг массива завершен, получено " + МассивРезультат.Количество() + " элементов");
    Возврат МассивРезультат;
КонецФункции

// Создает структуру сущности с базовыми параметрами
//
// Параметры:
//   ТипОбъекта - Строка - тип объекта (Объект, ЭлементМассива)
//   ИмяОбъекта - Строка - имя объекта
//   МинимальныйОтступ - Число - минимальный отступ
//
// Возвращаемое значение:
//   Структура - структура сущности
//
Функция СоздатьСтруктуруСущности(ТипОбъекта, ИмяОбъекта, МинимальныйОтступ)
    Сущность = Новый Структура();
    Сущность.Вставить("ТипОбъекта", ТипОбъекта);
    Сущность.Вставить("ИмяОбъекта", ИмяОбъекта);
    Сущность.Вставить("МинимальныйОтступ", МинимальныйОтступ);
    Сущность.Вставить("ЗначениеНаТойЖеСтроке", Ложь); // По умолчанию значения на той же строке нет
    Возврат Сущность;
КонецФункции

// Обрабатывает одну сущность из массива строк
//
// Параметры:
//   Строка - Строка - обрабатываемая строка
//   Строки - Массив - массив всех строк
//   Индекс - Число - индекс текущей строки
//   МассивСущностей - Массив - уже обработанные сущности
//
// Возвращаемое значение:
//   Структура - результат обработки сущности с полями: Сущность, НовыйИндекс
//

// Обрабатывает объект с двоеточием
//
// Параметры:
//   Строка - Строка - исходная строка
//   ПозицияДвоеточия - Число - позиция двоеточия
//   ТекущийОтступ - Число - текущий отступ
//
// Возвращаемое значение:
//   Структура - сущность и модифицированная строка
Функция ОбработатьОбъектСДвоеточием(Строка, ПозицияДвоеточия, ТекущийОтступ)
    ИмяОбъекта = СокрЛП(Лев(Строка, ПозицияДвоеточия - 1));
    Сущность = СоздатьСтруктуруСущности("Объект", ИмяОбъекта, ТекущийОтступ + 1);
    Лог.Отладка("Найден объект: " + ИмяОбъекта);
    
    // Определяем, есть ли значение на той же строке
    ОстатокСтроки = СокрЛП(Сред(Строка, ПозицияДвоеточия + 1));
    ЗначениеНаТойЖеСтроке = ОпределитьЗначениеНаТойЖеСтроке(ОстатокСтроки);
    Сущность.ЗначениеНаТойЖеСтроке = ЗначениеНаТойЖеСтроке;
    
    МодифицированнаяСтрока = ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, ПозицияДвоеточия);
    
    ПроверитьОтсутствиеДублирующихСимволов(МодифицированнаяСтрока, Строка);
    
    Результат = Новый Структура("Сущность, МодифицированнаяСтрока", Сущность, МодифицированнаяСтрока);
    Возврат Результат;
КонецФункции

// Определяет, есть ли значение на той же строке после двоеточия
//
// Параметры:
//   ОстатокСтроки - Строка - строка после двоеточия
//
// Возвращаемое значение:
//   Булево - Истина, если значение на той же строке
//
Функция ОпределитьЗначениеНаТойЖеСтроке(ОстатокСтроки)
    Если ПустаяСтрока(ОстатокСтроки) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Если остаток строки не пустой, проверяем, что это не только тег
    Если НЕ СтрНачинаетсяС(ОстатокСтроки, "!") Тогда
        // Если не начинается с !, то это значение
        Возврат Истина;
    Иначе
        // Если начинается с !, проверяем, есть ли что-то после тега
        Возврат ПроверитьЗначениеПослеТега(ОстатокСтроки);
    КонецЕсли;
КонецФункции

// Проверяет, есть ли значение после тега в строке
//
// Параметры:
//   ОстатокСтроки - Строка - строка с тегом
//
// Возвращаемое значение:
//   Булево - Истина, если есть значение после тега
//
Функция ПроверитьЗначениеПослеТега(ОстатокСтроки)
    ПозицияПробела = СтрНайти(ОстатокСтроки, " ");
    ПозицияТаба = СтрНайти(ОстатокСтроки, Символы.Таб);
    
    Если ПозицияПробела = 0 И ПозицияТаба = 0 Тогда
        Возврат Ложь;
    КонецЕсли;
    
    НачалоЗначения = ОпределитьНачалоЗначения(ПозицияПробела, ПозицияТаба);
    ЗначениеПослеТега = СокрЛП(Сред(ОстатокСтроки, НачалоЗначения + 1));
    
    Возврат НЕ ПустаяСтрока(ЗначениеПослеТега) И НЕ СтрНачинаетсяС(ЗначениеПослеТега, "#");
КонецФункции

// Определяет начало значения после тега
//
// Параметры:
//   ПозицияПробела - Число - позиция пробела
//   ПозицияТаба - Число - позиция табуляции
//
// Возвращаемое значение:
//   Число - позиция начала значения
//
Функция ОпределитьНачалоЗначения(ПозицияПробела, ПозицияТаба)
    Если ПозицияПробела > 0 И ПозицияТаба > 0 Тогда
        Возврат Мин(ПозицияПробела, ПозицияТаба);
    ИначеЕсли ПозицияПробела > 0 Тогда
        Возврат ПозицияПробела;
    Иначе
        Возврат ПозицияТаба;
    КонецЕсли;
КонецФункции

// Проверяет отсутствие дублирующих управляющих символов
//
// Параметры:
//   МодифицированнаяСтрока - Строка - модифицированная строка
//   ОригинальнаяСтрока - Строка - оригинальная строка для вывода ошибки
//
Процедура ПроверитьОтсутствиеДублирующихСимволов(МодифицированнаяСтрока, ОригинальнаяСтрока)
    СледующийУправляющийСимвол = НайтиУправляющийСимволИЕгоПозицию(МодифицированнаяСтрока);
    
    Если СледующийУправляющийСимвол.Позиция > 0 
            И (СледующийУправляющийСимвол.Символ = ":" 
            Или СледующийУправляющийСимвол.Символ = "-") Тогда
        Лог.Ошибка("Найдено несколько управляющих символов в строке: " + ОригинальнаяСтрока);
        ВызватьИсключение "Найдено несколько управляющих символов в строке: " + ОригинальнаяСтрока;
    КонецЕсли;
КонецПроцедуры

// Обрабатывает объект с явным ключом (символ ?)
//
// Параметры:
//   Строка - Строка - исходная строка
//   ПозицияВопроса - Число - позиция знака вопроса
//   ТекущийОтступ - Число - текущий отступ
//
// Возвращаемое значение:
//   Структура - сущность и модифицированная строка
Функция ОбработатьОбъектСЯвнымКлючом(Строка, ПозицияВопроса, ТекущийОтступ)
    // Для явного ключа имя всегда пустое - ключ будет собран из содержимого
    ИмяОбъекта = "";
    Сущность = СоздатьСтруктуруСущности("ОбъектЯвныйКлюч", ИмяОбъекта, ТекущийОтступ + 1);
    Лог.Отладка("Найден объект с явным ключом: " + ИмяОбъекта);
    
    МодифицированнаяСтрока = ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, ПозицияВопроса);
    
    Результат = Новый Структура("Сущность, МодифицированнаяСтрока", Сущность, МодифицированнаяСтрока);
    Возврат Результат;
КонецФункции

// Обрабатывает элемент массива (символ -)
//
// Параметры:
//   Строка - Строка - исходная строка
//   ПозицияТире - Число - позиция тире
//   ТекущийОтступ - Число - текущий отступ
//
// Возвращаемое значение:
//   Структура - сущность и модифицированная строка
Функция ОбработатьЭлементМассива(Строка, ПозицияТире, ТекущийОтступ)
    Сущность = СоздатьСтруктуруСущности("ЭлементМассива", "ЭлементМассива", ТекущийОтступ + 1);
    Лог.Отладка("Найден элемент массива");
    
    МодифицированнаяСтрока = ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, ПозицияТире);
    
    Результат = Новый Структура("Сущность, МодифицированнаяСтрока", Сущность, МодифицированнаяСтрока);
    Возврат Результат;
КонецФункции

// Обрабатывает якорь (символ &)
//
// Параметры:
//   Строка - Строка - исходная строка
//   ПозицияЯкоря - Число - позиция символа &
//   ТекущийОтступ - Число - текущий отступ
//
// Возвращаемое значение:
//   Структура - сущность и модифицированная строка
Функция ОбработатьЯкорь(Строка, ПозицияЯкоря, ТекущийОтступ)
    // Ищем следующий управляющий символ после якоря
    ОстатокСтроки = Сред(Строка, ПозицияЯкоря + 1);
    СледующийСимвол = НайтиУправляющийСимволИЕгоПозицию(ОстатокСтроки);
    
    Если СледующийСимвол.Символ = ":" Тогда
        // Якорь с объектом: &anchor key: value
        ПозицияДвоеточия = ПозицияЯкоря + СледующийСимвол.Позиция;
        ПолнаяСтрокаДоДвоеточия = СокрЛП(Лев(Строка, ПозицияДвоеточия - 1));
        // Убираем якорь из имени - ищем пробел после якоря
        ПозицияПробела = Найти(ПолнаяСтрокаДоДвоеточия, " ");
        Если ПозицияПробела > 0 Тогда
            ИмяОбъекта = СокрЛП(Сред(ПолнаяСтрокаДоДвоеточия, ПозицияПробела + 1));
        Иначе
            ИмяОбъекта = ПолнаяСтрокаДоДвоеточия;
        КонецЕсли;
        
        // Проверяем на недопустимое сочетание якоря и алиаса в ключе
        Если Найти(ИмяОбъекта, "*") > 0 Тогда
            ВызватьИсключение("YAML Error: Недопустимо использование алиаса (*) в ключе, который уже содержит якорь (&)");
        КонецЕсли;
        
        Сущность = СоздатьСтруктуруСущности("Объект", ИмяОбъекта, ТекущийОтступ + 1);
        Лог.Отладка("Найден объект с якорем: " + ИмяОбъекта);
        МодифицированнаяСтрока = ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, ПозицияДвоеточия);
    Иначе
        // Обычный якорь
        Сущность = СоздатьСтруктуруСущности("Якорь", "", ТекущийОтступ + 1);
        Лог.Отладка("Найден якорь");
        МодифицированнаяСтрока = ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, ПозицияЯкоря);
    КонецЕсли;
    
    Результат = Новый Структура("Сущность, МодифицированнаяСтрока", Сущность, МодифицированнаяСтрока);
    Возврат Результат;
КонецФункции

// Обрабатывает алиас (символ *)
//
// Параметры:
//   Строка - Строка - исходная строка
//   ПозицияАлиаса - Число - позиция символа *
//   ТекущийОтступ - Число - текущий отступ
//
// Возвращаемое значение:
//   Структура - сущность и модифицированная строка
Функция ОбработатьАлиас(Строка, ПозицияАлиаса, ТекущийОтступ)
    Сущность = СоздатьСтруктуруСущности("Алиас", "", ТекущийОтступ + 1);
    Лог.Отладка("Найден алиас");
    
    МодифицированнаяСтрока = ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, ПозицияАлиаса);
    
    Результат = Новый Структура("Сущность, МодифицированнаяСтрока", Сущность, МодифицированнаяСтрока);
    Возврат Результат;
КонецФункции

Функция ОбработатьОднуСущность(Строка, Строки, Индекс, МассивСущностей)
    ТекущийОтступ = ОпределитьОтступ(Строка);
    ДанныеУправляющегоСимвола = НайтиУправляющийСимволИЕгоПозицию(Строка);
    
    РезультатОбработки = Неопределено;
    
    Если ДанныеУправляющегоСимвола.Символ = ":" Тогда // Это объект
        РезультатОбработки = ОбработатьОбъектСДвоеточием(Строка, ДанныеУправляющегоСимвола.Позиция, ТекущийОтступ);
    ИначеЕсли ДанныеУправляющегоСимвола.Символ = "?" Тогда // Это объект с явным ключом
        РезультатОбработки = ОбработатьОбъектСЯвнымКлючом(Строка, ДанныеУправляющегоСимвола.Позиция, ТекущийОтступ);
    ИначеЕсли ДанныеУправляющегоСимвола.Символ = "-" Тогда // Это элемент массива
        РезультатОбработки = ОбработатьЭлементМассива(Строка, ДанныеУправляющегоСимвола.Позиция, ТекущийОтступ);
    ИначеЕсли ДанныеУправляющегоСимвола.Символ = "&" Тогда // Это якорь
        РезультатОбработки = ОбработатьЯкорь(Строка, ДанныеУправляющегоСимвола.Позиция, ТекущийОтступ);
    ИначеЕсли ДанныеУправляющегоСимвола.Символ = "*" Тогда // Это алиас
        РезультатОбработки = ОбработатьАлиас(Строка, ДанныеУправляющегоСимвола.Позиция, ТекущийОтступ);
    Иначе
        Лог.Ошибка("Не удалось выделить управляющий символ в строке: " + Строка);
        ВызватьИсключение "Не удалось выделить управляющий символ в строке: " + Строка;
    КонецЕсли;
    
    Сущность = РезультатОбработки.Сущность;
    МодифицированнаяСтрока = РезультатОбработки.МодифицированнаяСтрока;
    
    ПроверитьВалидностьСущности(Сущность, МассивСущностей);

    Строки[Индекс] = МодифицированнаяСтрока; // Обновим строку с отступом
    
    // Для явных ключей используем особую логику выделения содержимого
    Если Сущность.ТипОбъекта = "ОбъектЯвныйКлюч" Тогда
        СтрокиСодержимого = ВыделитьСодержимоеЯвногоКлюча(Строки, Индекс, ТекущийОтступ);
    Иначе
        СтрокиСодержимого = ВыделитьСодержимое(Строки, Индекс, ТекущийОтступ, Сущность);
    КонецЕсли;
    
    Сущность.Вставить("Содержимое", СтрокиСодержимого);
    НовыйИндекс = Индекс + СтрокиСодержимого.Количество() - 1;

    Результат = СоздатьРезультатОбработкиСущности(Сущность, НовыйИндекс);
    Возврат Результат;
КонецФункции

// Получение массива объектов из строк
//
// Параметры:
//   Строки - Массив - массив строк для анализа
//
// Возвращаемое значение:
//   Массив - массив структур с описанием объектов
//
Функция ПолучитьМассивСущностей(Строки)
    Лог.Отладка("Начало извлечения сущностей из " + Строки.Количество() + " строк");
    
    МассивСущностей = Новый Массив();
    
    Для Индекс = 0 По Строки.Количество() - 1 Цикл
        Строка = Строки[Индекс];

        // Пропускаем пустые строки и комментарии
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
            Продолжить;
        КонецЕсли;
        
        РезультатОбработки = ОбработатьОднуСущность(Строка, Строки, Индекс, МассивСущностей);
        МассивСущностей.Добавить(РезультатОбработки.Сущность);
        Индекс = РезультатОбработки.НовыйИндекс;
    КонецЦикла;
    
    Лог.Отладка("Извлечение сущностей завершено, найдено " + МассивСущностей.Количество() + " сущностей");
    Возврат МассивСущностей;
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ МЕТОДЫ ДЛЯ ОБРАБОТКИ СТРОК И ОТСТУПОВ
////////////////////////////////////////////////////////////////////////////////

Функция ЗаменитьВСтрокеПрефиксОпределенияНаПробелы(Строка, Позиция)
    
    Отступ = "";
    Пока СтрДлина(Отступ) < Позиция Цикл
        Отступ = Отступ + " ";
    КонецЦикла;
    ПолучившаясяСтрока = Отступ + Сред(Строка, Позиция + 1);
    Возврат ПолучившаясяСтрока;
КонецФункции

Процедура ПроверитьВалидностьСущности(Сущность, МассивСущностей)
    
    Если МассивСущностей.Количество() = 0 Тогда
        Возврат; // Если массив пустой, то валидность не проверяем
    КонецЕсли;
    ПервыйОбъект = МассивСущностей[0];
    
    Если НЕ Сущность.МинимальныйОтступ = ПервыйОбъект.МинимальныйОтступ Тогда
        ТекстОшибки = СтрШаблон(
                "Отступ <%1> отличается от требуемого <%2>. Все сущности должны иметь одинаковый отступ.",
                Сущность.МинимальныйОтступ - 1, ПервыйОбъект.МинимальныйОтступ - 1);
        Лог.Ошибка(ТекстОшибки);
        ВызватьИсключение ТекстОшибки;
    КонецЕсли;
    
    Если НЕ (Сущность.ТипОбъекта = ПервыйОбъект.ТипОбъекта 
            ИЛИ (ЭтоТипОбъекта(Сущность.ТипОбъекта) И ЭтоТипОбъекта(ПервыйОбъект.ТипОбъекта))) Тогда
        ТекстОшибки = СтрШаблон(
                "Тип сущности <%1> отличается от требуемого <%2>. Все сущности должны иметь одинаковый тип.",
                Сущность.ТипОбъекта, ПервыйОбъект.ТипОбъекта);
        Лог.Ошибка(ТекстОшибки);
        ВызватьИсключение ТекстОшибки;
    КонецЕсли;

КонецПроцедуры

// Проверяет, является ли тип объектным типом (обычный объект или объект с явным ключом)
//
// Параметры:
//   ТипОбъекта - Строка - тип объекта для проверки
//
// Возвращаемое значение:
//   Булево - Истина, если это объектный тип
//
Функция ЭтоТипОбъекта(ТипОбъекта)
    Возврат ТипОбъекта = "Объект" ИЛИ ТипОбъекта = "ОбъектЯвныйКлюч";
КонецФункции

// Функция для выделения содержимого из строк
//
// Параметры:
//   Строки - Массив - массив строк для анализа
//   Индекс - Число - индекс строки для анализа
//   ТекущийОтступ - Число - минимальный отступ для выделения содержимого
//   Сущность - Структура - информация о сущности (может быть Неопределено)
//
// Возвращаемое значение:
//   Массив - массив строк, содержащих выделенное содержимое
//
Функция ВыделитьСодержимое(Строки, Индекс, ТекущийОтступ, Сущность = Неопределено)
    
    Содержимое = Новый Массив();
    Для НомерСтроки = Индекс По Строки.Количество() - 1 Цикл
        Строка = Строки[НомерСтроки];
        
        // Определяем условие для включения строки в содержимое
        УсловиеВключения = Ложь;
        
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
            УсловиеВключения = Истина;
        ИначеЕсли ОпределитьОтступ(Строка) > ТекущийОтступ Тогда
            УсловиеВключения = Истина;
        ИначеЕсли Сущность <> Неопределено И Сущность.Свойство("ЗначениеНаТойЖеСтроке") 
                И НЕ Сущность.ЗначениеНаТойЖеСтроке И ОпределитьОтступ(Строка) = ТекущийОтступ Тогда
            // Если объект не имеет значения на той же строке, то содержимое может иметь тот же отступ
            // но только если это логически связанные элементы (например, элементы массива)
            // и это не новый объект верхнего уровня
            ДанныеСимвола = НайтиУправляющийСимволИЕгоПозицию(Строка);
            Если ДанныеСимвола.Символ = "-" И Сущность.ТипОбъекта = "Объект" Тогда
                // Только объекты (не элементы массива) могут включать элементы массива с тем же отступом
                УсловиеВключения = Истина;
            КонецЕсли;
        Иначе
            УсловиеВключения = Ложь;
        КонецЕсли;
        
        Если УсловиеВключения Тогда
            Содержимое.Добавить(Строка);
        Иначе
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Содержимое;
КонецФункции

// Функция для выделения содержимого явного ключа (включает строку с : на том же уровне)
//
// Параметры:
//   Строки - Массив - массив строк для анализа
//   Индекс - Число - индекс строки для анализа
//   ТекущийОтступ - Число - минимальный отступ для выделения содержимого
//
// Возвращаемое значение:
//   Массив - массив строк, содержащих выделенное содержимое
//

// Проверяет является ли строка двоеточием с валидацией
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка без отступов
//   ОтступСтроки - Число - отступ строки
//   ТекущийОтступ - Число - ожидаемый отступ
//
// Возвращаемое значение:
//   Булево - Истина, если строка начинается с двоеточия
Функция ЭтоДвоеточиеЯвногоКлюча(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ)
    Если НЕ СтрНачинаетсяС(СтрокаБезОтступов, ":") ИЛИ ОтступСтроки <> ТекущийОтступ Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем на табы после двоеточия - это запрещено YAML спецификацией
    ПроверитьОтсутствиеТабуляцииПослеДвоеточия(СтрокаБезОтступов);
    
    Возврат Истина;
КонецФункции

// Проверяет является ли строка новым явным ключом
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка без отступов
//   ОтступСтроки - Число - отступ строки  
//   ТекущийОтступ - Число - ожидаемый отступ
//   НомерСтроки - Число - номер текущей строки
//   Индекс - Число - начальный индекс
//   НайденоДвоеточие - Булево - найдено ли двоеточие
//
// Возвращаемое значение:
//   Булево - Истина, если строка является новым явным ключом
Функция ЭтоНовыйЯвныйКлюч(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ, НомерСтроки, Индекс, НайденоДвоеточие)
    Если НЕ СтрНачинаетсяС(СтрокаБезОтступов, "?") ИЛИ ОтступСтроки <> ТекущийОтступ Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Новый явный ключ, если двоеточие найдено или это не первая строка
    Возврат НайденоДвоеточие ИЛИ НомерСтроки > Индекс;
КонецФункции

// Проверяет является ли строка якорем на том же уровне
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка без отступов
//   ОтступСтроки - Число - отступ строки
//   ТекущийОтступ - Число - ожидаемый отступ
//
// Возвращаемое значение:
//   Булево - Истина, если строка является якорем на том же уровне
Функция ЭтоЯкорьНаТомЖеУровне(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ)
    Возврат СтрНачинаетсяС(СтрокаБезОтступов, "&") И ОтступСтроки = ТекущийОтступ;
КонецФункции

// Проверяет является ли строка обычным ключом на том же уровне
//
// Параметры:
//   СтрокаБезОтступов - Строка - строка без отступов
//   ОтступСтроки - Число - отступ строки
//   ТекущийОтступ - Число - ожидаемый отступ
//   НомерСтроки - Число - номер текущей строки
//   Индекс - Число - начальный индекс
//
// Возвращаемое значение:
//   Булево - Истина, если строка является обычным ключом на том же уровне
Функция ЭтоОбычныйКлючНаТомЖеУровне(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ, НомерСтроки, Индекс)
    Возврат ОтступСтроки = ТекущийОтступ 
        И НомерСтроки > Индекс 
        И Найти(СтрокаБезОтступов, ":") > 0 
        И НЕ СтрНачинаетсяС(СтрокаБезОтступов, ":");
КонецФункции

// Определяет действие для строки при выделении содержимого явного ключа
//
// Параметры:
//   Строка - Строка - исходная строка
//   НомерСтроки - Число - номер строки
//   Индекс - Число - начальный индекс
//   ТекущийОтступ - Число - текущий отступ
//   НайденоДвоеточие - Булево - найдено ли двоеточие (изменяется)
//
// Возвращаемое значение:
//   Строка - действие: "добавить", "двоеточие", "прервать", "пропустить"
Функция ОпределитьДействиеДляСтрокиЯвногоКлюча(Строка, НомерСтроки, Индекс, ТекущийОтступ, НайденоДвоеточие)
    ОтступСтроки = ОпределитьОтступ(Строка);
    
    Если ОтступСтроки < ТекущийОтступ И НЕ ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
        Лог.Отладка("Строка с меньшим отступом, завершаем блок");
        Возврат ДЕЙСТВИЕ_ПРЕРВАТЬ;
    КонецЕсли;
    
    СтрокаБезОтступов = СокрЛП(Строка);
    
    Если ЭтоДвоеточиеЯвногоКлюча(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ) Тогда
        Лог.Отладка("Найдено двоеточие, добавляем строку значения");
        НайденоДвоеточие = Истина;
        Возврат "двоеточие";
    КонецЕсли;
    
    Если ЭтоНовыйЯвныйКлюч(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ, НомерСтроки, Индекс, НайденоДвоеточие) Тогда
        Лог.Отладка("Найден следующий явный ключ, завершаем блок");
        Возврат ДЕЙСТВИЕ_ПРЕРВАТЬ;
    КонецЕсли;
    
    Если ЭтоЯкорьНаТомЖеУровне(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ) Тогда
        Лог.Отладка("Найден якорь на том же уровне, завершаем блок");
        Возврат ДЕЙСТВИЕ_ПРЕРВАТЬ;
    КонецЕсли;
    
    Если ЭтоОбычныйКлючНаТомЖеУровне(СтрокаБезОтступов, ОтступСтроки, ТекущийОтступ, НомерСтроки, Индекс) Тогда
        Лог.Отладка("Найден обычный ключ на том же уровне, завершаем блок");
        Возврат ДЕЙСТВИЕ_ПРЕРВАТЬ;
    КонецЕсли;
    
    Лог.Отладка("Добавляем строку в содержимое");
    Возврат "добавить";
КонецФункции

Функция ВыделитьСодержимоеЯвногоКлюча(Строки, Индекс, ТекущийОтступ)
    Содержимое = Новый Массив();
    НайденоДвоеточие = Ложь;
    
    Лог.Отладка("Выделение содержимого явного ключа начиная с индекса " + Индекс + ", отступ " + ТекущийОтступ);
    
    // Для явного ключа ищем строки до двоеточия (включая само двоеточие и значение после него)
    // Начинаем сразу с текущей строки, которая содержит "? ..."
    Для НомерСтроки = Индекс По Строки.Количество() - 1 Цикл
        Строка = Строки[НомерСтроки];
        Лог.Отладка("Анализ строки " + НомерСтроки + ": '" + Строка + "'");
        
        Действие = ОпределитьДействиеДляСтрокиЯвногоКлюча(Строка, НомерСтроки, Индекс, ТекущийОтступ, НайденоДвоеточие);
        
        Если Действие = "прервать" Тогда
            Прервать;
        ИначеЕсли Действие = "двоеточие" Тогда
            Содержимое.Добавить(Строка);
            НайденоДвоеточие = Истина;
        ИначеЕсли Действие = "добавить" Тогда
            Содержимое.Добавить(Строка);
        Иначе
            // Действие "пропустить" - ничего не делаем
            Продолжить;
        КонецЕсли;
    КонецЦикла;
    
    Лог.Отладка("Содержимое явного ключа выделено: " + Содержимое.Количество() + " строк");
    Возврат Содержимое;
КонецФункции

Функция ОпределитьОтступ(Строка)
    // Определяем отступ в строке (только пробелы в начале)
    // YAML спецификация: отступ может состоять только из пробелов
    Отступ = 0;
    Для а = 1 По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, а, 1);
        Если Символ = " " Тогда
            Отступ = Отступ + 1;
        Иначе
            // Встретили любой не-пробельный символ (включая таб) - отступ закончился
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Отступ;
КонецФункции

// Определяет минимальный отступ среди всех непустых строк содержимого
//
// Параметры:
//   МассивСтрок - Массив - массив всех строк
//   ИндексНачалаСодержимого - Число - индекс начала содержимого
//
// Возвращаемое значение:
//   Число - минимальный отступ содержимого
//
Функция ОпределитьМинимальныйОтступСодержимого(МассивСтрок, ИндексНачалаСодержимого)
    МинимальныйОтступ = Неопределено;
    
    Для Индекс = ИндексНачалаСодержимого По МассивСтрок.Количество() - 1 Цикл
        Строка = МассивСтрок[Индекс];
        
        // Пропускаем пустые строки и строки с одними пробелами при определении отступа
        СтрокаОбрезанная = СокрЛП(Строка);
        Если ПустаяСтрока(СтрокаОбрезанная) Тогда
            Продолжить;
        КонецЕсли;
        
        // Пропускаем строки с комментариями при определении отступа
        // Комментарий - это строка, которая после удаления пробелов слева начинается с #
        Если СтрНачинаетсяС(СтрокаОбрезанная, "#") Тогда
            Продолжить;
        КонецЕсли;
        
        ОтступСтроки = ОпределитьОтступ(Строка);
        
        Если МинимальныйОтступ = Неопределено ИЛИ ОтступСтроки < МинимальныйОтступ Тогда
            МинимальныйОтступ = ОтступСтроки;
        КонецЕсли;
    КонецЦикла;
    
    // Если не найдено ни одной строки с содержимым, возвращаем 0
    Если МинимальныйОтступ = Неопределено Тогда
        Возврат 0;
    КонецЕсли;
    
    Возврат МинимальныйОтступ;
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ПАРСЕРЫ МНОГОСТРОЧНЫХ СТРОК И СПЕЦИАЛЬНЫХ КОНСТРУКЦИЙ
////////////////////////////////////////////////////////////////////////////////

// Парсер многострочных строк
//
// Параметры:
//   МассивСтрок - Массив - массив строк для парсинга многострочной строки
//
// Возвращаемое значение:
//   Строка - результат парсинга многострочной строки
//
Функция ПарсерМногострочныхСтрок(МассивСтрок)
    
    // Определяем параметры многострочной строки
    ПараметрыМногострочнойСтроки = НайтиПараметрыМногострочнойСтроки(МассивСтрок);
    
    Если ПараметрыМногострочнойСтроки = Неопределено Тогда
        Возврат ""; // Не найден управляющий символ, возвращаем пустую строку
    КонецЕсли;
    
    // Извлекаем строки содержимого
    СтрокиСодержимого = ИзвлечьСодержимоеМногострочнойСтроки(МассивСтрок, ПараметрыМногострочнойСтроки);
    
    // Обрабатываем пустые строки в конце если необходимо
    СтрокиСодержимого = ОбработатьПустыеСтрокиВКонце(СтрокиСодержимого, ПараметрыМногострочнойСтроки);
    
    // Собираем финальную строку
    Возврат СобратьМногострочнуюСтроку(СтрокиСодержимого, ПараметрыМногострочнойСтроки);
    
КонецФункции

// Создает структуру параметров многострочной строки
//
// Параметры:
//   ТипСтроки - Строка - тип многострочной строки ("|" или ">")
//   УправляющийПодсимвол - Строка - подсимвол (+, -, или пустая строка)
//   ИндексНачалаСодержимого - Число - индекс строки начала содержимого
//   ОтступСодержимого - Число - отступ содержимого
//
// Возвращаемое значение:
//   Структура - структура параметров многострочной строки
//
Функция СоздатьПараметрыМногострочнойСтроки(ТипСтроки, УправляющийПодсимвол, ИндексНачалаСодержимого, ОтступСодержимого)
    Параметры = Новый Структура();
    Параметры.Вставить("ТипСтроки", ТипСтроки); // "|" или ">"
    
    // Разбираем chomping модификатор из подсимвола
    ChompingМодификатор = ИзвлечьChompingМодификатор(УправляющийПодсимвол);
    
    Параметры.Вставить("СохранятьПустыеСтрокиВКонце", ChompingМодификатор = "+");
    Параметры.Вставить("ДобавлятьПереносПоследнейСтроки", ChompingМодификатор <> "-");
    Параметры.Вставить("ИндексНачалаСодержимого", ИндексНачалаСодержимого);
    Параметры.Вставить("ОтступСодержимого", ОтступСодержимого);
    
    Возврат Параметры;
КонецФункции

// Извлекает chomping модификатор из строки управляющего подсимвола
//
// Параметры:
//   УправляющийПодсимвол - Строка - строка может содержать цифры и chomping символ (+, -)
//
// Возвращаемое значение:
//   Строка - chomping модификатор: "+", "-" или ""
//
Функция ИзвлечьChompingМодификатор(УправляющийПодсимвол)
    Если СтрНайти(УправляющийПодсимвол, "+") > 0 Тогда
        Возврат "+";
    ИначеЕсли СтрНайти(УправляющийПодсимвол, "-") > 0 Тогда
        Возврат "-";
    Иначе
        Возврат ""; // Clip chomping по умолчанию
    КонецЕсли;
КонецФункции

// Находит параметры многострочной строки по управляющим символам
//
// Параметры:
//   МассивСтрок - Массив - массив строк для анализа
//
// Возвращаемое значение:
//   Структура - параметры многострочной строки или Неопределено
//
Функция НайтиПараметрыМногострочнойСтроки(МассивСтрок)
    Лог.Отладка("Поиск параметров многострочной строки");
    
    Для Индекс = 0 По МассивСтрок.Количество() - 1 Цикл
        Строка = МассивСтрок[Индекс];
        
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) тогда
            Продолжить; // Пропускаем пустые строки и комментарии
        КонецЕсли;
        
        Строка = УбратьКомментарийИзСтроки(Строка);
        ДанныеУправляющегоСимвола = НайтиУправляющийСимволИЕгоПозицию(Строка);
        
        Если НЕ (ДанныеУправляющегоСимвола.Символ = "|" ИЛИ ДанныеУправляющегоСимвола.Символ = ">") тогда
            Лог.Ошибка("Ожидался управляющий символ многострочной строки, но найдено: " + Строка);
            ВызватьИсключение "Ожидался управляющий символ многострочной строки, но найдено: " + Строка;
        КонецЕсли;
        
        УправляющийПодсимвол = ПолучитьУправляющийПодсимвол(Строка, ДанныеУправляющегоСимвола.Позиция + 1);
        Лог.Отладка("Найден управляющий символ: %1 с подсимволом: %2",
                    ДанныеУправляющегоСимвола.Символ,
                    УправляющийПодсимвол);
        
        // Проверяем, что после управляющей последовательности нет недопустимого содержимого
        // Допускается наличие тегов (начинающихся с !) или якорей (начинающихся с &) перед управляющим символом
        ПозицияУправляющейПоследовательности = ДанныеУправляющегоСимвола.Позиция;
        ДлинаУправляющейПоследовательности = СтрДлина(ДанныеУправляющегоСимвола.Символ + УправляющийПодсимвол);
        
        // Извлекаем часть строки после управляющей последовательности
        ЧастьПослеУправляющейПоследовательности = Сред(Строка, ПозицияУправляющейПоследовательности + ДлинаУправляющейПоследовательности);
        ЧастьПослеУправляющейПоследовательности = СокрЛП(ЧастьПослеУправляющейПоследовательности);
        
        // После управляющей последовательности может быть только пустая строка или комментарий
        Если НЕ ПустаяСтрока(ЧастьПослеУправляющейПоследовательности) 
                И НЕ СтрНачинаетсяС(ЧастьПослеУправляющейПоследовательности, "#") Тогда
            Лог.Ошибка("В многострочной строке не должно быть ничего после управляющей последовательности, найдено: %1"
                            , ЧастьПослеУправляющейПоследовательности);
            ВызватьИсключение "В многострочной строке не должно быть ничего после управляющей последовательности";
        КонецЕсли;

        // Определяем отступ для содержимого - минимальный среди всех непустых строк содержимого
        ОтступСодержимого = ОпределитьМинимальныйОтступСодержимого(МассивСтрок, Индекс + 1);
        
        Параметры = СоздатьПараметрыМногострочнойСтроки(
            ДанныеУправляющегоСимвола.Символ, 
            УправляющийПодсимвол, 
            Индекс + 1, 
            ОтступСодержимого
        );
        
        Лог.Отладка("Параметры многострочной строки найдены");
        Возврат Параметры;
    КонецЦикла;
    
    Лог.Предупреждение("Управляющий символ многострочной строки не найден");
    Возврат Неопределено; // Управляющий символ не найден
    
КонецФункции

// Извлекает строки содержимого многострочной строки
//
// Параметры:
//   МассивСтрок - Массив - исходный массив строк
//   Параметры - Структура - параметры многострочной строки
//
// Возвращаемое значение:
//   Массив - массив строк содержимого
//
Функция ИзвлечьСодержимоеМногострочнойСтроки(МассивСтрок, Параметры)
    Лог.Отладка("Извлечение содержимого многострочной строки");
    
    СтрокиСодержимого = Новый Массив();
    
    Для Индекс = Параметры.ИндексНачалаСодержимого По МассивСтрок.Количество() - 1 Цикл
        ИсходнаяСтрока = МассивСтрок[Индекс];
        
        ПроверитьОтступСтроки(ИсходнаяСтрока, Параметры.ОтступСодержимого);
        
        СтрокаБезОтступа = УбратьБазовыйОтступИзСтроки(ИсходнаяСтрока, Параметры.ОтступСодержимого);
        
        Если ДолженПропуститьКомментарий(СтрокаБезОтступа, ИсходнаяСтрока, Параметры.ОтступСодержимого) Тогда
            Продолжить;
        КонецЕсли;
        
        СтрокиСодержимого.Добавить(СтрокаБезОтступа);
    КонецЦикла;
    
    Лог.Отладка("Извлечено " + СтрокиСодержимого.Количество() + " строк содержимого");
    Возврат СтрокиСодержимого;
КонецФункции

// Проверяет корректность отступа строки
//
// Параметры:
//   Строка - Строка - проверяемая строка
//   БазовыйОтступ - Число - требуемый базовый отступ
//
Процедура ПроверитьОтступСтроки(Строка, БазовыйОтступ)
    Если ОпределитьОтступ(Строка) < БазовыйОтступ 
        И Не ЭтоПустаяСтрокаИлиКомментарий(Строка) Тогда
         Лог.Ошибка("Отступ строки меньше требуемого");
         ВызватьИсключение "Отступ строки меньше требуемого";
    КонецЕсли;
КонецПроцедуры

// Убирает базовый отступ из строки
//
// Параметры:
//   Строка - Строка - исходная строка
//   БазовыйОтступ - Число - базовый отступ для удаления
//
// Возвращаемое значение:
//   Строка - строка без базового отступа
//
Функция УбратьБазовыйОтступИзСтроки(Строка, БазовыйОтступ)
    ОтступТекущейСтроки = ОпределитьОтступ(Строка);
    
    Если ОтступТекущейСтроки >= БазовыйОтступ Тогда
        Возврат Сред(Строка, БазовыйОтступ + 1);
    КонецЕсли;
    
    // Если отступ меньше базового и это пустая строка, делаем ее пустой
    Если ЭтоПустаяСтрокаПослеОбрезки(Строка) Тогда
        Возврат "";
    КонецЕсли;
    
    // Если отступ меньше базового, но строка не пустая - оставляем как есть
    Возврат Строка;
КонецФункции

// Проверяет должен ли комментарий быть пропущен
//
// Параметры:
//   СтрокаБезОтступа - Строка - строка без отступа
//   ИсходнаяСтрока - Строка - исходная строка
//   БазовыйОтступ - Число - базовый отступ содержимого
//
// Возвращаемое значение:
//   Булево - Истина если комментарий должен быть пропущен
//
Функция ДолженПропуститьКомментарий(СтрокаБезОтступа, ИсходнаяСтрока, БазовыйОтступ)
    СтрокаБезОтступаОбрезанная = СокрЛП(СтрокаБезОтступа);
    
    Если НЕ СтрНачинаетсяС(СтрокаБезОтступаОбрезанная, "#") Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем отступ комментария
    ОтступСтрокиКомментария = ОпределитьОтступ(ИсходнаяСтрока);
    Возврат ОтступСтрокиКомментария < БазовыйОтступ;
КонецФункции

// Обрабатывает пустые строки в конце массива строк
//
// Параметры:
//   СтрокиСодержимого - Массив - строки содержимого
//   Параметры - Структура - параметры многострочной строки
//
// Возвращаемое значение:
//   Массив - обработанный массив строк
//
Функция ОбработатьПустыеСтрокиВКонце(СтрокиСодержимого, Параметры)
    
    Если Параметры.СохранятьПустыеСтрокиВКонце Тогда
        Возврат СтрокиСодержимого; // Сохраняем все строки как есть
    КонецЕсли;
    
    // Для literal blocks (|) сохраняем строки с пробелами, удаляем только полностью пустые
    // Для folded blocks (>) можем удалять строки с пробелами
    Если Параметры.ТипСтроки = "|" Тогда
        // Для literal blocks удаляем только полностью пустые строки (без пробелов)
        Пока СтрокиСодержимого.Количество() > 0 
            И СтрокиСодержимого[СтрокиСодержимого.Количество() - 1] = "" Цикл
            СтрокиСодержимого.Удалить(СтрокиСодержимого.Количество() - 1);
        КонецЦикла;
    Иначе
        // Для folded blocks удаляем пустые строки и строки из пробелов
        Пока СтрокиСодержимого.Количество() > 0 
            И СтрЗаменить(СтрокиСодержимого[СтрокиСодержимого.Количество() - 1], " ", "") = "" Цикл
            СтрокиСодержимого.Удалить(СтрокиСодержимого.Количество() - 1);
        КонецЦикла;
    КонецЕсли;
    
    Возврат СтрокиСодержимого;
    
КонецФункции

// Собирает финальную многострочную строку
//
// Параметры:
//   СтрокиСодержимого - Массив - строки содержимого
//   Параметры - Структура - параметры многострочной строки
//
// Возвращаемое значение:
//   Строка - собранная многострочная строка
//
Функция СобратьМногострочнуюСтроку(СтрокиСодержимого, Параметры)
    
    Если СтрокиСодержимого.Количество() = 0 Тогда
        Возврат "";
    КонецЕсли;
    
    // Соединяем строки разделителем
    
    
    // Заменяем двойные пробелы на переносы строк для блочного стиля
    Если Параметры.ТипСтроки = ">" Тогда
        РезультирующаяСтрока = СобратьСтрокуИзМассива(СтрокиСодержимого);
    Иначе
        РезультирующаяСтрока = СтрСоединить(СтрокиСодержимого, Символы.ПС);
    КонецЕсли;
    
    // Применяем chomping правила
    Если НЕ Параметры.ДобавлятьПереносПоследнейСтроки Тогда
        // Strip chomping (-): удаляем ВСЕ завершающие переносы строк
        Пока СтрЗаканчиваетсяНа(РезультирующаяСтрока, Символы.ПС) Цикл
            РезультирующаяСтрока = Лев(РезультирующаяСтрока, СтрДлина(РезультирующаяСтрока) - 1);
        КонецЦикла;
    ИначеЕсли НЕ Параметры.СохранятьПустыеСтрокиВКонце Тогда
        // Clip chomping (обычный): добавляем ровно один перенос строки
        Пока СтрЗаканчиваетсяНа(РезультирующаяСтрока, Символы.ПС) Цикл
            РезультирующаяСтрока = Лев(РезультирующаяСтрока, СтрДлина(РезультирующаяСтрока) - 1);
        КонецЦикла;
        РезультирующаяСтрока = РезультирующаяСтрока + Символы.ПС;
    Иначе
        // Keep chomping (+): оставляем все как есть при Параметры.СохранятьПустыеСтрокиВКонце = Истина
        // Никаких действий не требуется - строка остается как есть
        Лог.Отладка("Применяется keep chomping - строка остается без изменений");
    КонецЕсли;
    
    Возврат РезультирующаяСтрока;
    
КонецФункции

Функция ПолучитьУправляющийПодсимвол(Строка, Позиция)
    Если СтрДлина(Строка) < Позиция Тогда
        Возврат ""; // Нет подсимвола, возвращаем пустую строку
    КонецЕсли;
    Возврат СокрЛП(Сред(Строка, Позиция, МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ));
КонецФункции

Функция СобратьСтрокуИзМассива(МассивСтрок)
    Результат = "";
    СтрокаБезРазделителя = Истина;
    Для Каждого Строка Из МассивСтрок Цикл
        Если ЭтоПустаяСтрокаПослеОбрезки(Строка) Тогда
            Результат = Результат + Символы.ПС;
            СтрокаБезРазделителя = Истина;
        Иначе
            // Проверяем на недопустимые конструкции в plain scalar
            ОчищеннаяСтрока = СокрЛП(Строка);
            Если СтрНайти(ОчищеннаяСтрока, ": ") > 0 ИЛИ СтрЗаканчиваетсяНа(ОчищеннаяСтрока, ":") Тогда
                ВызватьИсключение "Недопустимое отображение в plain scalar: '" + ОчищеннаяСтрока + "'";
            КонецЕсли;
            
            Результат = Результат + ?(СтрокаБезРазделителя,"", " ")+ Строка;
            СтрокаБезРазделителя = Ложь; 
        КонецЕсли;        
    КонецЦикла;
    Возврат СокрЛП(Результат);
    
КонецФункции

// Собирает double-quoted строку с правильной обработкой escape-последовательностей
//
// Параметры:
//   МассивСтрок - Массив - массив строк для объединения
//
// Возвращаемое значение:
//   Строка - объединенная строка с правильно обработанными escape-последовательностями
Функция СобратьDoubleQuotedСтрокуИзМассива(МассивСтрок)
    Результат = "";
    БылЭкранированныйПеренос = Ложь;
    БылПереносСтроки = Ложь;
    
    Для Индекс = 0 По МассивСтрок.ВГраница() Цикл
        Строка = МассивСтрок[Индекс];
        
        Если ЭтоПустаяСтрокаПослеОбрезки(Строка) Тогда
            Результат = ОбработатьПустуюСтроку(Результат, БылЭкранированныйПеренос);
            БылЭкранированныйПеренос = Ложь;
            БылПереносСтроки = Истина;
            Продолжить;
        КонецЕсли;
        
        Если ЭтоЭкранированныйПеренос(Строка) Тогда
            Результат = ОбработатьЭкранированныйПеренос(Результат, Строка, Индекс, БылЭкранированныйПеренос, БылПереносСтроки);
            БылЭкранированныйПеренос = Истина;
            БылПереносСтроки = Ложь;
        Иначе
            Результат = ОбработатьОбычнуюСтрокуВКавычках(Результат, Строка, Индекс, БылЭкранированныйПеренос, БылПереносСтроки);
            БылЭкранированныйПеренос = Ложь;
            БылПереносСтроки = Ложь;
        КонецЕсли;
    КонецЦикла;
    
    Возврат СокрЛП(Результат);
КонецФункции

// Обрабатывает пустую строку в double quoted блоке
//
// Параметры:
//   Результат - Строка - накопленный результат
//   БылЭкранированныйПеренос - Булево - был ли экранированный перенос
//
// Возвращаемое значение:
//   Строка - обновленный результат
//
Функция ОбработатьПустуюСтроку(Результат, БылЭкранированныйПеренос)
    Если НЕ БылЭкранированныйПеренос Тогда
        Возврат Результат + Символы.ПС;
    КонецЕсли;
    Возврат Результат;
КонецФункции

// Проверяет является ли строка экранированным переносом
//
// Параметры:
//   Строка - Строка - строка для проверки
//
// Возвращаемое значение:
//   Булево - Истина если строка заканчивается экранированным переносом
//
Функция ЭтоЭкранированныйПеренос(Строка)
    Возврат СтрЗаканчиваетсяНа(Строка, "\") И НЕ СтрЗаканчиваетсяНа(Строка, "\\");
КонецФункции

// Обрабатывает экранированный перенос строки
//
// Параметры:
//   Результат - Строка - накопленный результат
//   Строка - Строка - текущая строка
//   Индекс - Число - индекс текущей строки
//   БылЭкранированныйПеренос - Булево - был ли экранированный перенос
//   БылПереносСтроки - Булево - был ли перенос строки
//
// Возвращаемое значение:
//   Строка - обновленный результат
//
Функция ОбработатьЭкранированныйПеренос(Результат, Строка, Индекс, БылЭкранированныйПеренос, БылПереносСтроки)
    // Убираем \ в конце
    СтрокаБезBackslash = Лев(Строка, СтрДлина(Строка) - 1);
    
    // Если это не первая строка и не было экранированного переноса и не было переноса строки, добавляем пробел
    Если ТребуетсяПробел(Индекс, БылЭкранированныйПеренос, БылПереносСтроки) Тогда
        Результат = Результат + " ";
    КонецЕсли;
    
    Возврат Результат + СтрокаБезBackslash;
КонецФункции

// Обрабатывает обычную строку в double quoted блоке
//
// Параметры:
//   Результат - Строка - накопленный результат
//   Строка - Строка - текущая строка
//   Индекс - Число - индекс текущей строки
//   БылЭкранированныйПеренос - Булево - был ли экранированный перенос
//   БылПереносСтроки - Булево - был ли перенос строки
//
// Возвращаемое значение:
//   Строка - обновленный результат
//
Функция ОбработатьОбычнуюСтрокуВКавычках(Результат, Строка, Индекс, БылЭкранированныйПеренос, БылПереносСтроки)
    // Если это не первая строка и не было экранированного переноса и не было переноса строки, добавляем пробел
    Если ТребуетсяПробел(Индекс, БылЭкранированныйПеренос, БылПереносСтроки) Тогда
        Результат = Результат + " ";
    КонецЕсли;
    
    Возврат Результат + Строка;
КонецФункции

// Проверяет требуется ли добавить пробел между строками
//
// Параметры:
//   Индекс - Число - индекс текущей строки
//   БылЭкранированныйПеренос - Булево - был ли экранированный перенос
//   БылПереносСтроки - Булево - был ли перенос строки
//
// Возвращаемое значение:
//   Булево - Истина если требуется пробел
//
Функция ТребуетсяПробел(Индекс, БылЭкранированныйПеренос, БылПереносСтроки)
    Возврат Индекс > 0 И НЕ БылЭкранированныйПеренос И НЕ БылПереносСтроки;
КонецФункции

// Создает структуру параметров якоря с отступом
//
// Параметры:
//   УровеньОтступа - Число - уровень отступа якоря
//
// Возвращаемое значение:
//   Структура - структура параметров якоря
//
Функция СоздатьПараметрыЯкоряСОтступом(УровеньОтступа)
    Параметры = Новый Структура();
    Параметры.Вставить("ИмяЯкоря", "");
    Параметры.Вставить("ИндексСтрокиСЯкорем", 0);
    Параметры.Вставить("УровеньОтступа", УровеньОтступа);
    
    Возврат Параметры;
КонецФункции

// Находит параметры якоря по управляющему символу &
//
// Параметры:
//   МассивСтрок - Массив - массив строк для анализа
//
// Возвращаемое значение:
//   Структура - параметры якоря или Неопределено
//
Функция НайтиПараметрыЯкоря(МассивСтрок)
    Лог.Отладка("Поиск параметров якоря");
    
    Для Индекс = 0 По МассивСтрок.Количество() - 1 Цикл
        Строка = МассивСтрок[Индекс];
        
        Если ЭтоПустаяСтрокаИлиКомментарий(Строка) тогда
            Продолжить; // Пропускаем пустые строки и комментарии
        КонецЕсли;
        
        ДанныеУправляющегоСимвола = НайтиУправляющийСимволИЕгоПозицию(Строка);
        
        Если НЕ ДанныеУправляющегоСимвола.Символ = "&" тогда
            Лог.Ошибка("Ожидался управляющий символ якоря (&), но найдено: " + Строка);
            ВызватьИсключение "Ожидался управляющий символ якоря (&), но найдено: " + Строка;
        КонецЕсли;
        
        
        // Извлекаем имя якоря
        ИмяЯкоря = ИзвлечьИмяЯкоряИлиАлиаса(Строка);
        Если ПустаяСтрока(ИмяЯкоря) Тогда
            Лог.Ошибка("Не удалось извлечь имя якоря из строки: " + Строка);
            ВызватьИсключение "Не удалось извлечь имя якоря из строки: " + Строка;
        КонецЕсли;
        
        Лог.Отладка("Найден якорь с именем: " + ИмяЯкоря);
        
        // Вычисляем уровень отступа якоря
        УровеньОтступа = ОпределитьОтступ(Строка);
        
        Параметры = СоздатьПараметрыЯкоряСОтступом(УровеньОтступа);
        Параметры.ИмяЯкоря = ИмяЯкоря;
        Параметры.ИндексСтрокиСЯкорем = Индекс;
        
        Возврат Параметры;
    КонецЦикла;
    
    Лог.Предупреждение("Управляющий символ якоря не найден");
    Возврат Неопределено; // Управляющий символ якоря не найден
    
КонецФункции

// Извлекает строки содержимого якоря (убирает строку с определением якоря)
//
// Параметры:
//   МассивСтрок - Массив - исходный массив строк
//   Параметры - Структура - параметры якоря
//
// Возвращаемое значение:
//   Массив - массив строк содержимого без определения якоря
//
Функция ИзвлечьСодержимоеЯкоря(МассивСтрок, Параметры)
    
    СтрокиСодержимого = Новый Массив();
    
    // Обрабатываем строку с якорем - убираем определение якоря
    СтрокаСЯкорем = МассивСтрок[Параметры.ИндексСтрокиСЯкорем];
    ОчищеннаяСтрока = УдалитьОпределениеЯкоря(СтрокаСЯкорем);
   
    СтрокиСодержимого.Добавить(ОчищеннаяСтрока);
   
    
    // Добавляем все остальные строки
    Для Индекс = Параметры.ИндексСтрокиСЯкорем + 1 По МассивСтрок.Количество() - 1 Цикл
        СтрокиСодержимого.Добавить(МассивСтрок[Индекс]);
    КонецЦикла;

    Возврат СтрокиСодержимого;
    
КонецФункции

// Проверяет корректность YAML строки flow последовательности
//
// Параметры:
//   СтрокаFlow - Строка - строка flow последовательности для проверки
//
// Исключения:
//   При некорректном формате flow последовательности
//
Процедура ВалидироватьFlowПоследовательность(СтрокаFlow)
    Если ПустаяСтрока(СтрокаFlow) Тогда
        Лог.Ошибка("Не найдена строка с flow последовательностью");
        ВызватьИсключение "Не найдена строка с flow последовательностью";
    КонецЕсли;
    
    Если НЕ СтрНачинаетсяС(СтрокаFlow, "[") Тогда
        Лог.Ошибка("Flow последовательность должна начинаться с [. Получено: " + СтрокаFlow);
        ВызватьИсключение "Flow последовательность должна начинаться с [";
    КонецЕсли;
КонецПроцедуры

// Парсер flow последовательностей (массивов в стиле [1, 2, 3])
//
// Параметры:
//   Строки - Массив - массив строк для парсинга
//
// Возвращаемое значение:
//   Массив - результат парсинга flow последовательности
//
Функция ПарсерFlowПоследовательности(Строки)
    Лог.Отладка("Начало парсинга flow последовательности");
    
    // Объединяем все строки в одну, удаляя комментарии
    СтрокаFlow = ОбъединитьСтрокиFlowСинтаксиса(Строки);
    
    // Валидируем строку flow последовательности
    ВалидироватьFlowПоследовательность(СтрокаFlow);
    
    // Найдем позицию соответствующей закрывающей скобки
    ПозицияЗакрытия = НайтиСоответствующуюЗакрывающуюСкобку(СтрокаFlow, 1);
    Если ПозицияЗакрытия = 0 Тогда
        Лог.Ошибка("Flow последовательность должна заканчиваться ]. Получено: " + СтрокаFlow);
        ВызватьИсключение "Flow последовательность должна заканчиваться ]";
    КонецЕсли;
    
    // Проверим, что после соответствующей закрывающей скобки нет значащих символов
    ОстатокСтроки = СокрЛП(Сред(СтрокаFlow, ПозицияЗакрытия + 1));
    Если НЕ ПустаяСтрока(ОстатокСтроки) Тогда
        Лог.Ошибка("После закрывающей скобки flow последовательности не должно быть других символов. Получено: " + СтрокаFlow);
        ВызватьИсключение "После закрывающей скобки flow последовательности не должно быть других символов";
    КонецЕсли;

    СодержимоеМассива = Сред(СтрокаFlow, МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ, ПозицияЗакрытия - МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ);
    Лог.Отладка("Содержимое flow последовательности: " + СодержимоеМассива);
    
    // Проверяем валидность синтаксиса
    ПроверитьВалидностьFlowПоследовательности(СодержимоеМассива);
    
    // Разбираем элементы
    Элементы = РазбитьFlowЭлементы(СодержимоеМассива);
    
    МассивРезультат = Новый Массив();
    Для Каждого Элемент Из Элементы Цикл
        ОчищенныйЭлемент = СокрЛП(Элемент);
        Если НЕ ПустаяСтрока(ОчищенныйЭлемент) Тогда
            // Рекурсивно обрабатываем каждый элемент
            СтрокиЭлемента = Новый Массив();
            СтрокиЭлемента.Добавить(ОчищенныйЭлемент);
            МассивРезультат.Добавить(ДанныеИзМассиваСтрок(СтрокиЭлемента));
        КонецЕсли;
    КонецЦикла;
    
    Лог.Отладка("Парсинг flow последовательности завершен, получено " + МассивРезультат.Количество() + " элементов");
    Возврат МассивРезультат;
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ МЕТОДЫ ДЛЯ FLOW-СИНТАКСИСА
////////////////////////////////////////////////////////////////////////////////

// Объединяет массив строк в одну строку, удаляя комментарии
//
// Параметры:
//   Строки - Массив - массив строк для объединения
//
// Возвращаемое значение:
//   Строка - объединенная строка без комментариев
//
Функция ОбъединитьСтрокиFlowСинтаксиса(Строки)
    СтрокаFlow = "";
    Для Каждого Строка Из Строки Цикл
        Если НЕ ПустаяСтрока(СокрЛП(Строка)) Тогда
            // Удаляем комментарии из строки
            СтрокаБезКомментария = УбратьКомментарийИзСтроки(Строка);
            Если НЕ ПустаяСтрока(СокрЛП(СтрокаБезКомментария)) Тогда
                СтрокаFlow = СтрокаFlow + " " + СокрЛП(СтрокаБезКомментария);
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    Возврат СокрЛП(СтрокаFlow);
КонецФункции

// Обрабатывает один элемент flow объекта
//
// Параметры:
//   ОчищенныйЭлемент - Строка - элемент для обработки
//   СоответствиеРезультат - Соответствие - результирующее соответствие
//
Процедура ОбработатьЭлементFlowОбъекта(ОчищенныйЭлемент, СоответствиеРезультат)
    Если ПустаяСтрока(ОчищенныйЭлемент) Тогда
        Возврат;
    КонецЕсли;
    
    // Ищем разделитель ключ-значение
    ПозицияДвоеточия = ПозицияНеЭкранированногоСимвола(ОчищенныйЭлемент, ":", Истина);
    Если ПозицияДвоеточия = 0 Тогда
        Лог.Отладка("Не найден разделитель ':' в элементе flow объекта: " + ОчищенныйЭлемент);
        Ключ = ОчищенныйЭлемент;
        Значение = "";
    Иначе
        Ключ = СокрЛП(Лев(ОчищенныйЭлемент, ПозицияДвоеточия - 1));
        Значение = ИзвлечьЗначениеПослеДвоеточияСОчисткой(ОчищенныйЭлемент, ПозицияДвоеточия);
    КонецЕсли;
    
    // Убираем кавычки с ключа
    Ключ = УбратьКавычки(Ключ);
    
    // Проверяем, содержит ли ключ тег
    Если СтрНачинаетсяС(СокрЛП(Ключ), "!") Тогда
        Лог.Отладка("Обнаружен тег в ключе: " + Ключ);
        // Создаем массив строк для обработки тега
        СтрокиКлюча = Новый Массив();
        СтрокиКлюча.Добавить(Ключ);
        Ключ = ДанныеИзМассиваСтрок(СтрокиКлюча);
        Лог.Отладка("Ключ после применения тега: " + Ключ);
    КонецЕсли;
    
    // Обрабатываем пустые значения
    Если ПустаяСтрока(Значение) Тогда
        СоответствиеРезультат.Вставить(Ключ, Null);
    Иначе
        // Рекурсивно обрабатываем значение
        СтрокиЗначения = Новый Массив();
        СтрокиЗначения.Добавить(Значение);
        СоответствиеРезультат.Вставить(Ключ, ДанныеИзМассиваСтрок(СтрокиЗначения));
    КонецЕсли;
КонецПроцедуры

// Проверяет корректность YAML строки flow объекта
//
// Параметры:
//   СтрокаFlow - Строка - строка flow объекта для проверки
//
// Исключения:
//   При некорректном формате flow объекта
//
Процедура ВалидироватьFlowОбъект(СтрокаFlow)
    Если ПустаяСтрока(СтрокаFlow) Тогда
        Лог.Ошибка("Не найдена строка с flow объектом");
        ВызватьИсключение "Не найдена строка с flow объектом";
    КонецЕсли;
    
    Если НЕ (СтрНачинаетсяС(СтрокаFlow, "{") И СтрЗаканчиваетсяНа(СтрокаFlow, "}")) Тогда
        Лог.Ошибка("Flow объект должен начинаться с { и заканчиваться }. Получено: " + СтрокаFlow);
        ВызватьИсключение "Flow объект должен начинаться с { и заканчиваться }";
    КонецЕсли;
КонецПроцедуры

// Парсер flow объектов (объектов в стиле {key1: value1, key2: value2})
//
// Параметры:
//   Строки - Массив - массив строк для парсинга
//
// Возвращаемое значение:
//   Соответствие - результат парсинга flow объекта
//
Функция ПарсерFlowОбъекта(Строки)
    Лог.Отладка("Начало парсинга flow объекта");
    
    // Объединяем все строки в одну, удаляя комментарии
    СтрокаFlow = ОбъединитьСтрокиFlowСинтаксиса(Строки);
    
    // Валидируем строку flow объекта
    ВалидироватьFlowОбъект(СтрокаFlow);
    
    СодержимоеОбъекта = УдалитьПервыйИПоследнийСимволы(СтрокаFlow);
    Лог.Отладка("Содержимое flow объекта: " + СодержимоеОбъекта);
    
    // Проверяем валидность синтаксиса
    ПроверитьВалидностьFlowОбъекта(СодержимоеОбъекта);
    
    // Разбираем пары ключ-значение
    Элементы = РазбитьFlowЭлементы(СодержимоеОбъекта);
    
    СоответствиеРезультат = Новый Соответствие();
    Для Каждого Элемент Из Элементы Цикл
        ОчищенныйЭлемент = СокрЛП(Элемент);
        ОбработатьЭлементFlowОбъекта(ОчищенныйЭлемент, СоответствиеРезультат);
    КонецЦикла;
    
    Лог.Отладка("Парсинг flow объекта завершен, получено " + СоответствиеРезультат.Количество() + " свойств");
    Возврат СоответствиеРезультат;
КонецФункции

// Разбивает строку flow элементов на отдельные элементы с учетом вложенности
//
// Параметры:
//   СтрокаЭлементов - Строка - строка с элементами для разбиения
//
// Возвращаемое значение:
//   Массив - массив отдельных элементов
//
Функция РазбитьFlowЭлементы(СтрокаЭлементов)
    Лог.Отладка("Разбиение flow элементов: " + СтрокаЭлементов);
    
    Элементы = Новый Массив();
    ТекущийЭлемент = "";
    УровеньВложенности = 0;
    ВКавычках = Ложь;
    ТипКавычек = "";
    
    Для Позиция = 1 По СтрДлина(СтрокаЭлементов) Цикл
        Символ = Сред(СтрокаЭлементов, Позиция, 1);
        
        // Обработка кавычек
        Если ОбработатьКавычки(Символ, ВКавычках, ТипКавычек) Тогда
            ТекущийЭлемент = ТекущийЭлемент + Символ;
            Продолжить;
        КонецЕсли;
        
        Если НЕ ВКавычках Тогда
            // Обрабатываем элементы вне кавычек
            Если ОбработатьЭлементВнеКавычек(Символ, УровеньВложенности, ТекущийЭлемент, Элементы) Тогда
                Продолжить;
            КонецЕсли;
        КонецЕсли;
        
        ТекущийЭлемент = ТекущийЭлемент + Символ;
    КонецЦикла;
    
    // Добавляем последний элемент
    Если НЕ ПустаяСтрока(ТекущийЭлемент) Тогда
        Элементы.Добавить(ТекущийЭлемент);
    КонецЕсли;
    
    Лог.Отладка("Разбиение завершено, получено " + Элементы.Количество() + " элементов");
    Возврат Элементы;
КонецФункции

// Обрабатывает кавычки в flow элементах
//
// Параметры:
//   Символ - Строка - текущий символ
//   ВКавычках - Булево - флаг нахождения в кавычках (передается по ссылке)
//   ТипКавычек - Строка - тип кавычек (передается по ссылке)
//
// Возвращаемое значение:
//   Булево - Истина, если символ обработан как кавычка
//
Функция ОбработатьКавычки(Символ, ВКавычках, ТипКавычек)
    
    Если (Символ = """" ИЛИ Символ = "'") И НЕ ВКавычках Тогда
        ВКавычках = Истина;
        ТипКавычек = Символ;
        Возврат Истина;
    ИначеЕсли ВКавычках И Символ = ТипКавычек Тогда
        ВКавычках = Ложь;
        ТипКавычек = "";
        Возврат Истина;
    Иначе
        Возврат Ложь;
    КонецЕсли;
    
КонецФункции

// Обрабатывает элемент вне кавычек
//
// Параметры:
//   Символ - Строка - текущий символ
//   УровеньВложенности - Число - уровень вложенности (передается по ссылке)
//   ТекущийЭлемент - Строка - текущий элемент (передается по ссылке)
//   Элементы - Массив - массив элементов (передается по ссылке)
//
// Возвращаемое значение:
//   Булево - Истина, если нужно продолжить итерацию
//
Функция ОбработатьЭлементВнеКавычек(Символ, УровеньВложенности, ТекущийЭлемент, Элементы)
    
    Если Символ = "[" ИЛИ Символ = "{" Тогда
        УровеньВложенности = УровеньВложенности + 1;
    ИначеЕсли Символ = "]" ИЛИ Символ = "}" Тогда
        УровеньВложенности = УровеньВложенности - 1;
    ИначеЕсли Символ = "," И УровеньВложенности = 0 Тогда
        // Это разделитель элементов на верхнем уровне
        Элементы.Добавить(ТекущийЭлемент);
        ТекущийЭлемент = "";
        Возврат Истина;
    Иначе
        Возврат Ложь;
    КонецЕсли;
    
    Возврат Ложь;
    
КонецФункции

// Проверяет валидность flow последовательности
//
// Параметры:
//   СодержимоеМассива - Строка - содержимое между [ и ]
//
// Исключения:
//   При обнаружении некорректного синтаксиса
//
Процедура ПроверитьВалидностьFlowПоследовательности(СодержимоеМассива)
    
    Если ПустаяСтрока(СокрЛП(СодержимоеМассива)) Тогда
        Возврат; // Пустая последовательность валидна
    КонецЕсли;
    
    // Проверяем на недопустимые символы в начале
    ОчищенноеСодержимое = СокрЛП(СодержимоеМассива);
    Если СтрНачинаетсяС(ОчищенноеСодержимое, ",") Тогда
        Лог.Ошибка("Flow последовательность не может начинаться с запятой");
        ВызватьИсключение "Flow последовательность не может начинаться с запятой";
    КонецЕсли;
    
    Если СтрНачинаетсяС(ОчищенноеСодержимое, "-") Тогда
        Лог.Ошибка("Flow последовательность не может содержать дефисы");
        ВызватьИсключение "Flow последовательность не может содержать дефисы";
    КонецЕсли;
    
    // Проверяем на двойные запятые (недопустимо)
    Если СтрНайти(СодержимоеМассива, ",,") > 0 Тогда
        Лог.Ошибка(ОШИБКА_ЛИШНИЕ_ЗАПЯТЫЕ_FLOW);
        ВызватьИсключение ОШИБКА_ЛИШНИЕ_ЗАПЯТЫЕ_FLOW;
    КонецЕсли;
    
    // Проверяем на запятые с пробелами между ними (тоже недопустимо)
    Если СтрНайти(СодержимоеМассива, ", ,") > 0 Тогда
        Лог.Ошибка(ОШИБКА_ЛИШНИЕ_ЗАПЯТЫЕ_FLOW);
        ВызватьИсключение ОШИБКА_ЛИШНИЕ_ЗАПЯТЫЕ_FLOW;
    КонецЕсли;
    
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// МЕТОДЫ ВАЛИДАЦИИ И ПРОВЕРКИ СИНТАКСИСА
////////////////////////////////////////////////////////////////////////////////

// Проверяет валидность flow объекта
//
// Параметры:
//   СодержимоеОбъекта - Строка - содержимое между { и }
//
// Возвращаемое значение:
//   Булево - истина, если синтаксис корректен
//
Функция ПроверитьВалидностьFlowОбъекта(СодержимоеОбъекта)
    
    // Проверяем на недопустимые конструкции
    ОчищенноеСодержимое = СокрЛП(СодержимоеОбъекта);
    
    // Проверяем на недопустимые запятые
    Если СтрНачинаетсяС(ОчищенноеСодержимое, ",") Тогда
        Лог.Ошибка("Flow объект не может начинаться с запятой");
        ВызватьИсключение "Flow объект не может начинаться с запятой";
    КонецЕсли;
    
    Возврат Истина;
    
КонецФункции

// Поиск соответствующей закрывающей скобки с учетом вложенности
//
// Параметры:
//   Строка - Строка - строка для поиска
//   НачальнаяПозиция - Число - позиция открывающей скобки
//
// Возвращаемое значение:
//   Число - позиция соответствующей закрывающей скобки или 0, если не найдена
//
Функция НайтиСоответствующуюЗакрывающуюСкобку(Строка, НачальнаяПозиция)
    
    УровеньВложенности = 1;
    ДлинаСтроки = СтрДлина(Строка);
    
    Для Позиция = НачальнаяПозиция + 1 По ДлинаСтроки Цикл
        Символ = Сред(Строка, Позиция, 1);
        
        Если Символ = "[" Тогда
            УровеньВложенности = УровеньВложенности + 1;
        ИначеЕсли Символ = "]" Тогда
            УровеньВложенности = УровеньВложенности - 1;
            Если УровеньВложенности = 0 Тогда
                Возврат Позиция;
            КонецЕсли;
        Иначе
            Продолжить;
        КонецЕсли;
    КонецЦикла;
    
    Возврат 0; // Не найдена соответствующая закрывающая скобка
    
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ФУНКЦИИ РАБОТЫ С ТЕГАМИ
////////////////////////////////////////////////////////////////////////////////

// Разбирает вербатим тег (заключенный в угловые скобки)
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка с вербатим тегом
//
// Возвращаемое значение:
//   Структура - структура с полями "Тег" и "Значение".
//
Функция РазобратьVerbatimТег(ОчищеннаяСтрока)
    ТегИЗначение = Новый Структура("Тег, Значение", "", "");
    
    ПозицияЗакрытияТега = СтрНайти(ОчищеннаяСтрока, ">");
    Если ПозицияЗакрытияТега = 0 Тогда
        ВызватьИсключение "Незакрытый verbatim тег: " + ОчищеннаяСтрока;
    КонецЕсли;
    
    ТегИЗначение.Тег = Лев(ОчищеннаяСтрока, ПозицияЗакрытияТега);
    
    // Ищем значение после тега
    ОстатокСтроки = СокрЛП(Сред(ОчищеннаяСтрока, ПозицияЗакрытияТега + 1));
    ТегИЗначение.Значение = ОстатокСтроки;
    
    Лог.Отладка("Разобран verbatim тег '" + ТегИЗначение.Тег + "' со значением '" + ТегИЗначение.Значение + "'");
    Возврат ТегИЗначение;
КонецФункции

// Разбирает обычный тег
//
// Параметры:
//   ОчищеннаяСтрока - Строка - строка с тегом
//
// Возвращаемое значение:
//   Структура - структура с тегом и значением
Функция РазобратьОбычныйТег(ОчищеннаяСтрока)
    ТегИЗначение = Новый Структура("Тег, Значение", "", "");
    
    // Ищем первый пробел или таб (но не в самом начале)
    ПозицияПробела = 0;
    Для Инд = 1 По СтрДлина(ОчищеннаяСтрока) Цикл
        Символ = Сред(ОчищеннаяСтрока, Инд, 1);
        Если Инд > 1 И (Символ = " " ИЛИ Символ = Символы.Таб) Тогда
            ПозицияПробела = Инд;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Если ПозицияПробела = 0 Тогда
        // Тег без значения (только тег)
        ТегИЗначение.Тег = ОчищеннаяСтрока;
        ТегИЗначение.Значение = "";
    Иначе
        // Разделяем тег и значение
        ТегИЗначение.Тег = Лев(ОчищеннаяСтрока, ПозицияПробела - 1);
        Значение = СокрЛП(Сред(ОчищеннаяСтрока, ПозицияПробела + 1));
        
        // Убираем комментарий, если он есть
        ПозицияКомментария = СтрНайти(Значение, "#");
        Если ПозицияКомментария > 0 Тогда
            Значение = СокрП(Лев(Значение, ПозицияКомментария - 1));
        КонецЕсли;
        
        ТегИЗначение.Значение = Значение;
    КонецЕсли;
    
    Возврат ТегИЗначение;
КонецФункции

// Валидирует тег согласно YAML спецификации
//
// Параметры:
//   Тег - Строка - тег для валидации
//   ЭтоVerbatim - Булево - истина, если это verbatim тег
Процедура ВалидироватьТег(Тег, ЭтоVerbatim = Ложь)
    // Verbatim теги могут содержать любые символы между !< и >
    Если ЭтоVerbatim Тогда
        Возврат; // Пропускаем валидацию для verbatim тегов
    КонецЕсли;
    
    // Обычные теги не должны содержать определенные символы
    НедопустимыеСимволы = "{}[],";
    Для Инд = 1 По СтрДлина(НедопустимыеСимволы) Цикл
        Символ = Сред(НедопустимыеСимволы, Инд, 1);
        Если СтрНайти(Тег, Символ) > 0 Тогда
            ВызватьИсключение "Недопустимый символ '" + Символ + "' в теге: " + Тег;
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

// Разбирает строку с тегом и значением
//
// Параметры:
//   Строка - Строка - строка для разбора
//
// Возвращаемое значение:
//   Структура - структура с полями Тег и Значение
Функция РазобратьТегИЗначение(Строка)
    // Убираем отступы
    ОчищеннаяСтрока = СокрЛП(Строка);
    
    // Проверяем, что строка начинается с !
    Если НЕ СтрНачинаетсяС(ОчищеннаяСтрока, "!") Тогда
        ВызватьИсключение "Ожидался тег, начинающийся с !, а найдено: " + Строка;
    КонецЕсли;
    
    // Обработка verbatim тегов !<uri>
    Если СтрНачинаетсяС(ОчищеннаяСтрока, "!<") Тогда
        ТегИЗначение = РазобратьVerbatimТег(ОчищеннаяСтрока);
        ВалидироватьТег(ТегИЗначение.Тег, Истина); // Verbatim тег
    Иначе
        // Обработка обычных тегов
        ТегИЗначение = РазобратьОбычныйТег(ОчищеннаяСтрока);
        ВалидироватьТег(ТегИЗначение.Тег, Ложь); // Обычный тег
    КонецЕсли;
    
    Лог.Отладка("Разобран тег '" + ТегИЗначение.Тег + "' со значением '" + ТегИЗначение.Значение + "'");
    Возврат ТегИЗначение;
КонецФункции

// Применяет тег к значению согласно YAML спецификации
//
// Параметры:
//   Тег - Строка - тег для применения
//   Значение - Строка - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - результат применения тега
//
Функция ПрименитьТегКЗначению(Тег, Значение)
    Лог.Отладка("Применение тега '" + Тег + "' к значению '" + Значение + "'");
    
    // Разрешаем префиксные теги (пропускаем исключения дальше)
    РазрешенныйТег = РазрешитьПрефиксныйТег(Тег);
    
    // Неспецифический тег ! - просто возвращаем значение как строку
    Если РазрешенныйТег = "!" Тогда
        Лог.Отладка("Неспецифический тег !, возвращаем значение как строку");
        Возврат Значение;
    КонецЕсли;
    
    // Обрабатываем стандартные теги YAML
    Результат = ОбработатьСтандартныйТег(РазрешенныйТег, Значение);
    Если Результат <> Неопределено Тогда
        Возврат Результат;
    КонецЕсли;
    
    // Обрабатываем пользовательские теги
    Возврат ОбработатьПользовательскийТег(РазрешенныйТег, Значение);
КонецФункции

// Обрабатывает стандартные теги YAML
//
// Параметры:
//   РазрешенныйТег - Строка - разрешенный тег
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение или Неопределено, если тег не стандартный
//
Функция ОбработатьСтандартныйТег(РазрешенныйТег, Значение)
    Если РазрешенныйТег = "!!str" Тогда
        Возврат УбратьКавычки(Значение);
    ИначеЕсли РазрешенныйТег = "!!int" Тогда
        Возврат ПреобразоватьВЧисло(Значение);
    ИначеЕсли РазрешенныйТег = "!!bool" Тогда
        Возврат ПреобразоватьВБулево(Значение);
    ИначеЕсли РазрешенныйТег = "!!null" Тогда
        Возврат Неопределено;
    ИначеЕсли РазрешенныйТег = "!!float" Тогда
        Возврат ПреобразоватьВЧисло(Значение);
    ИначеЕсли РазрешенныйТег = "!!map" Тогда
        Возврат ОбработатьТегMap(Значение);
    ИначеЕсли РазрешенныйТег = "!!seq" Тогда
        Возврат ОбработатьТегSeq(Значение);
    ИначеЕсли РазрешенныйТег = "!!set" Тогда
        Возврат ОбработатьТегSet(Значение);
    ИначеЕсли РазрешенныйТег = "!!omap" Тогда
        Возврат ОбработатьТегOmap(Значение);
    ИначеЕсли РазрешенныйТег = "!!binary" Тогда
        Возврат ОбработатьТегBinary(Значение);
    Иначе
        Возврат Неопределено; // Не стандартный тег
    КонецЕсли;
КонецФункции

// Обрабатывает тег !!map
//
// Параметры:
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьТегMap(Значение)
    // Обрабатываем !!map - должен возвращать соответствие
    Если ТипЗнч(Значение) = Тип("Соответствие") Тогда
        Возврат Значение;
    ИначеЕсли ТипЗнч(Значение) = Тип("Строка") И СтрНачинаетсяС(СокрЛП(Значение), "{") Тогда
        Возврат ПарситьFlowObject(Значение);
    ИначеЕсли ТипЗнч(Значение) = Тип("Строка") И СтрНайти(Значение, ":") > 0 Тогда
        Возврат ПарситьKeyValueПару(Значение);
    Иначе
        Лог.Предупреждение("Тег !!map применяется к не-соответствию, возвращаем как строку");
        Возврат Строка(Значение);
    КонецЕсли;
КонецФункции

// Парсит flow object из строки
//
// Параметры:
//   Значение - Строка - строка с flow синтаксисом
//
// Возвращаемое значение:
//   Произвольный - результат парсинга или строка в случае ошибки
//
Функция ПарситьFlowObject(Значение)
    Попытка
        // Парсим как flow object
        МассивСтрок = Новый Массив();
        МассивСтрок.Добавить(Значение);
        Результат = ДанныеИзМассиваСтрок(МассивСтрок);
        Если ТипЗнч(Результат) = Тип("Соответствие") Тогда
            Возврат Результат;
        КонецЕсли;
    Исключение
        Лог.Предупреждение("Не удалось разобрать !!map как flow object: " + ОписаниеОшибки());
    КонецПопытки;
    
    Возврат Строка(Значение);
КонецФункции

// Парсит key-value пару из строки
//
// Параметры:
//   Значение - Строка - строка с двоеточием (key-value пара)
//
// Возвращаемое значение:
//   Произвольный - результат парсинга или строка в случае ошибки
//
Функция ПарситьKeyValueПару(Значение)
    Попытка
        // Парсим как mapping
        МассивСтрок = Новый Массив();
        МассивСтрок.Добавить(Значение);
        Результат = ПарсерОбъектов(МассивСтрок);
        Если ТипЗнч(Результат) = Тип("Соответствие") Тогда
            Возврат Результат;
        КонецЕсли;
    Исключение
        Лог.Предупреждение("Не удалось разобрать !!map как key-value пару: " + ОписаниеОшибки());
    КонецПопытки;
    
    Возврат Строка(Значение);
КонецФункции

// Обрабатывает тег !!seq
//
// Параметры:
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьТегSeq(Значение)
    // Обрабатываем !!seq - должен возвращать массив
    Если ТипЗнч(Значение) = Тип("Массив") Тогда
        Возврат Значение;
    Иначе
        // Если это строка с flow синтаксисом, парсим её
        Если ТипЗнч(Значение) = Тип("Строка") И СтрНачинаетсяС(СокрЛП(Значение), "[") Тогда
            Попытка
                // Парсим как flow array
                МассивСтрок = Новый Массив();
                МассивСтрок.Добавить(Значение);
                Результат = ДанныеИзМассиваСтрок(МассивСтрок);
                Если ТипЗнч(Результат) = Тип("Массив") Тогда
                    Возврат Результат;
                КонецЕсли;
            Исключение
                Лог.Предупреждение("Не удалось разобрать !!seq как flow array: " + ОписаниеОшибки());
            КонецПопытки;
        КонецЕсли;
        Лог.Предупреждение("Тег !!seq применяется к не-массиву, возвращаем как строку");
        Возврат Строка(Значение);
    КонецЕсли;
КонецФункции

// Обрабатывает тег !!set
//
// Параметры:
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьТегSet(Значение)
    // Обрабатываем !!set - множество представляется как соответствие с null значениями
    Если ТипЗнч(Значение) = Тип("Соответствие") Тогда
        // Преобразуем все значения в null
        РезультатSet = Новый Соответствие();
        Для Каждого КлючЗначение Из Значение Цикл
            РезультатSet.Вставить(КлючЗначение.Ключ, Неопределено);
        КонецЦикла;
        Возврат РезультатSet;
    Иначе
        Лог.Предупреждение("Тег !!set применяется к не-соответствию, возвращаем как строку");
        Возврат Строка(Значение);
    КонецЕсли;
КонецФункции

// Обрабатывает тег !!omap
//
// Параметры:
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьТегOmap(Значение)
    // Обрабатываем !!omap - упорядоченное отображение как массив объектов
    Если ТипЗнч(Значение) = Тип("Массив") Тогда
        // Возвращаем массив как есть - это уже правильный формат для !!omap
        Возврат Значение;
    Иначе
        Лог.Предупреждение("Тег !!omap применяется к не-массиву, возвращаем как строку");
        Возврат Строка(Значение);
    КонецЕсли;
КонецФункции

// Обрабатывает тег !!binary
//
// Параметры:
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Строка - обработанная Base64 строка
//
Функция ОбработатьТегBinary(Значение)
    // Обрабатываем !!binary - декодируем Base64
    Лог.Отладка("Обработка тега !!binary для значения: " + Значение);
    
    // Убираем кавычки если есть
    СтрокаДляДекодирования = УбратьКавычки(Значение);
    
    // Обрабатываем символы экранирования для продолжения строк
    // В двойных кавычках \ в конце строки означает продолжение на следующей строке
    СтрокаДляДекодирования = СтрЗаменить(СтрокаДляДекодирования, "\ ", "");
    СтрокаДляДекодирования = СтрЗаменить(СтрокаДляДекодирования, "\", "");
    
    // Убираем переводы строк и пробелы (Base64 может быть разбит на строки)
    СтрокаДляДекодирования = СтрЗаменить(СтрокаДляДекодирования, Символы.ПС, "");
    СтрокаДляДекодирования = СтрЗаменить(СтрокаДляДекодирования, Символы.ВК, "");
    СтрокаДляДекодирования = СтрЗаменить(СтрокаДляДекодирования, " ", "");
    СтрокаДляДекодирования = СтрЗаменить(СтрокаДляДекодирования, Символы.Таб, "");
    
    Лог.Отладка("Base64 строка для декодирования: " + СтрокаДляДекодирования);
    
    // Возвращаем очищенную Base64 строку как есть
    // В OneScript нет встроенной функции декодирования Base64
    // Поэтому возвращаем строку как есть
    Возврат СтрокаДляДекодирования;
КонецФункции

// Обрабатывает пользовательские теги
//
// Параметры:
//   РазрешенныйТег - Строка - разрешенный тег
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьПользовательскийТег(РазрешенныйТег, Значение)
    // Для всех остальных тегов (включая пользовательские)
    // Проверяем, является ли это неопределенным префиксным тегом
    ПроверитьНеопределенныйПрефиксныйТег(РазрешенныйТег);
    
    Лог.Предупреждение("Неизвестный тег '" + РазрешенныйТег + "', возвращаем исходное значение");
    
    // Для сложных типов (массивы, объекты) возвращаем как есть
    Если ТипЗнч(Значение) = Тип("Массив") ИЛИ ТипЗнч(Значение) = Тип("Соответствие") Тогда
        Возврат Значение;
    КонецЕсли;
    
    // Для строковых значений обрабатываем кавычки
    Возврат ОбработатьКавычкиВСтроке(Значение);
КонецФункции

// Проверяет неопределенный префиксный тег
//
// Параметры:
//   РазрешенныйТег - Строка - разрешенный тег
//
Процедура ПроверитьНеопределенныйПрефиксныйТег(РазрешенныйТег)
    Если СтрНачинаетсяС(РазрешенныйТег, "!") 
        И НЕ СтрНачинаетсяС(РазрешенныйТег, "!!") 
        И НЕ СтрНачинаетсяС(РазрешенныйТег, "!<") 
        И НЕ СтрНачинаетсяС(РазрешенныйТег, "!tag:") Тогда
        // Проверяем, есть ли второй ! (признак префиксного тега)
        Если СтрДлина(РазрешенныйТег) > 1 Тогда
            ВторойВосклицательныйЗнак = 0;
            Попытка
                ВторойВосклицательныйЗнак = СтрНайти(РазрешенныйТег, "!", 2);
            Исключение
                // Если произошла ошибка при поиске второго !, игнорируем
                // Обычно это происходит если аргумент неправильного типа
                ВторойВосклицательныйЗнак = 0;
            КонецПопытки;
            
            Если ВторойВосклицательныйЗнак > 0 Тогда
                // Это неопределенный префиксный тег - должно вызывать ошибку
                ВызватьИсключение "Используется неопределенный префикс тега: " + РазрешенныйТег;
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

// Обрабатывает кавычки в строке
//
// Параметры:
//   Значение - Произвольный - значение для обработки
//
// Возвращаемое значение:
//   Произвольный - обработанное значение
//
Функция ОбработатьКавычкиВСтроке(Значение)
    // Для строковых значений обрабатываем кавычки
    Если СтрНачинаетсяС(Значение, """") И СтрЗаканчиваетсяНа(Значение, """") И СтрДлина(Значение) >= 2 Тогда
        // Убираем внешние кавычки
        Результат = Сред(Значение, 2, СтрДлина(Значение) - 2);
        Лог.Отладка("Убраны внешние кавычки: '" + Значение + "' -> '" + Результат + "'");
        Возврат Результат;
    КонецЕсли;
    
    Возврат Значение;
КонецФункции

// Обрабатывает TAG директиву
//
// Параметры:
//   Директива - Строка - строка директивы TAG
//
Процедура ОбработатьТАГДирективу(Директива)
    // Формат: %TAG !handle! prefix
    // Пример: %TAG !e! tag:example.com,2000:app/
    
    Лог.Отладка("ОбработатьТАГДирективу вызвана с параметром: " + Директива);
    
    Части = СтрРазделить(Директива, " ");
    Если Части.Количество() <> 3 Тогда
        Лог.Предупреждение("Некорректная TAG директива: " + Директива);
        Возврат;
    КонецЕсли;
    
    Handle = Части[1]; // !e!
    Prefix = Части[2]; // tag:example.com,2000:app/
    
    ТекущиеТАГДирективы.Вставить(Handle, Prefix);
    Лог.Отладка("Зарегистрирована TAG директива: " + Handle + " -> " + Prefix);
КонецПроцедуры

// Разрешает префиксный тег в полный URI
//
// Параметры:
//   Тег - Строка - тег для разрешения (например, !e!foo)
//
// Возвращаемое значение:
//   Строка - полный URI тега или исходный тег, если не найден префикс
//
Функция РазрешитьПрефиксныйТег(Тег)
    Лог.Отладка("РазрешитьПрефиксныйТег вызвана для тега: " + Тег);
    Лог.Отладка("Доступные TAG директивы: " + ТекущиеТАГДирективы.Количество());
    
    // Проверим, что Тег является строкой
    Если ТипЗнч(Тег) <> Тип("Строка") Тогда
        Возврат Тег;
    КонецЕсли;
    
    // Если это verbatim тег (!<uri>), пропускаем проверку префиксов
    Если СтрНачинаетсяС(Тег, "!<") И СтрЗаканчиваетсяНа(Тег, ">") Тогда
        Возврат Тег; // Verbatim теги не требуют разрешения префиксов
    КонецЕсли;
    
    // Ищем префикс в зарегистрированных пользовательских директивах
    Для Каждого КлючЗначение Из ТекущиеТАГДирективы Цикл
        Handle = КлючЗначение.Ключ;
        Prefix = КлючЗначение.Значение;
        
        Лог.Отладка("Проверяем префикс: " + Handle + " -> " + Prefix);
        
        Если СтрНачинаетсяС(Тег, Handle) Тогда
            // Заменяем handle на prefix
            ЛокальноеИмя = Сред(Тег, СтрДлина(Handle) + 1);
            ПолныйТег = Prefix + ЛокальноеИмя;
            Лог.Отладка("Разрешен префиксный тег: " + Тег + " -> " + ПолныйТег);
            Возврат ПолныйТег;
        КонецЕсли;
    КонецЦикла;
    
    // Если не найдено пользовательское переопределение, проверяем стандартные YAML теги
    Если СтрНачинаетсяС(Тег, "!!") Тогда
        // Стандартные теги используются только если нет пользовательского переопределения
        Возврат Тег;
    КонецЕсли;
    
    // Проверяем, содержит ли тег неопределенный префикс
    // Префикс имеет вид !something! (начинается и заканчивается восклицательным знаком)
    Если СтрНачинаетсяС(Тег, "!") И НЕ СтрЗаканчиваетсяНа(Тег, "!") Тогда
        // Ищем второй восклицательный знак (пропускаем первый)
        ОстальнаяЧасть = Сред(Тег, 2); // Убираем первый "!"
        ВтораяПозиция = Найти(ОстальнаяЧасть, "!");
        Если ВтораяПозиция > 0 Тогда
            // Есть префикс формата !prefix!something
            НеопределенныйПрефикс = "!" + Лев(ОстальнаяЧасть, ВтораяПозиция);
            
            // Исключение: префикс !! является стандартным YAML префиксом
            Если НеопределенныйПрефикс <> "!!" Тогда
                ВызватьИсключение("Использован неопределенный TAG префикс: " + НеопределенныйПрефикс);
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;
    
    // Если префикс не найден, возвращаем исходный тег
    Возврат Тег;
КонецФункции

// Преобразует строку в число с проверкой
//
// Параметры:
//   Значение - Строка - значение для преобразования
//
// Возвращаемое значение:
//   Число - результат преобразования
//
Функция ПреобразоватьВЧисло(Значение)
    // Проверяем, что значение похоже на число
    ОчищенноеЗначение = СокрЛП(Значение);
    Если ПустаяСтрока(ОчищенноеЗначение) Тогда
        ВызватьИсключение "Пустое значение не может быть преобразовано в число";
    КонецЕсли;
    
    // Попытка преобразования
    Попытка
        Результат = XMLЗначение(Тип("Число"), ОчищенноеЗначение);
        Возврат Результат;
    Исключение
        ВызватьИсключение "Не удалось преобразовать в число: " + Значение;
    КонецПопытки;
КонецФункции

// Преобразует строку в булево значение
//
// Параметры:
//   Значение - Строка - значение для преобразования
//
// Возвращаемое значение:
//   Булево - результат преобразования
//
Функция ПреобразоватьВБулево(Значение)
    Если ВРег(Значение) = "TRUE" ИЛИ Значение = "1" Тогда
        Возврат Истина;
    ИначеЕсли ВРег(Значение) = "FALSE" ИЛИ Значение = "0" Тогда
        Возврат Ложь;
    Иначе
        ВызватьИсключение "Не удалось преобразовать в булево: " + Значение;
    КонецЕсли;
КонецФункции

// Проверяет, является ли разделитель документа действительным
//
// Параметры:
//   Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//   Булево - истина, если это действительный разделитель документа
//
Функция ЭтоДействительныйРазделительДокумента(Строка)
    
    СокращеннаяСтрока = СокрЛП(Строка);
    
    // Должно начинаться с ---
    Если НЕ СтрНачинаетсяС(СокращеннаяСтрока, YAML_РАЗДЕЛИТЕЛЬ_ДОКУМЕНТА) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем что после --- идет пробел, табуляция или конец строки
    Если СтрДлина(СокращеннаяСтрока) = 3 Тогда
        // Точно "---" - это действительный разделитель
        Возврат Истина;
    КонецЕсли;
    
    // Получаем символ сразу после ---
    СимволПослеТретьегоДаша = Сред(СокращеннаяСтрока, 4, 1);
    
    // Действительный разделитель только если после --- идет пробел или табуляция
    Если СимволПослеТретьегоДаша = " " ИЛИ СимволПослеТретьегоДаша = Символы.Таб Тогда
        Возврат Истина;
    КонецЕсли;
    
    // Во всех остальных случаях (например, "---word1") это не разделитель документа
    Возврат Ложь;
КонецФункции

// Проверяет, является ли терминатор документа действительным
//
// Параметры:
//   Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//   Булево - истина, если это действительный терминатор документа
//
Функция ЭтоДействительныйТерминаторДокумента(Строка)
    
    СокращеннаяСтрока = СокрЛП(Строка);
    
    // Должно начинаться с ...
    Если НЕ СтрНачинаетсяС(СокращеннаяСтрока, YAML_ТЕРМИНАТОР_ДОКУМЕНТА) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // В YAML ... должно быть в отдельной строке или только с пробелами/комментариями после
    ОстаткСтроки = Сред(СокращеннаяСтрока, СтрДлина(YAML_ТЕРМИНАТОР_ДОКУМЕНТА) + 1);
    ОстаткСтрокиБезПробелов = СокрЛП(ОстаткСтроки);
    
    // Проверяем остаток строки
    Если НЕ ПустаяСтрока(ОстаткСтрокиБезПробелов) Тогда
        // Если есть непробельное содержимое, оно должно быть комментарием
        Если НЕ СтрНачинаетсяС(ОстаткСтрокиБезПробелов, "#") Тогда
            // Если это не комментарий, то это ошибка
            ВызватьИсключение "Недопустимое содержимое после маркера конца документа: " + СокращеннаяСтрока;
        КонецЕсли;
    КонецЕсли;
    
    Возврат Истина;
КонецФункции


// Якоря
//
//

// Сохранение значения под якорем
//
// Параметры:
//   ИмяЯкоря - Строка - имя якоря
//   Значение - Произвольный - значение для сохранения
//
Процедура СохранитьЯкорь(ИмяЯкоря, Значение)
	Якоря.Вставить(ИмяЯкоря, Значение);
КонецПроцедуры

// Получение значения по якорю
//
// Параметры:
//   ИмяЯкоря - Строка - имя якоря
//
// Возвращаемое значение:
//   Произвольный - значение якоря или Неопределено, если якорь не найден
//
Функция ПолучитьЗначениеЯкоря(ИмяЯкоря)
	Возврат Якоря.Получить(ИмяЯкоря);
КонецФункции

// Проверка существования якоря
//
// Параметры:
//   ИмяЯкоря - Строка - имя якоря
//
// Возвращаемое значение:
//   Булево - Истина, если якорь существует
//
Функция ЯкорьСуществует(ИмяЯкоря)
	Для каждого КлючЗначение Из Якоря Цикл
		Если КлючЗначение.Ключ = ИмяЯкоря Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

// Извлечение имени якоря из строки (для &anchor)
//
// Параметры:
//   Строка - Строка - строка с определением якоря
//
// Возвращаемое значение:
//   Строка - имя якоря или пустая строка, если якорь не найден
//
Функция ИзвлечьИмяЯкоряИлиАлиаса(Строка)
	
	Строка = СокрЛП(Строка);
	Позиция = 1;
	Попытка
		Если не Лев(Строка, 1) = "&" И Не Лев(Строка, 1) = "*" Тогда
			Возврат "";
		КонецЕсли;
	
		// Извлекаем имя якоря (до пробела или до конца строки)
		НачалоИмени = Позиция + 1;
		КонецИмени = СтрДлина(Строка);
		
		Для Позиция = НачалоИмени По КонецИмени Цикл
			Символ = Сред(Строка, Позиция, 1);
			Если Символ = " " ИЛИ Символ = Символы.Таб ИЛИ Символ = ":" Тогда
				КонецИмени = Позиция - 1;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Возврат Сред(Строка, НачалоИмени, КонецИмени - НачалоИмени + 1);
	Исключение
		Возврат "";
		// Если произошла ошибка, возвращаем пустую строку
	КонецПопытки;
	
КонецФункции

// Удаление определения якоря из строки
//
// Параметры:
//   Строка - Строка - строка с определением якоря
//
// Возвращаемое значение:
//   Строка - строка без определения якоря
//
Функция УдалитьОпределениеЯкоря(Строка)
	ПозицияЯкоря = СтрНайти(Строка, "&");
	Если ПозицияЯкоря = 0 Тогда
		Возврат Строка;
	КонецЕсли;
	
	// Находим конец имени якоря
	КонецИмени = СтрДлина(Строка);
	Для Позиция = ПозицияЯкоря + 1 По СтрДлина(Строка) Цикл
		Символ = Сред(Строка, Позиция, 1);
		// Якорь заканчивается на пробеле, табуляции или конце строки
		Если Символ = " " ИЛИ Символ = Символы.Таб Тогда
			КонецИмени = Позиция - 1;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	// Удаляем определение якоря из строки
	ЧастьДо = Лев(Строка, ПозицияЯкоря - 1);
	ЧастьПосле = Сред(Строка, КонецИмени + 1);
	
	Возврат СокрЛП(ЧастьДо + ЧастьПосле);
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ИНИЦИАЛИЗАЦИЯ МОДУЛЯ
////////////////////////////////////////////////////////////////////////////////

// Инициализация константы YAML символов
YAML_РАЗДЕЛИТЕЛЬ_ДОКУМЕНТА = "---";
YAML_ТЕРМИНАТОР_ДОКУМЕНТА = "...";

// Инициализация констант для работы со строками
МИНИМАЛЬНАЯ_ДЛИНА_ДЛЯ_ПОДСТРОКИ = 2;
ДЕЙСТВИЕ_ПРЕРВАТЬ = "прервать";
ОШИБКА_ЛИШНИЕ_ЗАПЯТЫЕ_FLOW = "Flow последовательность содержит лишние запятые";

// Инициализация констант парсинга
ДЛИНА_ПРЕФИКСА_ШЕСТНАДЦАТЕРИЧНОГО_ЧИСЛА = 2;
ОСНОВАНИЕ_ДЕСЯТИЧНОЙ_СИСТЕМЫ = 10;
ОСНОВАНИЕ_ШЕСТНАДЦАТЕРИЧНОЙ_СИСТЕМЫ = 16;

// Инициализация констант типов кавычек
ТИП_КАВЫЧЕК_ДВОЙНЫЕ = "double";
ТИП_КАВЫЧЕК_ОДИНАРНЫЕ = "single";

// Инициализация логгера модуля
Лог = Логирование.ПолучитьЛог("oscript.oscript-yaml.deserializer");

// Хранилище TAG директив для текущего документа
ТекущиеТАГДирективы = Новый Соответствие();

// Флаг наличия YAML директивы в текущем документе
ВстречалаYAMLДиректива = Ложь;

// Инициализация кэша якорей
Якоря = Новый Соответствие;

// Инициализация кэша регулярных выражений
КэшРегулярныхВыражений = Новый Соответствие();
КэшРегулярныхВыражений.Вставить("пробелы", Новый РегулярноеВыражение("[ \t]"));
КэшРегулярныхВыражений.Вставить("спецСимволы", "[\]{}()*+?.^$|");

// Инициализация статического массива управляющих символов
СтатическийМассивУправляющихСимволов = Новый Массив();
СтатическийМассивУправляющихСимволов.Добавить(":");
СтатическийМассивУправляющихСимволов.Добавить("-");
СтатическийМассивУправляющихСимволов.Добавить("[");
СтатическийМассивУправляющихСимволов.Добавить("{");
СтатическийМассивУправляющихСимволов.Добавить("|");
СтатическийМассивУправляющихСимволов.Добавить(">");
СтатическийМассивУправляющихСимволов.Добавить("&");
СтатическийМассивУправляющихСимволов.Добавить("*");
СтатическийМассивУправляющихСимволов.Добавить("!");
СтатическийМассивУправляющихСимволов.Добавить("?");

// Инициализация кэша типов строк
КэшТиповСтрок = Новый Соответствие();
////////////////////////////////////////////////////////////////////////////////
// АРХИТЕКТУРНЫЕ ЗАМЕТКИ
//
// Модуль организован по принципу разделения ответственности:
// 1. Публичные методы - точки входа в модуль
// 2. Методы работы с документами - разбиение на документы, обработка разделителей
// 3. Методы работы со строками и комментариями - очистка, обработка кавычек
// 4. Методы определения типов данных - анализ содержимого для выбора парсера
// 5. Основные парсеры типов данных - парсинг различных YAML-структур
// 6. Парсеры многострочных строк - специальная обработка | и > синтаксиса
// 7. Вспомогательные методы для flow-синтаксиса - парсинг [...] и {...}
// 8. Вспомогательные методы для строк и отступов - работа с форматированием
// 9. Методы валидации и проверки синтаксиса - контроль корректности YAML
//
// Каждая секция содержит логически связанные функции, что упрощает навигацию
// и поддержку кода.
////////////////////////////////////////////////////////////////////////////////